{
  "name": "agoraiq",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @agoraiq/api dev",
    "dev:tracker": "pnpm --filter @agoraiq/tracker dev",
    "dev:telegram": "pnpm --filter @agoraiq/telegram dev",
    "dev:web": "pnpm --filter @agoraiq/web dev",
    "db:generate": "pnpm --filter @agoraiq/db generate",
    "db:migrate": "pnpm --filter @agoraiq/db migrate",
    "db:seed": "pnpm --filter @agoraiq/db seed",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3",
    "socks-proxy-agent": "^8.0.4",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
