  if (!cfg) return 'api';
  if (cfg.source === 'telegram' || cfg.channel || cfg.telegramChannel) return 'telegram';
  if (cfg.discordChannelId) return 'discord';
  if (cfg.webhookSecret) return 'webhook';
  return 'api';
}
function getCatColor(cat) {
  if (cat === 'spot') return '#22d3ee';
