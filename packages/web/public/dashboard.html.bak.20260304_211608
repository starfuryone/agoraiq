  // Build bar chart data
  const maxRet = Math.max(...months.map(m => Math.abs(m.totalReturn || 0)), 1);

  const rows = months.map(m => {
    const pct = Math.abs(m.totalReturn || 0) / maxRet * 100;
    const isPos = (m.totalReturn || 0) >= 0;
    const color = isPos ? 'var(--green)' : 'var(--red)';
    const lossCount = (m.signals || 0) - (m.wins || 0) - (m.expired || 0);
    return `
      <tr style="border-bottom:1px solid var(--border);">
        <td style="padding:10px 12px;font-weight:600;color:var(--text);white-space:nowrap;">${m.month}</td>
