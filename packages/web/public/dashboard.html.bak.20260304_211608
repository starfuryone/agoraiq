let logPage = 1;
async function fetchSignalLog(page) {
  logPage = page || 1;
  try {
    const r = await fetch(API + '/signal-log?page=' + logPage + '&limit=20', { headers: headers() });
    const d = await r.json();
    const entries = d.entries || [];
    const p = d.pagination || {};
    if (!entries.length) {
      document.getElementById('log-table').innerHTML = '<div class="empty-state" style="padding:48px">No saved signals yet</div>';
      document.getElementById('log-pagination').innerHTML = '';
      return;
    }
    const rows = entries.map(function(e) {
      const tps = e.takeProfits || [];
      const tpStr = tps.length ? tps.map(function(v,i){ return 'TP'+(i+1)+': '+v; }).join(' / ') : '-';
      const dirColor = e.direction==='LONG' ? 'var(--green)' : e.direction==='SHORT' ? 'var(--red)' : 'var(--text3)';
      const entry = e.entryMin ? (e.entryMin===e.entryMax ? e.entryMin : e.entryMin+'-'+e.entryMax) : '-';
      const conf = e.confidence ? Math.round(e.confidence*100)+'%' : '-';
      const delBtn = '<button onclick="deleteLogEntry(\'' + e.id + '\')" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;padding:2px 8px;border-radius:4px" onmouseenter="this.style.color=\'var(--red)\';this.style.background=\'var(--red-dim)\'" onmouseleave="this.style.color=\'var(--text3)\';this.style.background=\'none\'">&#x2715;</button>';
      return '<tr>'
        +'<td style="font-family:var(--mono);font-size:11px;color:var(--text3)">'+new Date(e.createdAt).toLocaleString()+'</td>'
        +'<td style="font-weight:700">'+e.symbol+'</td>'
        +'<td style="color:'+dirColor+';font-weight:700">'+(e.direction||'-')+'</td>'
        +'<td style="font-family:var(--mono);font-size:12px">'+entry+'</td>'
        +'<td style="font-family:var(--mono);font-size:11px;color:var(--red)">'+(e.stopLoss||'-')+'</td>'
        +'<td style="font-size:11px;color:var(--text3)">'+tpStr+'</td>'
        +'<td style="font-family:var(--mono);font-size:11px">'+(e.leverage ? e.leverage+'x' : '-')+'</td>'
        +'<td style="font-family:var(--mono);font-size:11px">'+conf+'</td>'
        +'<td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;color:var(--text3)">'+(e.note||'')+'</td>'
        +'<td>'+delBtn+'</td>'
        +'</tr>';
    });
    document.getElementById('log-table').innerHTML = '<table><thead><tr><th>Saved</th><th>Symbol</th><th>Dir</th><th>Entry</th><th>SL</th><th>Take Profits</th><th>Lev</th><th>Conf</th><th>Note</th><th></th></tr></thead><tbody>'+rows.join('')+'</tbody></table>';
    const totalPages = Math.min(p.totalPages||1, 10);
    const btns = [];
    for (let i=1; i<=totalPages; i++) btns.push('<button class="page-btn '+(i===logPage?'active':'')+'" onclick="fetchSignalLog('+i+')">'+i+'</button>');
    document.getElementById('log-pagination').innerHTML = btns.join('');
  } catch(e) {
    document.getElementById('log-table').innerHTML = '<div class="empty-state">Error: '+e.message+'</div>';
  }
}

