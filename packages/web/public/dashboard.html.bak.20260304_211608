async function saveToSignalLog(parsed, rawMessage) {
  const btn = document.getElementById('save-log-btn');
  if (btn) { btn.disabled = true; btn.textContent = 'Saving...'; }
  const sig = parsed.data || {};
  const note = window.prompt('Add a note (optional):', '') || '';
  try {
    const r = await fetch(API + '/signal-log', {
      method: 'POST', headers: headers(),
      body: JSON.stringify({
        symbol: sig.pair, direction: sig.direction,
        entryMin: sig.entryMin || null, entryMax: sig.entryMax || null,
        stopLoss: sig.stopLoss || null, takeProfits: sig.takeProfits || [],
        leverage: sig.leverage || null, marketType: sig.marketType || null,
        confidence: parsed.confidence || null, rawMessage, note: note || null,
      })
    });
    const d2 = await r.json();
    if (!d2.ok) throw new Error(d2.error);
    if (btn) {
      btn.textContent = '\u2713 Saved to Log!';
      btn.style.cssText = 'background:var(--green-dim);border:1px solid rgba(52,211,153,.3);border-radius:6px;color:var(--green);font-size:12px;font-weight:600;padding:8px 16px;width:100%';
    }
  } catch(e) {
    if (btn) { btn.disabled = false; btn.textContent = 'Save to Personal Log'; }
    alert('Failed: ' + e.message);
  }
}

