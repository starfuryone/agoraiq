<!doctype html>
<html lang="en">
<head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>AgoraIQ — Signal Intelligence Console</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --font: 'IBM Plex Sans', sans-serif;
  --mono: 'IBM Plex Mono', monospace;
  --bg: #060a14;
  --bg2: #0b0f1a;
  --bg3: #111827;
  --card: #0d1220;
  --card-hover: #111828;
  --border: #1a2236;
  --border2: #243049;
  --accent: #a78bfa;
  --accent-dim: rgba(167,139,250,.10);
  --accent-border: rgba(167,139,250,.20);
  --accent-glow: rgba(167,139,250,.06);
  --green: #34d399;
  --green-dim: rgba(52,211,153,.10);
  --red: #f87171;
  --red-dim: rgba(248,113,113,.10);
  --blue: #38bdf8;
  --blue-dim: rgba(56,189,248,.10);
  --amber: #fbbf24;
  --amber-dim: rgba(251,191,36,.10);
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --dim: #475569;
  --sidebar-w: 220px;
  --topbar-h: 52px;
  --r: 8px;
  --r-lg: 12px;
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
body {
  font-family: var(--font); font-size: 14px; line-height: 1.5;
  background: var(--bg); color: var(--text);
  -webkit-font-smoothing: antialiased;
  overflow: hidden; height: 100vh;
}
a { color: inherit; text-decoration: none; }
button { font-family: var(--font); cursor: pointer; border: none; background: none; color: inherit; }

/* ── App Shell ─────────────────────────────────────── */
.app { display: grid; grid-template-columns: var(--sidebar-w) 1fr; grid-template-rows: var(--topbar-h) 1fr; height: 100vh; }

/* ── Sidebar ───────────────────────────────────────── */
.sidebar {
  grid-row: 1 / -1; background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  padding: 0; overflow-y: auto;
}
.sidebar-logo {
  display: flex; align-items: center; gap: 10px;
  padding: 16px 20px; border-bottom: 1px solid var(--border);
  text-decoration: none;
}
.sidebar-logo svg { flex-shrink: 0; }
.sidebar-logo .mark { font-size: 14px; font-weight: 700; letter-spacing: -.02em; }
.sidebar-logo .mark .a { color: var(--text); }
.sidebar-logo .mark .b { color: #00e5ff; }
.sidebar-label {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .08em; color: var(--text3); padding: 20px 20px 8px;
}
.sidebar-nav { display: flex; flex-direction: column; gap: 2px; padding: 0 8px; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: var(--r);
  font-size: 13px; font-weight: 500; color: var(--text2);
  cursor: pointer; transition: all .15s; position: relative;
}
.nav-item:hover { background: var(--accent-glow); color: var(--text); }
.nav-item.active {
  background: var(--accent-dim); color: var(--accent);
  font-weight: 600;
}
.nav-item.active::before {
  content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
  width: 3px; height: 20px; border-radius: 0 3px 3px 0;
  background: var(--accent);
}
.nav-icon { width: 18px; text-align: center; font-size: 14px; flex-shrink: 0; opacity: .7; }
.nav-item.active .nav-icon { opacity: 1; }
.nav-badge {
  margin-left: auto; font-family: var(--mono); font-size: 10px;
  font-weight: 600; padding: 2px 7px; border-radius: 10px;
  background: var(--accent-dim); color: var(--accent);
}
.sidebar-spacer { flex: 1; }
.sidebar-plan {
  margin: 8px; padding: 14px; border-radius: var(--r);
  background: var(--bg3); border: 1px solid var(--border);
}
.sidebar-plan .plan-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text3); margin-bottom: 6px; }
.sidebar-plan .plan-name { font-size: 14px; font-weight: 700; color: var(--accent); }
.sidebar-plan .plan-btn {
  display: block; width: 100%; margin-top: 10px; padding: 7px 0;
  text-align: center; border-radius: 6px; font-size: 12px; font-weight: 600;
  background: linear-gradient(135deg, #a78bfa, #7c3aed); color: #fff;
  transition: opacity .15s;
}
.sidebar-plan .plan-btn:hover { opacity: .85; }
.nav-item.sub {
  padding-left: 32px;
  font-size: 12px;
  color: var(--text3);
}
.nav-item.sub::before { display: none !important; }
.nav-item.sub .nav-icon { font-size: 11px; opacity: 0.5; }
.nav-item.sub.active { color: var(--text); background: var(--accent-dim); }


/* ── Topbar ────────────────────────────────────────── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24px; border-bottom: 1px solid var(--border);
  background: var(--bg2);
}
.topbar-left { display: flex; align-items: center; gap: 16px; }
.topbar-title { font-size: 15px; font-weight: 600; color: var(--text); letter-spacing: -.01em; }
.topbar-breadcrumb { font-size: 12px; color: var(--text3); }

.topbar-stats { display: flex; align-items: center; gap: 20px; }
.topbar-stat { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text2); }
.topbar-stat .dot {
  width: 6px; height: 6px; border-radius: 50%;
}
.dot-green { background: var(--green); box-shadow: 0 0 6px var(--green); }
.dot-amber { background: var(--amber); }
.dot-red { background: var(--red); }
.topbar-stat .val { font-family: var(--mono); font-weight: 600; color: var(--text); }

.topbar-right { display: flex; align-items: center; gap: 12px; }
.topbar-email { font-size: 12px; color: var(--text3); }
.btn-logout {
  font-size: 12px; font-weight: 500; color: var(--text3);
  padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border);
  transition: all .15s;
}
.btn-logout:hover { color: var(--red); border-color: rgba(248,113,113,.3); }

/* ── Main Content ──────────────────────────────────── */
.main {
  overflow-y: auto; padding: 24px;
  background: var(--bg);
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

/* ── Page Header ───────────────────────────────────── */
.page-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24px;
}
.page-header h2 { font-size: 20px; font-weight: 700; letter-spacing: -.02em; }
.page-header .subtitle { font-size: 13px; color: var(--text3); margin-top: 2px; }

/* ── KPI Cards ─────────────────────────────────────── */
.kpi-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px; }
.kpi {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--r-lg);
  padding: 18px 20px; position: relative; overflow: hidden;
  transition: border-color .2s;
}
.kpi:hover { border-color: var(--border2); }
.kpi::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  border-radius: var(--r-lg) var(--r-lg) 0 0; opacity: .6;
}
.kpi.kpi-accent::after { background: var(--accent); }
.kpi.kpi-green::after { background: var(--green); }
.kpi.kpi-red::after { background: var(--red); }
.kpi.kpi-blue::after { background: var(--blue); }
.kpi.kpi-amber::after { background: var(--amber); }
.kpi-label { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .06em; color: var(--text3); margin-bottom: 8px; }
.kpi-value { font-family: var(--mono); font-size: 28px; font-weight: 700; letter-spacing: -.03em; line-height: 1; }
.kpi-sub { font-family: var(--mono); font-size: 11px; color: var(--dim); margin-top: 6px; }

/* ── Cards ─────────────────────────────────────────── */
.card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--r-lg);
  padding: 20px; margin-bottom: 16px;
}
.card-title {
  font-size: 13px; font-weight: 600; color: var(--text);
  margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
}
.card-title .icon { font-size: 15px; opacity: .6; }

/* ── Tables ────────────────────────────────────────── */
table { width: 100%; border-collapse: collapse; }
thead th {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .06em; color: var(--text3);
  padding: 10px 14px; text-align: left;
  border-bottom: 1px solid var(--border);
  background: var(--bg3);
  position: sticky; top: 0;
}
thead th:first-child { border-radius: var(--r) 0 0 0; }
thead th:last-child { border-radius: 0 var(--r) 0 0; }
tbody td {
  padding: 11px 14px; font-size: 13px;
  border-bottom: 1px solid rgba(26,34,54,.6);
  transition: background .1s;
}
tbody tr { cursor: pointer; }
tbody tr:hover td { background: var(--accent-glow); }
tbody tr:last-child td { border-bottom: none; }

/* ── Badges ────────────────────────────────────────── */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-family: var(--mono); font-size: 11px; font-weight: 600;
  padding: 3px 10px; border-radius: 6px;
}
.badge-active { background: var(--blue-dim); color: var(--blue); }
.badge-tp { background: var(--green-dim); color: var(--green); }
.badge-sl { background: var(--red-dim); color: var(--red); }
.badge-exp { background: rgba(100,116,139,.15); color: var(--text3); }
.badge-pending { background: var(--amber-dim); color: var(--amber); }

.pos { color: var(--green); }
.neg { color: var(--red); }

/* ── Filters ───────────────────────────────────────── */
.filters { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.filter-input {
  height: 34px; padding: 0 12px; border-radius: 6px;
  border: 1px solid var(--border); background: var(--bg3);
  color: var(--text); font-size: 12px; font-family: var(--font);
  outline: none; transition: border-color .15s;
}
.filter-input:focus { border-color: var(--accent-border); }
select.filter-input { cursor: pointer; }

/* ── Buttons ───────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  height: 34px; padding: 0 14px; border-radius: 6px;
  font-size: 12px; font-weight: 600; transition: all .15s;
}
.btn-accent { background: var(--accent-dim); color: var(--accent); border: 1px solid var(--accent-border); }
.btn-accent:hover { background: rgba(167,139,250,.16); }
.btn-ghost { color: var(--text2); border: 1px solid var(--border); }
.btn-ghost:hover { border-color: var(--border2); color: var(--text); }
.btn-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(52,211,153,.2); }
.btn-green:hover { background: rgba(52,211,153,.16); }
.btn-danger { color: var(--red); border: 1px solid rgba(248,113,113,.2); }
.btn-danger:hover { background: var(--red-dim); }

/* ── Pagination ────────────────────────────────────── */
.pagination { display: flex; justify-content: center; gap: 4px; margin-top: 16px; }
.page-btn {
  width: 32px; height: 32px; border-radius: 6px;
  border: 1px solid var(--border); background: var(--card);
  color: var(--text2); font-size: 12px; font-weight: 500;
  display: grid; place-items: center; transition: all .15s;
}
.page-btn.active { background: var(--accent-dim); border-color: var(--accent-border); color: var(--accent); font-weight: 700; }
.page-btn:hover:not(.active) { border-color: var(--border2); }
.page-btn:disabled { opacity: .3; cursor: default; }

/* ── Watchlist ─────────────────────────────────────── */
.wl-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 0; border-bottom: 1px solid var(--border);
}
.wl-item:last-child { border-bottom: none; }
.wl-remove { color: var(--red); cursor: pointer; font-size: 12px; font-weight: 500; padding: 4px 8px; border-radius: 4px; transition: background .15s; }
.wl-remove:hover { background: var(--red-dim); }
.wl-dot { display:inline-block; width:7px; height:7px; border-radius:50%; background:var(--accent); margin-right:2px; animation:wlPulse 1.4s ease-in-out infinite; }
.wl-dot:nth-child(2) { animation-delay:.2s; }
.wl-dot:nth-child(3) { animation-delay:.4s; }
@keyframes wlPulse { 0%,80%,100%{opacity:.25;transform:scale(.8)} 40%{opacity:1;transform:scale(1)} }
.wl-add { display: flex; gap: 8px; margin-top: 12px; }

/* ── Overview Grid ─────────────────────────────────── */
.overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.overview-full { grid-column: 1 / -1; }

/* ── Settings Form ─────────────────────────────────── */
.settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid var(--border); }
.setting-row:last-child { border-bottom: none; }
.setting-label { font-size: 13px; font-weight: 500; }
.setting-desc { font-size: 12px; color: var(--text3); margin-top: 2px; }
.setting-value { font-family: var(--mono); font-size: 13px; color: var(--text2); }

/* ── Proof Hash ────────────────────────────────────── */
.proof-hash {
  font-family: var(--mono); font-size: 11px; color: var(--text3);
  background: var(--bg3); padding: 4px 8px; border-radius: 4px;
  max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* ── Loading / Empty ───────────────────────────────── */
.loading-state { text-align: center; padding: 48px 20px; color: var(--text3); }
.loading-state .spinner {
  width: 24px; height: 24px; border: 2px solid var(--border);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin .7s linear infinite; margin: 0 auto 12px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 48px 20px; color: var(--text3); font-size: 13px; }

/* ── Responsive ────────────────────────────────────── */
@media (max-width: 900px) {
  .app { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .overview-grid { grid-template-columns: 1fr; }
  .settings-grid { grid-template-columns: 1fr; }
  .topbar-stats { display: none; }
}
@media (max-width: 600px) {
  .kpi-grid { grid-template-columns: 1fr 1fr; }
  .main { padding: 16px; }
}

/* ── Fade In Animation ─────────────────────────────── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeUp .3s ease both; }
.fade-in-1 { animation-delay: .05s; }
.fade-in-2 { animation-delay: .10s; }
.fade-in-3 { animation-delay: .15s; }
.fade-in-4 { animation-delay: .20s; }
.fade-in-5 { animation-delay: .25s; }
</style>
</head>
<body>

<div class="app">

