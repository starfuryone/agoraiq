// ── Inject Ticker Bar into DOM ────────────────────────────────
function injectTickerBar() {
  var topbar = document.querySelector('.topbar');
  if (!topbar || document.getElementById('ticker-bar')) return;
  var bar = document.createElement('div');
  bar.className = 'ticker-bar';
  bar.id = 'ticker-bar';
  bar.innerHTML = '<div class="ticker-track" id="ticker-track"></div>';
  topbar.parentNode.insertBefore(bar, topbar.nextSibling);
  // Fix grid to accommodate ticker
  var app = document.querySelector('.app');
  if (app) app.style.gridTemplateRows = 'var(--topbar-h) 30px 1fr';
}

// ── Format Price ──────────────────────────────────────────────
function fmtPrice(p) {
  p = parseFloat(p);
  if (p >= 1000) return '$' + p.toLocaleString(undefined, {maximumFractionDigits:0});
  if (p >= 1) return '$' + p.toFixed(2);
  if (p >= 0.01) return '$' + p.toFixed(4);
  return '$' + p.toFixed(6);
}

function fmtVol(v) {
  v = parseFloat(v);
  if (v >= 1e9) return (v/1e9).toFixed(1) + 'B';
  if (v >= 1e6) return (v/1e6).toFixed(1) + 'M';
  if (v >= 1e3) return (v/1e3).toFixed(0) + 'K';
  return v.toFixed(0);
}

// ── Mini Sparkline (last 8 hours via klines) ──────────────────
function renderSparkBars(data) {
  if (!data || data.length === 0) return '';
  var min = Math.min.apply(null, data);
  var max = Math.max.apply(null, data);
  var range = max - min || 1;
  var isUp = data[data.length-1] >= data[0];
  var color = isUp ? '#34d399' : '#f87171';
  return '<div class="ticker-spark">' + data.map(function(v) {
    var h = Math.max(2, Math.round(((v - min) / range) * 12));
    return '<div class="ticker-spark-bar" style="height:' + h + 'px;background:' + color + '"></div>';
  }).join('') + '</div>';
}

// ── Fetch Ticker Data ─────────────────────────────────────────
async function fetchTickerData() {
  try {
    var pairs = TICKER_COINS.map(function(s){ return KRAKEN_PAIRS[s]; }).filter(Boolean).join(',');
    var r = await fetch('https://api.kraken.com/0/public/Ticker?pair=' + pairs);
    var json = await r.json();
    if (json.error && json.error.length) throw new Error(json.error[0]);
    Object.entries(json.result).forEach(function(entry) {
      var krakenKey = entry[0], t = entry[1];
      var sym = KRAKEN_RMAP[krakenKey];
      if (!sym) return;
      var price  = parseFloat(t.c[0]);
      var open24 = parseFloat(t.o);
      var chgPct = ((price - open24) / open24) * 100;
      // Normalise to same shape updateTickerBar() expects
      tickerData[sym] = {
        lastPrice:          t.c[0],
        priceChangePercent: chgPct.toFixed(2),
      };
    });
    updateTickerBar();
  } catch(e) {
    console.warn('Ticker fetch error (Kraken):', e);
  }
}

// ── Fetch Sparkline Data ──────────────────────────────────────
var sparkData = {};
async function fetchSparklines() {
  // Kraken OHLC: interval=60 = 1h candles, close price is index 4
  for (var i = 0; i < TICKER_COINS.length; i++) {
    var binSym  = TICKER_COINS[i];
    var krakPair = KRAKEN_PAIRS[binSym];
    if (!krakPair) continue;
    try {
      var r = await fetch('https://api.kraken.com/0/public/OHLC?pair=' + krakPair + '&interval=60');
      var json = await r.json();
      if (json.error && json.error.length) continue;
      var pairKey = Object.keys(json.result).find(function(k){ return k !== 'last'; });
      if (!pairKey) continue;
      var candles = json.result[pairKey].slice(-8); // last 8 hourly candles
      sparkData[binSym] = candles.map(function(k) { return parseFloat(k[4]); });
    } catch(e) {}
  }
  updateTickerBar();
}

// ── Update Ticker Bar ─────────────────────────────────────────
function updateTickerBar() {
  var track = document.getElementById('ticker-track');
  if (!track) return;

  var items = '';
  TICKER_COINS.forEach(function(sym) {
    var t = tickerData[sym];
    if (!t) return;
    var name = NAMES[sym] || sym;
    var icon = ICONS[name] || '●';
    var price = fmtPrice(t.lastPrice);
    var chg = parseFloat(t.priceChangePercent);
    var chgClass = chg >= 0 ? 'ticker-up' : 'ticker-down';
    var chgStr = (chg >= 0 ? '+' : '') + chg.toFixed(2) + '%';
    var spark = renderSparkBars(sparkData[sym] || []);

    items += '<div class="ticker-item">' +
      '<span class="ticker-icon">' + icon + '</span>' +
      '<span class="ticker-name">' + name + '</span>' +
      '<span class="ticker-price">' + price + '</span>' +
      '<span class="ticker-chg ' + chgClass + '">' + chgStr + '</span>' +
      spark +
      '</div>';
  });

  // Duplicate for seamless scroll
  track.innerHTML = items + items;
}

// ── Market Overview Widget (for Overview page) ────────────────
window.renderMarketOverview = function() {
  var container = document.getElementById('market-overview');
  if (!container) return;

  if (Object.keys(tickerData).length === 0) {
    container.innerHTML = '<div class="loading-state"><div class="spinner"></div></div>';
    return;
  }

  var html = '<div class="market-grid">';
  TICKER_COINS.forEach(function(sym) {
    var t = tickerData[sym];
    if (!t) return;
    var name = NAMES[sym] || sym;
    var icon = ICONS[name] || '●';
    var price = fmtPrice(t.lastPrice);
    var chg = parseFloat(t.priceChangePercent);
    var chgClass = chg >= 0 ? 'ticker-up' : 'ticker-down';
    var chgStr = (chg >= 0 ? '+' : '') + chg.toFixed(2) + '%';
    var vol = fmtVol(t.quoteVolume);
    var high = fmtPrice(t.highPrice);
    var low = fmtPrice(t.lowPrice);
    var spark = sparkData[sym] || [];

    // Mini canvas sparkline for market card
    var sparkHtml = '';
    if (spark.length > 0) {
      var svgW = 80, svgH = 24;
      var min = Math.min.apply(null, spark);
      var max = Math.max.apply(null, spark);
      var range = max - min || 1;
      var pts = spark.map(function(v, i) {
        return (i / (spark.length - 1)) * svgW + ',' + (svgH - ((v - min) / range) * svgH);
      }).join(' ');
      var col = chg >= 0 ? '#34d399' : '#f87171';
      sparkHtml = '<svg width="' + svgW + '" height="' + svgH + '" style="display:block;margin-top:8px">' +
        '<polyline points="' + pts + '" fill="none" stroke="' + col + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' +
        '</svg>';
    }

    html += '<div class="market-coin">' +
      '<div class="market-coin-head">' +
        '<div class="market-coin-name"><span class="market-coin-icon">' + icon + '</span>' + name + '</div>' +
        '<span class="ticker-chg ' + chgClass + '">' + chgStr + '</span>' +
      '</div>' +
      '<div class="market-coin-price">' + price + '</div>' +
      sparkHtml +
      '<div class="market-coin-row"><span>24h Vol</span><span class="val">$' + vol + '</span></div>' +
      '<div class="market-coin-row"><span>High</span><span class="val" style="color:var(--green)">' + high + '</span></div>' +
      '<div class="market-coin-row"><span>Low</span><span class="val" style="color:var(--red)">' + low + '</span></div>' +
    '</div>';
  });
  html += '</div>';
  container.innerHTML = html;
};

