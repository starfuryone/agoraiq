<script>
// ── Auth ──────────────────────────────────────────────────────
const TOKEN = localStorage.getItem('agoraiq_token');
if (!TOKEN) window.location.href = '/login';
const API = '/api/v1/dashboard';
const BILLING_API = '/api/v1/billing';
const headers = () => ({ 'Authorization': `Bearer ${TOKEN}`, 'Content-Type': 'application/json' });
function logout() { localStorage.removeItem('agoraiq_token'); window.location.href = '/login'; }

// ── State ─────────────────────────────────────────────────────
let currentPage = 'overview';
let userInfo = null;
let planInfo = { planTier: 'FREE', subscriptionStatus: 'inactive' };
let sigPage = 1;

// ── Init ──────────────────────────────────────────────────────
async function init() {
  try {
    const r = await fetch('/api/v1/auth/me', { headers: headers() });
    const d = await r.json();
    if (d.error) { logout(); return; }
    userInfo = d.user;
    document.getElementById('user-email').textContent = d.user?.email || '';

    // Plan info from /me response
    if (d.subscription) {
      planInfo.planTier = d.subscription.planTier || d.subscription.tier?.toUpperCase() || 'FREE';
      planInfo.subscriptionStatus = d.subscription.subscriptionStatus || d.subscription.status || 'inactive';
      // Show Marketplace nav for Pro/Elite
      const mpNav = document.getElementById("marketplace-nav");
      if (mpNav && ["PRO","ELITE"].includes(planInfo.planTier)) { mpNav.style.display = "flex"; }
    }

    // Try billing status for more accurate data
    try {
      const br = await fetch(`${BILLING_API}/status`, { headers: headers() });
      if (br.ok) {
        const bd = await br.json();
        planInfo = { ...planInfo, ...bd };
      }
    } catch(e) {}

    updatePlanUI();

    const urlParams = new URLSearchParams(window.location.search);
    const pageParam = urlParams.get('p');
    if (pageParam && pageNames[pageParam]) {
      currentPage = pageParam;
      document.querySelectorAll('.nav-item').forEach(n => {
        n.classList.toggle('active', n.dataset.page === pageParam);
      });
      document.getElementById('breadcrumb').textContent = pageNames[pageParam];
    }

    loadPage();
  } catch (e) { logout(); }
}

function updatePlanUI() {
