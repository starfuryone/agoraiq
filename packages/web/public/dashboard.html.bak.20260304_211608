async function addWatchlist() {
  const type = document.getElementById('wl-type').value;
  const value = document.getElementById('wl-value').value;
  if (!value) return;
  await fetch(`${API}/watchlists`, { method: 'POST', headers: headers(), body: JSON.stringify({ type, value }) });
  document.getElementById('wl-value').value = '';
  fetchWatchlists();
}

async function removeWatchlist(id) {
  await fetch(`${API}/watchlists/${id}`, { method: 'DELETE', headers: headers() });
  fetchWatchlists();
}

