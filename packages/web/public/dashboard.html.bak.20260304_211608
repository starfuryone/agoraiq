async function fetchSignals() {
  const sym = document.getElementById('f-symbol')?.value || '';
  const act = document.getElementById('f-action')?.value || '';
  const prov = document.getElementById('f-provider')?.value || '';
  let url = `${API}/signals?page=${sigPage}&limit=20`;
  if (sym) url += `&symbol=${encodeURIComponent(sym)}`;
  if (act) url += `&action=${encodeURIComponent(act)}`;
  if (prov) url += `&provider=${encodeURIComponent(prov)}`;
  try {
    const r = await fetch(url, { headers: headers() });
    const d = await r.json();
    if (d.error) { document.getElementById('signals-table').innerHTML = `<div class="empty-state">${d.message || d.error}</div>`; return; }
    const rows = (d.signals || []).map(s => {
      const t = s.trade || {};
      const rVal = t.rMultiple != null ? `<span class="${t.rMultiple >= 0 ? 'pos' : 'neg'}">${t.rMultiple >= 0 ? '+' : ''}${t.rMultiple.toFixed(2)}R</span>` : '<span style="color:var(--dim)">—</span>';
      return `<tr>
        <td style="font-family:var(--mono);font-size:12px;color:var(--text3)">${new Date(s.signalTs).toLocaleString()}</td>
        <td><strong>${s.symbol}</strong></td>
        <td>${s.timeframe}</td>
        <td>${s.action}</td>
        <td style="font-family:var(--mono)">${(s.confidence*100||0).toFixed(0)}%</td>
        <td>${s.providerKey}</td>
        <td>${statusBadge(t.status || 'PENDING')}</td>
        <td>${rVal}</td></tr>`;
    });
    document.getElementById('signals-table').innerHTML = rows.length
      ? `<table><thead><tr><th>Time</th><th>Symbol</th><th>TF</th><th>Action</th><th>Conf</th><th>Provider</th><th>Status</th><th>R</th></tr></thead><tbody>${rows.join('')}</tbody></table>`
      : '<div class="empty-state">No signals match your filters</div>';
    const p = d.pagination || {};
    const btns = [];
    const totalPages = Math.min(p.totalPages || 1, 10);
    for (let i = 1; i <= totalPages; i++) {
      btns.push(`<button class="page-btn ${i===sigPage?'active':''}" onclick="sigPage=${i};fetchSignals()">${i}</button>`);
    }
    document.getElementById('sig-pagination').innerHTML = btns.join('');
  } catch (e) { document.getElementById('signals-table').innerHTML = '<div class="empty-state">Error loading signals</div>'; }
}

