// ── Inspector ─────────────────────────────────────────────────────────────────
function openInspector(row) {
  const insp = document.getElementById('inspector');
  insp.style.display = 'flex';
  document.getElementById('insp-sym-label').textContent = row.symbol;
  document.getElementById('insp-ex-label').textContent  = row.exchangeDisplayName || row.exchange;
  switchTab(currentTab);
}
function closeInspector() {
  document.getElementById('inspector').style.display = 'none';
  selectedRow = null;
  selectedIdx = null;
  renderBody();
}
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.insp-tab').forEach(t =>
    t.classList.toggle('active', t.dataset.tab===tab));
  document.querySelectorAll('.insp-pane').forEach(p =>
    p.classList.toggle('active', p.id===`pane-${tab}`));
  if (selectedRow) loadTabContent(tab, selectedRow);
}
async function loadTabContent(tab, row) {
  if (tab==='overview') renderOverview(row);
  else if (tab==='compare') await renderCompare(row);
  else if (tab==='changelog' || tab==='sync' || tab==='raw') {
    await fetchDetail(row, tab);
  }
}

function renderOverview(row) {
  const pane = document.getElementById('pane-overview');
  const specs = [
    ['Status',    `<span class="status-badge ${statusCls(row.status)}">${statusLabel(row.status)}</span>`],
    ['Tick Size', `<code style="font-family:var(--mono);font-size:11px">${row.tickSize||'—'}</code>`],
    ['Min Qty',   `<code style="font-family:var(--mono);font-size:11px">${row.orderMin||'—'}</code>`],
    ['Min Value', `<code style="font-family:var(--mono);font-size:11px">${row.orderMinValue||'—'}</code>`],
    ['Price Dec', row.pairDecimals??'—'],
    ['Lot Dec',   row.lotDecimals??'—'],
    ['Margin',    row.marginAvailable?'<span style="color:var(--blue)">Yes</span>':'No'],
    ['Last Sync', fRel(row.lastSyncedAt)||'—'],
  ];
  const specRows = specs.map(([l,v])=>`<tr><td>${l}</td><td>${v}</td></tr>`).join('');

  const stats = [
    {label:'Last Price', val:fPrice(row.last)||'—', color:'var(--text)'},
    {label:'Bid',        val:fPrice(row.bid)||'—',  color:'var(--green)'},
    {label:'Ask',        val:fPrice(row.ask)||'—',  color:'var(--red)'},
    {label:'Spread',     val:fPrice(row.spreadAbs)||'—', color:'var(--text2)'},
    {label:'Spread bps', val:(fBps(row.spreadBps)||'—')+' bps', color:row.spreadBps!=null&&parseFloat(row.spreadBps)<5?'var(--green)':'var(--amber)'},
    {label:'Vol 24h',    val:fVol(row.volume24h)||'—', color:'var(--text2)'},
    {label:'Vol USD',    val:'$'+(fVol(row.volume24hUsd)||'—'), color:'var(--text3)'},
    {label:'Funding',    val:fFund(row.fundingRate)||'—', color:row.fundingRate!=null&&parseFloat(row.fundingRate)>=0?'var(--green)':'var(--red)'},
    {label:'Liquidity',  val:row.liquidityScore!=null?row.liquidityScore+'/100':'—', color:scoreColor(row.liquidityScore)},
    {label:'Volatility', val:row.volatilityScore!=null?row.volatilityScore+'/100':'—', color:scoreColor(100-row.volatilityScore)},
  ];
  const statCards = stats.map(s=>
    `<div class="stat-card">
      <div class="stat-card-label">${s.label}</div>
      <div class="stat-card-val" style="color:${s.color}">${s.val}</div>
    </div>`
  ).join('');

  const copyBtns = [
    ['Symbol',    row.symbol],
    ['TV Symbol', row.tvSymbol],
    ['Pair ID',   row.pairId],
  ].filter(([,v])=>v).map(([l,v])=>
    `<button class="copy-btn" onclick="doCopy('${v}',this)">
      Copy ${l}
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    </button>`
  ).join('');

  pane.innerHTML = `
    <div class="overview-left">
      <div style="margin-bottom:12px">
        <div style="font-size:16px;font-weight:700;color:var(--text)">${row.symbol}</div>
        <div style="font-size:11px;color:var(--text3);margin-top:2px">${row.pairId} · ${row.exchangeDisplayName||row.exchange}</div>
      </div>
      <table class="spec-table">${specRows}</table>
      <div class="copy-btns">${copyBtns}</div>
    </div>
    <div class="overview-right">
      <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);margin-bottom:8px">Live Market</div>
      <div class="stat-grid">${statCards}</div>
      ${row.statTs?`<div style="font-size:10px;color:var(--border2);margin-top:8px">Data snapshot: ${new Date(row.statTs).toLocaleTimeString()}</div>`:''}
