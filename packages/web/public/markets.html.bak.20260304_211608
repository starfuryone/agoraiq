async function renderCompare(row) {
  const pane = document.getElementById('pane-compare');
  pane.innerHTML = '<div class="empty-state">Loading cross-exchange data…</div>';
  try {
    const r = await fetch(`${MI_API}/compare?base=${row.baseCanonical}&quote=${row.quoteCanonical}`, { headers: AUTH() });
    const d = await r.json();
    const rows = d.data || [];
    if (!rows.length) {
      pane.innerHTML = '<div class="empty-state">No cross-exchange data available</div>';
      return;
    }
    const trs = rows.map(r => {
      const isCur = r.exchange===row.exchange;
      const bestTags = [
        r.isBestSpread?'<span class="best-tag best-spread">SPREAD</span>':'',
        r.isBestVolume?'<span class="best-tag best-vol">VOL</span>':'',
        r.isBestLiq   ?'<span class="best-tag best-liq">LIQ</span>':'',
      ].join('');
      return `<tr class="${isCur?'current':''}">
        <td>${exDot(r.tier||2)} <span style="margin-left:4px;font-weight:${isCur?600:400};color:${isCur?'var(--accent)':'var(--text2)'}">${r.displayName||r.exchange}</span></td>
        <td class="r cell-mono">${fPrice(r.last)||'—'}</td>
        <td class="r cell-mono" style="color:${r.isBestSpread?'var(--green)':'var(--text2)'}">${fBps(r.spreadBps)||'—'}</td>
        <td class="r cell-mono">${fVol(r.volume24h)||'—'}</td>
        <td class="r" style="color:${scoreColor(r.liquidityScore)};font-family:var(--mono)">${r.liquidityScore??'—'}</td>
        <td class="c"><span class="status-badge ${statusCls(r.status)}">${statusLabel(r.status)}</span></td>
        <td>${bestTags}</td>
      </tr>`;
    }).join('');
    pane.innerHTML = `
      <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);margin-bottom:8px">
        ${row.symbol} across all exchanges
      </div>
      <table class="compare-table">
        <thead><tr>
          <th>Exchange</th><th class="r">Price</th><th class="r">Spread bps</th>
          <th class="r">Vol 24h</th><th class="r">Liquidity</th>
          <th class="c">Status</th><th>Best</th>
        </tr></thead>
        <tbody>${trs}</tbody>
      </table>`;
  } catch(e) {
    pane.innerHTML = '<div class="empty-state">Failed to load comparison data</div>';
  }
}

let detailCache = {};
async function fetchDetail(row, tab) {
  const key = `${row.exchange}:${row.pairId}`;
  if (!detailCache[key]) {
    try {
      const r = await fetch(`${MI_API}/${row.exchange}/${row.pairId}`, { headers: AUTH() });
      detailCache[key] = await r.json();
    } catch(e) { detailCache[key] = {}; }
  }
  const data = detailCache[key];
  if (tab==='changelog') renderChangelog(data.changelog||[]);
  else if (tab==='sync') renderSync(data.syncHistory||[]);
  else if (tab==='raw') renderRaw(row, data);
}

function renderChangelog(rows) {
  const pane = document.getElementById('pane-changelog');
  if (!rows.length) { pane.innerHTML='<div class="empty-state">No changes recorded for this pair</div>'; return; }
  const trs = rows.map(r => {
    const typeCls = r.changeType==='DELIST'?'color:var(--red)':r.changeType==='RELIST'?'color:var(--green)':'color:var(--amber)';
    return `<tr>
      <td style="${typeCls};font-weight:600">${r.changeType}</td>
      <td>${r.fieldName}</td>
      <td style="color:var(--red)">${r.oldValue??'—'}</td>
      <td style="color:var(--green)">${r.newValue??'—'}</td>
      <td style="color:var(--text3)">${fRel(r.detectedAt)||'—'}</td>
    </tr>`;
  }).join('');
  pane.innerHTML = `<table class="changelog-table">
    <thead><tr><th>Type</th><th>Field</th><th>Old</th><th>New</th><th>Detected</th></tr></thead>
    <tbody>${trs}</tbody>
  </table>`;
}

function renderSync(rows) {
  const pane = document.getElementById('pane-sync');
  if (!rows.length) { pane.innerHTML='<div class="empty-state">No sync history available</div>'; return; }
  const trs = rows.map(r => {
    const sc = r.status==='SUCCESS'?'color:var(--green)':r.status==='FAILED'?'color:var(--red)':'color:var(--amber)';
    return `<tr>
      <td style="${sc};font-weight:600">${r.status}${r.errorMessage?`<div style="font-size:9px;color:var(--red);font-weight:400">${r.errorMessage.slice(0,40)}</div>`:''}</td>
      <td>${(r.totalFetched||0).toLocaleString()}</td>
      <td>${(r.totalUpserted||0).toLocaleString()}</td>
      <td style="color:var(--red)">${r.totalDelisted||0}</td>
      <td style="color:var(--amber)">${r.totalChanges||0}</td>
      <td style="color:var(--text3)">${r.durationMs?(r.durationMs/1000).toFixed(1)+'s':'—'}</td>
      <td style="color:var(--text3)">${fRel(r.startedAt)||'—'}</td>
    </tr>`;
  }).join('');
  pane.innerHTML = `<table class="changelog-table">
    <thead><tr><th>Status</th><th>Fetched</th><th>Upserted</th><th>Delisted</th><th>Changes</th><th>Duration</th><th>Started</th></tr></thead>
    <tbody>${trs}</tbody>
  </table>`;
}

function renderRaw(row, detail) {
  const pane = document.getElementById('pane-raw');
  pane.innerHTML = `<pre style="font-family:var(--mono);font-size:10px;color:var(--text3);background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:12px;overflow:auto;max-height:100%">${JSON.stringify({...row,...detail},null,2)}</pre>`;
}

function doCopy(text, btn) {
  navigator.clipboard.writeText(text);
  const orig = btn.innerHTML;
  btn.classList.add('copied');
  btn.innerHTML = btn.innerHTML.replace('Copy','Copied ✓');
  setTimeout(()=>{ btn.classList.remove('copied'); btn.innerHTML=orig; }, 1500);
}

// ── Live toggle ───────────────────────────────────────────────────────────────
function toggleLive() {
  liveOn = !liveOn;
  document.getElementById('live-btn').classList.toggle('live-btn', liveOn);
  document.getElementById('live-btn-label').textContent = liveOn?'LIVE':'PAUSED';
  document.getElementById('live-btn-dot').classList.toggle('active', liveOn);
  document.getElementById('live-dot').classList.toggle('active', liveOn);
  if (liveOn) connectWS(); else disconnectWS();
}

function connectWS() {
  const proto = location.protocol==='https:'?'wss:':'ws:';
  try {
    wsConn = new WebSocket(`${proto}//${location.host}/ws/markets`);
    wsConn.onmessage = (e) => {
      if (!liveOn) return;
      try {
        const msg = JSON.parse(e.data);
        if (msg.channel==='markets:snapshots' && Array.isArray(msg.rows)) {
          const map = new Map(allRows.map(r=>[`${r.exchange}:${r.pairId}`,r]));
          for (const s of msg.rows) {
            const k = `${s.exchange}:${s.pairId}`;
            if (map.has(k)) Object.assign(map.get(k), s);
          }
          applyClientFilters();
        }
      } catch(e){}
    };
    wsConn.onerror = wsConn.onclose = () => { wsConn=null; };
  } catch(e){}
}
function disconnectWS() {
  if (wsConn) { wsConn.close(); wsConn=null; }
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────────
function setupKeyboard() {
  document.addEventListener('keydown', e => {
    const tag = document.activeElement?.tagName;
    const inInput = tag==='INPUT'||tag==='TEXTAREA';

    if (e.key==='/' && !inInput) {
      e.preventDefault();
      document.getElementById('search-input').focus();
      return;
    }
    if (!inInput) {
      if (e.key==='e'||e.key==='E') openExchangeModal();
      if (e.key==='f'||e.key==='F') toggleRail();
      if (e.key==='c'||e.key==='C') openColumnsModal();
      if (e.key==='Escape') {
        closeInspector();
        document.getElementById('ex-modal').classList.add('hidden');
        document.getElementById('col-modal').classList.add('hidden');
      }
      if (e.key==='ArrowDown' && selectedIdx!==null && selectedIdx<filteredRows.length-1) {
        e.preventDefault();
        selectRow(selectedIdx+1);
        scrollToSelected();
      }
      if (e.key==='ArrowUp' && selectedIdx!==null && selectedIdx>0) {
        e.preventDefault();
        selectRow(selectedIdx-1);
        scrollToSelected();
      }
      if (e.key==='Enter' && selectedIdx!==null) {
        e.preventDefault();
        openInspector(selectedRow);
      }
    }
    if (e.key==='Escape' && inInput) {
      document.getElementById('search-input').blur();
    }
  });

  // Search debounce
  let searchTimer;
  document.getElementById('search-input').addEventListener('input', e => {
    searchVal = e.target.value.trim();
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      if (searchVal.length===0 || searchVal.length>=2) applyClientFilters();
    }, 200);
  });

  // Click outside modals
  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', e => {
      if (e.target===el) el.classList.add('hidden');
    });
  });
}

function scrollToSelected() {
  const row = document.querySelector('.grid-row.selected');
  if (row) row.scrollIntoView({ block:'nearest' });
}

// ── Inspector resize ──────────────────────────────────────────────────────────
function setupResize() {
  const handle = document.getElementById('insp-resize');
  let startY, startH;
  handle.addEventListener('mousedown', e => {
    e.preventDefault();
    startY = e.clientY;
    startH = parseInt(document.getElementById('inspector').style.height);
    const onMove = ev => {
      const delta = startY - ev.clientY;
      const newH = Math.max(180, Math.min(600, startH+delta));
      document.getElementById('inspector').style.height = newH+'px';
    };
    const onUp = () => {
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
    };
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onUp);
  });
}

// ── CSV Export ────────────────────────────────────────────────────────────────
function exportCSV() {
  const visCols = columns.filter(c=>c.vis);
  const header  = visCols.map(c=>c.label).join(',');
  const rows    = filteredRows.map(row =>
    visCols.map(c => {
      const v = row[c.key];
      if (v==null) return '';
      const s = String(v);
      return s.includes(',') ? `"${s}"` : s;
    }).join(',')
  );
  const csv  = [header,...rows].join('\n');
  const blob = new Blob([csv],{type:'text/csv'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href=url; a.download=`agoraiq-markets-${new Date().toISOString().slice(0,10)}.csv`;
  a.click(); URL.revokeObjectURL(url);
}

// ── Boot ──────────────────────────────────────────────────────────────────────
init();
</script>
