<!doctype html>
<html lang="en">
<head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>AgoraIQ — Markets Console</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --font: 'IBM Plex Sans', sans-serif;
  --mono: 'IBM Plex Mono', monospace;
  --bg:   #060a14;
  --bg2:  #0b0f1a;
  --bg3:  #111827;
  --card: #0d1220;
  --card-hover: #111828;
  --border:  #1a2236;
  --border2: #243049;
  --accent:       #a78bfa;
  --accent-dim:   rgba(167,139,250,.10);
  --accent-border:rgba(167,139,250,.20);
  --accent-glow:  rgba(167,139,250,.06);
  --green:     #34d399;
  --green-dim: rgba(52,211,153,.10);
  --red:       #f87171;
  --red-dim:   rgba(248,113,113,.10);
  --blue:      #38bdf8;
  --blue-dim:  rgba(56,189,248,.10);
  --amber:     #fbbf24;
  --amber-dim: rgba(251,191,36,.10);
  --text:  #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --dim:   #475569;
  --sidebar-w: 220px;
  --topbar-h:  52px;
  --r: 8px;
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html, body { height:100vh; overflow:hidden; }
body {
  font-family:var(--font); font-size:13px; line-height:1.5;
  background:var(--bg); color:var(--text);
  -webkit-font-smoothing:antialiased;
}
a { color:inherit; text-decoration:none; }
button { font-family:var(--font); cursor:pointer; border:none; background:none; color:inherit; }
input, select { font-family:var(--font); }

/* ── App Shell ──────────────────────────────────────────────── */
.app { display:grid; grid-template-columns:var(--sidebar-w) 1fr; grid-template-rows:var(--topbar-h) 1fr; height:100vh; }

/* ── Sidebar ────────────────────────────────────────────────── */
.sidebar {
  grid-row:1/-1; background:var(--bg2);
  border-right:1px solid var(--border);
  display:flex; flex-direction:column; overflow-y:auto;
}
.sidebar-logo {
  display:flex; align-items:center; gap:10px;
  padding:16px 20px; border-bottom:1px solid var(--border);
}
.sidebar-logo .mark { font-size:14px; font-weight:700; letter-spacing:-.02em; }
.sidebar-logo .mark .a { color:var(--text); }
.sidebar-logo .mark .b { color:#00e5ff; }
.sidebar-label {
  font-size:10px; font-weight:600; text-transform:uppercase;
  letter-spacing:.08em; color:var(--text3); padding:20px 20px 8px;
}
.sidebar-nav { display:flex; flex-direction:column; gap:2px; padding:0 8px; }
.nav-item {
  display:flex; align-items:center; gap:10px;
  padding:9px 12px; border-radius:var(--r);
  font-size:13px; font-weight:500; color:var(--text2);
  cursor:pointer; transition:all .15s; position:relative;
  text-decoration:none;
}
.nav-item:hover { background:var(--accent-glow); color:var(--text); }
.nav-item.active {
  background:var(--accent-dim); color:var(--accent); font-weight:600;
}
.nav-item.active::before {
  content:''; position:absolute; left:0; top:50%; transform:translateY(-50%);
  width:3px; height:20px; border-radius:0 3px 3px 0; background:var(--accent);
}
.nav-icon { width:18px; text-align:center; font-size:14px; flex-shrink:0; opacity:.7; }
.nav-item.active .nav-icon { opacity:1; }
.nav-badge {
  margin-left:auto; font-family:var(--mono); font-size:10px; font-weight:600;
  padding:2px 7px; border-radius:10px;
  background:var(--accent-dim); color:var(--accent);
}
.sidebar-bottom {
  margin-top:auto; padding:12px; border-top:1px solid var(--border);
}
.user-row {
  display:flex; align-items:center; gap:8px; padding:8px 8px; border-radius:var(--r);
}
.user-avatar {
  width:28px; height:28px; border-radius:50%;
  background:var(--accent-dim); border:1px solid var(--accent-border);
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:600; color:var(--accent); flex-shrink:0;
}
.user-email { font-size:11px; color:var(--text3); truncate; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.plan-chip {
  margin-left:auto; font-size:9px; font-weight:700; text-transform:uppercase;
  letter-spacing:.05em; padding:2px 6px; border-radius:4px;
  background:var(--accent-dim); color:var(--accent); flex-shrink:0;
}

/* ── Topbar ─────────────────────────────────────────────────── */
.topbar {
  background:var(--bg2); border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:12px; padding:0 20px;
  position:sticky; top:0; z-index:20;
}
.topbar-title { font-size:13px; font-weight:600; color:var(--text2); }
.topbar-title span { color:var(--accent); }
.topbar-spacer { flex:1; }
.topbar-stat {
  font-family:var(--mono); font-size:11px; color:var(--text3);
  padding:4px 10px; border-radius:5px; background:var(--bg3);
  border:1px solid var(--border);
}
.topbar-stat b { color:var(--text2); font-weight:600; }
.live-dot {
  width:8px; height:8px; border-radius:50%; background:var(--text3);
  flex-shrink:0; transition:background .3s;
}
.live-dot.active { background:var(--green); box-shadow:0 0 6px var(--green); animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }

/* ── Markets Layout ─────────────────────────────────────────── */
.markets-shell {
  display:flex; flex-direction:column; height:100%; overflow:hidden;
}

/* ── Filter Bar (top) ────────────────────────────────────────── */
.filter-bar {
  display:flex; align-items:center; gap:8px; padding:8px 12px;
  background:var(--bg2); border-bottom:1px solid var(--border);
  flex-shrink:0; flex-wrap:wrap;
}
.search-wrap {
  position:relative; display:flex; align-items:center;
}
.search-wrap svg { position:absolute; left:8px; color:var(--text3); pointer-events:none; }
.search-input {
  background:var(--bg3); border:1px solid var(--border); border-radius:6px;
  padding:5px 8px 5px 28px; font-size:12px; color:var(--text);
  width:200px; outline:none; transition:border .15s;
}
.search-input::placeholder { color:var(--text3); }
.search-input:focus { border-color:var(--accent); }
.filter-pill {
  padding:4px 10px; border-radius:5px; font-size:11px; font-weight:500;
  border:1px solid var(--border); background:var(--bg3); color:var(--text3);
  cursor:pointer; transition:all .15s; white-space:nowrap;
}
.filter-pill:hover { border-color:var(--border2); color:var(--text2); }
.filter-pill.active { border-color:currentColor; }
.filter-pill.online  { color:var(--green);  background:var(--green-dim); }
.filter-pill.post    { color:var(--amber);  background:var(--amber-dim); }
.filter-pill.limit   { color:var(--amber);  background:var(--amber-dim); }
.filter-pill.cancel  { color:var(--red);    background:var(--red-dim); }
.filter-pill.delisted{ color:var(--text3);  background:var(--bg3); }
.filter-sep { width:1px; height:20px; background:var(--border); flex-shrink:0; }
.filter-btn {
  display:flex; align-items:center; gap:5px; padding:4px 10px;
  border-radius:5px; font-size:11px; font-weight:500; color:var(--text3);
  border:1px solid var(--border); background:var(--bg3); cursor:pointer;
  transition:all .15s; white-space:nowrap;
}
.filter-btn:hover { border-color:var(--border2); color:var(--text2); }
.filter-btn.live-btn { color:var(--green); border-color:rgba(52,211,153,.3); background:var(--green-dim); }
.filter-spacer { flex:1; }
.count-label { font-family:var(--mono); font-size:10px; color:var(--text3); }

/* ── Body ────────────────────────────────────────────────────── */
.markets-body { display:flex; flex:1; min-height:0; }

/* ── Left Rail ───────────────────────────────────────────────── */
.left-rail {
  width:176px; flex-shrink:0; background:var(--bg2);
  border-right:1px solid var(--border);
  overflow-y:auto; display:flex; flex-direction:column;
  transition:width .2s;
}
.left-rail.closed { width:0; overflow:hidden; }
.rail-section { border-bottom:1px solid var(--border); }
.rail-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 12px; cursor:pointer;
  font-size:11px; font-weight:600; color:var(--text3);
  text-transform:uppercase; letter-spacing:.06em;
  user-select:none;
}
.rail-header:hover { color:var(--text2); }
.rail-body { padding:6px 8px 8px; }
.rail-ex-item {
  display:flex; align-items:center; gap:6px; padding:3px 4px;
  border-radius:4px; cursor:pointer; font-size:11px; color:var(--text3);
  transition:all .1s;
}
.rail-ex-item:hover { background:var(--bg3); color:var(--text2); }
.rail-ex-item input[type=checkbox] { accent-color:var(--accent); width:12px; height:12px; flex-shrink:0; }
.rail-ex-item.checked { color:var(--text2); }
.tier-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
.tier-1 { background:var(--blue); }
.tier-2 { background:var(--text3); }
.tier-3 { background:var(--border2); }
.rail-quick { display:flex; gap:4px; margin-bottom:6px; }
.rail-quick-btn {
  padding:2px 7px; border-radius:4px; font-size:10px; font-weight:500;
  border:1px solid var(--border); background:var(--bg3); color:var(--text3);
  cursor:pointer; transition:all .1s;
}
.rail-quick-btn:hover { color:var(--text2); border-color:var(--border2); }
.asset-pills { display:flex; flex-wrap:wrap; gap:3px; }
.asset-pill {
  padding:2px 7px; border-radius:4px; font-size:10px; font-weight:500;
  border:1px solid var(--border); background:var(--bg3); color:var(--text3);
  cursor:pointer; transition:all .1s;
}
.asset-pill:hover { color:var(--text2); }
.asset-pill.active { border-color:var(--accent); color:var(--accent); background:var(--accent-dim); }
.toggle-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:4px 4px; font-size:11px; color:var(--text3);
}
.toggle {
  width:30px; height:16px; border-radius:8px; background:var(--border2);
  position:relative; cursor:pointer; transition:background .2s; flex-shrink:0;
}
.toggle.on { background:var(--accent); }
.toggle::after {
  content:''; position:absolute; top:2px; left:2px;
  width:12px; height:12px; border-radius:50%; background:#fff;
  transition:transform .2s;
}
.toggle.on::after { transform:translateX(14px); }
.rail-input {
  width:100%; background:var(--bg3); border:1px solid var(--border);
  border-radius:4px; padding:4px 7px; font-size:11px; color:var(--text);
  outline:none; font-family:var(--mono); margin-top:3px;
}
.rail-input:focus { border-color:var(--accent); }
.rail-input::placeholder { color:var(--text3); }
.rail-label { font-size:10px; color:var(--text3); margin-top:6px; display:block; }

/* ── Main Grid Area ──────────────────────────────────────────── */
.grid-area { flex:1; display:flex; flex-direction:column; min-width:0; overflow:hidden; }

/* ── Subbar ──────────────────────────────────────────────────── */
.subbar {
  display:flex; align-items:center; gap:8px; padding:4px 12px;
  background:var(--bg); border-bottom:1px solid var(--border);
  font-size:10px; color:var(--text3); flex-shrink:0;
}
.subbar kbd {
  border:1px solid var(--border2); border-radius:3px;
  padding:1px 4px; font-family:var(--mono); font-size:9px;
}

/* ── Grid ────────────────────────────────────────────────────── */
.grid-wrap { flex:1; overflow:auto; position:relative; }
.grid-table { width:100%; border-collapse:collapse; table-layout:fixed; }
.grid-table thead { position:sticky; top:0; z-index:10; }
.grid-table thead th {
  background:var(--bg2); border-bottom:2px solid var(--border);
  padding:6px 10px; text-align:left; font-size:10px; font-weight:600;
  text-transform:uppercase; letter-spacing:.06em; color:var(--text3);
  white-space:nowrap; user-select:none;
}
.grid-table thead th.sortable { cursor:pointer; transition:color .1s; }
.grid-table thead th.sortable:hover { color:var(--text2); }
.grid-table thead th.sort-asc::after  { content:' ↑'; color:var(--accent); }
.grid-table thead th.sort-desc::after { content:' ↓'; color:var(--accent); }
.grid-table thead th.r { text-align:right; }
.grid-table thead th.c { text-align:center; }
.grid-row {
  border-bottom:1px solid rgba(26,34,54,.7);
  cursor:pointer; transition:background .1s;
}
.grid-row:hover { background:var(--card-hover); }
.grid-row.selected { background:rgba(167,139,250,.08); border-left:2px solid var(--accent); }
.grid-row td {
  padding:5px 10px; font-size:12px; color:var(--text2);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.grid-row td.r { text-align:right; }
.grid-row td.c { text-align:center; }
.cell-mono { font-family:var(--mono); }
.ex-chip { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:500; }
.ex-chip-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
.symbol-cell { font-weight:600; color:var(--text); font-size:12px; letter-spacing:.01em; }
.status-badge {
  display:inline-flex; align-items:center; gap:4px;
  padding:2px 6px; border-radius:4px; font-size:10px; font-weight:600;
  white-space:nowrap;
}
.status-dot { width:4px; height:4px; border-radius:50%; }
.s-online  { color:var(--green); background:var(--green-dim); }
.s-post    { color:var(--amber); background:var(--amber-dim); }
.s-limit   { color:var(--amber); background:var(--amber-dim); }
.s-cancel  { color:var(--red);   background:var(--red-dim); }
.s-delist  { color:var(--text3); background:var(--bg3); }
.s-unknown { color:var(--text3); background:var(--bg3); }
.score-wrap { display:inline-flex; align-items:center; gap:5px; justify-content:flex-end; }
.score-bar-bg { width:36px; height:4px; background:var(--border2); border-radius:2px; overflow:hidden; }
.score-bar-fill { height:100%; border-radius:2px; transition:width .3s; }
.price-up   { color:var(--green) !important; }
.price-down { color:var(--red) !important; }
.null-cell  { color:var(--border2); font-family:var(--mono); }
.margin-chip {
  font-size:9px; font-weight:700; text-transform:uppercase;
  padding:1px 5px; border-radius:3px;
  color:var(--blue); background:var(--blue-dim);
}

/* ── Inspector ───────────────────────────────────────────────── */
.inspector {
  background:var(--bg2); border-top:2px solid var(--border);
  flex-shrink:0; display:flex; flex-direction:column;
  overflow:hidden; position:relative;
}
.inspector-resize {
  height:4px; background:transparent; cursor:ns-resize;
  position:absolute; top:0; left:0; right:0;
  transition:background .15s;
}
.inspector-resize:hover { background:var(--accent-border); }
.inspector-tabs {
  display:flex; align-items:center; border-bottom:1px solid var(--border);
  padding:0 12px; flex-shrink:0; margin-top:4px;
}
.insp-tab {
  padding:8px 14px; font-size:12px; font-weight:500; color:var(--text3);
  cursor:pointer; border-bottom:2px solid transparent; transition:all .15s;
  white-space:nowrap;
}
.insp-tab:hover { color:var(--text2); }
.insp-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.insp-identity {
  margin-left:auto; display:flex; align-items:center; gap:8px;
  font-size:11px; color:var(--text3); padding-right:4px;
}
.insp-identity strong { color:var(--text); font-size:13px; }
.insp-close {
  padding:4px 8px; border-radius:4px; font-size:14px;
  color:var(--text3); cursor:pointer; transition:all .1s;
}
.insp-close:hover { background:var(--bg3); color:var(--text2); }
.insp-body { flex:1; overflow:auto; }
.insp-pane { display:none; padding:12px; height:100%; }
.insp-pane.active { display:flex; gap:12px; }
.insp-pane.active.block { display:block; }

/* Overview tab */
.overview-left { width:220px; flex-shrink:0; }
.overview-right { flex:1; }
.spec-table { width:100%; }
.spec-table tr td { padding:3px 0; font-size:11px; }
.spec-table tr td:first-child { color:var(--text3); width:100px; }
.spec-table tr td:last-child { color:var(--text2); font-family:var(--mono); text-align:right; }
.stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
.stat-card {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:var(--r); padding:10px 12px;
}
.stat-card-label { font-size:10px; color:var(--text3); margin-bottom:4px; }
.stat-card-val { font-family:var(--mono); font-size:14px; font-weight:600; color:var(--text); }
.copy-btns { margin-top:12px; display:flex; flex-direction:column; gap:4px; }
.copy-btn {
  display:flex; align-items:center; justify-content:space-between;
  padding:6px 10px; border-radius:5px; font-size:11px;
  border:1px solid var(--border); background:var(--bg3); color:var(--text3);
  cursor:pointer; transition:all .1s;
}
.copy-btn:hover { border-color:var(--border2); color:var(--text2); }
.copy-btn.copied { border-color:var(--green); color:var(--green); }

/* Compare tab */
.compare-table { width:100%; border-collapse:collapse; font-size:12px; }
.compare-table th {
  padding:6px 10px; text-align:left; font-size:10px; font-weight:600;
  text-transform:uppercase; letter-spacing:.05em; color:var(--text3);
  border-bottom:1px solid var(--border);
}
.compare-table th.r { text-align:right; }
.compare-table td { padding:5px 10px; border-bottom:1px solid rgba(26,34,54,.5); }
.compare-table td.r { text-align:right; font-family:var(--mono); }
.compare-table tr:hover td { background:var(--card-hover); }
.compare-table tr.current td { background:rgba(167,139,250,.05); }
.best-tag {
  font-size:9px; font-weight:700; text-transform:uppercase;
  padding:1px 5px; border-radius:3px; margin-left:4px;
}
.best-spread { color:var(--green); background:var(--green-dim); }
.best-vol    { color:var(--blue);  background:var(--blue-dim); }
.best-liq    { color:var(--amber); background:var(--amber-dim); }

/* Changelog / sync tabs */
.changelog-table { width:100%; border-collapse:collapse; font-size:11px; }
.changelog-table th {
  padding:5px 10px; text-align:left; font-size:10px; font-weight:600;
  text-transform:uppercase; letter-spacing:.05em; color:var(--text3);
  border-bottom:1px solid var(--border);
}
.changelog-table td { padding:4px 10px; border-bottom:1px solid rgba(26,34,54,.4); font-family:var(--mono); }
.changelog-table tr:hover td { background:var(--card-hover); }
.empty-state { color:var(--text3); font-size:12px; padding:24px; text-align:center; }

/* ── Modals ───────────────────────────────────────────────────── */
.modal-overlay {
  position:fixed; inset:0; background:rgba(0,0,0,.7); z-index:100;
  display:flex; align-items:center; justify-content:center;
  backdrop-filter:blur(4px);
}
.modal-overlay.hidden { display:none; }
.modal {
  background:var(--card); border:1px solid var(--border2);
  border-radius:var(--r); box-shadow:0 20px 60px rgba(0,0,0,.5);
  width:320px; max-height:80vh; display:flex; flex-direction:column;
}
.modal-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:14px 16px; border-bottom:1px solid var(--border);
}
.modal-title { font-size:13px; font-weight:600; }
.modal-close { cursor:pointer; color:var(--text3); font-size:18px; line-height:1; }
.modal-close:hover { color:var(--text); }
.modal-body { padding:12px; overflow-y:auto; flex:1; }
.modal-footer {
  padding:10px 14px; border-top:1px solid var(--border);
  display:flex; justify-content:flex-end; gap:8px;
}
.btn { padding:6px 14px; border-radius:6px; font-size:12px; font-weight:500; cursor:pointer; border:none; }
.btn-primary { background:var(--accent); color:#fff; transition:opacity .15s; }
.btn-primary:hover { opacity:.85; }
.btn-ghost { background:var(--bg3); border:1px solid var(--border); color:var(--text2); transition:all .1s; }
.btn-ghost:hover { border-color:var(--border2); }
.modal-ex-item {
  display:flex; align-items:center; gap:8px; padding:6px 8px;
  border-radius:5px; cursor:pointer; font-size:12px; color:var(--text3);
}
.modal-ex-item:hover { background:var(--bg3); color:var(--text2); }
.modal-ex-item input { accent-color:var(--accent); width:13px; height:13px; }
.modal-tier-label {
  font-size:9px; font-weight:600; text-transform:uppercase; letter-spacing:.07em;
  color:var(--text3); padding:6px 8px 2px; margin-top:4px;
}
.modal-ex-pairs { margin-left:auto; font-family:var(--mono); font-size:10px; color:var(--text3); }

/* ── Loading ─────────────────────────────────────────────────── */
.loading-row td { color:var(--text3); text-align:center; padding:40px; font-size:12px; }
</style>
</head>
<body>
<div class="app">

  <!-- ── Sidebar ─────────────────────────────────────────────── -->
  <nav class="sidebar">
    <a class="sidebar-logo" href="/dashboard">
      <svg width="24" height="24" viewBox="0 0 40 40" fill="none"><defs><linearGradient id="hg" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse"><stop stop-color="#00e5ff"/><stop offset="1" stop-color="#0066ff"/></linearGradient></defs><polygon points="20,2 38,11 38,29 20,38 2,29 2,11" fill="url(#hg)"/></svg>
      <div class="mark"><span class="a">Agora</span><span class="b">IQ</span></div>
