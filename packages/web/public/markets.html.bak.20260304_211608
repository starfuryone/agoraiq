</div>

<!-- ── Exchange Modal ─────────────────────────────────────────── -->
<div class="modal-overlay hidden" id="ex-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Select Exchanges</div>
      <span class="modal-close" onclick="closeExchangeModal()">✕</span>
    </div>
    <div class="modal-body">
      <div style="display:flex;gap:6px;margin-bottom:8px;">
        <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px;" onclick="clearExchanges()">All exchanges</button>
        <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px;" onclick="selectTier1()">Tier 1 only</button>
      </div>
      <div id="modal-ex-list"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="clearExchanges()">Clear</button>
      <button class="btn btn-primary" onclick="closeExchangeModal()">Apply</button>
    </div>
  </div>
</div>

<!-- ── Columns Modal ──────────────────────────────────────────── -->
<div class="modal-overlay hidden" id="col-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Columns</div>
      <span class="modal-close" onclick="closeColumnsModal()">✕</span>
    </div>
    <div class="modal-body" id="col-modal-body"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="resetColumns()">Reset</button>
      <button class="btn btn-primary" onclick="closeColumnsModal()">Done</button>
    </div>
  </div>
