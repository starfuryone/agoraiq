        <!-- Quote -->
        <div class="rail-section">
          <div class="rail-header" onclick="toggleSection('quote')">
            Quote <span id="quote-sec-arrow">▶</span>
          </div>
          <div class="rail-body" id="quote-sec-body" style="display:none">
            <div class="asset-pills" id="quote-pills"></div>
          </div>
        </div>

        <!-- Advanced -->
        <div class="rail-section">
          <div class="rail-header" onclick="toggleSection('adv')">
            Advanced <span id="adv-sec-arrow">▶</span>
          </div>
          <div class="rail-body" id="adv-sec-body" style="display:none">
            <div class="toggle-row">
              <span>Margin only</span>
              <div class="toggle" id="margin-toggle" onclick="toggleMargin()"></div>
            </div>
            <span class="rail-label">Min Vol 24h</span>
            <input class="rail-input" id="min-vol-input" type="number" placeholder="e.g. 100000" oninput="applyFilters()"/>
            <span class="rail-label">Max Spread (bps)</span>
            <input class="rail-input" id="max-spread-input" type="number" placeholder="e.g. 50" oninput="applyFilters()"/>
          </div>
        </div>

      </aside>

      <!-- Grid + Inspector -->
      <div class="grid-area">
        <div class="grid-wrap" id="grid-wrap">
          <table class="grid-table">
            <thead id="grid-head"></thead>
            <tbody id="grid-body">
              <tr class="loading-row"><td colspan="20">Loading markets…</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Inspector -->
        <div class="inspector" id="inspector" style="display:none; height:260px;">
          <div class="inspector-resize" id="insp-resize"></div>
          <div class="inspector-tabs">
            <div class="insp-tab active" data-tab="overview"   onclick="switchTab('overview')">Overview</div>
            <div class="insp-tab"        data-tab="compare"    onclick="switchTab('compare')">Cross-Exchange</div>
            <div class="insp-tab"        data-tab="changelog"  onclick="switchTab('changelog')">Changelog</div>
            <div class="insp-tab"        data-tab="sync"       onclick="switchTab('sync')">Sync History</div>
            <div class="insp-tab"        data-tab="raw"        onclick="switchTab('raw')">Raw</div>
            <div class="insp-identity">
              <span id="insp-ex-label"></span>
              <strong id="insp-sym-label"></strong>
            </div>
            <button class="insp-close" onclick="closeInspector()">✕</button>
          </div>
          <div class="insp-body">
            <div class="insp-pane active" id="pane-overview"></div>
            <div class="insp-pane block"  id="pane-compare"></div>
            <div class="insp-pane block"  id="pane-changelog"></div>
            <div class="insp-pane block"  id="pane-sync"></div>
            <div class="insp-pane block"  id="pane-raw"></div>
          </div>
        </div>
