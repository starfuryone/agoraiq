  </header>

  <!-- ── Markets Shell ────────────────────────────────────────── -->
  <main class="markets-shell">

    <!-- Filter Bar -->
    <div class="filter-bar" id="filter-bar">
      <!-- Search -->
      <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input class="search-input" id="search-input" type="text" placeholder="Search pairs… (/)" autocomplete="off"/>
      </div>

      <!-- Exchange select -->
      <button class="filter-btn" id="btn-exchanges" onclick="openExchangeModal()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Exchanges <span id="ex-badge" style="color:var(--accent)"></span>
        <kbd>E</kbd>
      </button>

      <div class="filter-sep"></div>

      <!-- Status pills -->
      <button class="filter-pill online active"  data-status="ONLINE"      onclick="toggleStatus(this)">ONLINE</button>
      <button class="filter-pill post   active"  data-status="POST_ONLY"   onclick="toggleStatus(this)">POST</button>
      <button class="filter-pill limit  active"  data-status="LIMIT_ONLY"  onclick="toggleStatus(this)">LIMIT</button>
      <button class="filter-pill cancel"         data-status="CANCEL_ONLY" onclick="toggleStatus(this)">CANCEL</button>
      <button class="filter-pill delisted"       data-status="DELISTED"    onclick="toggleStatus(this)">DELISTED</button>

      <div class="filter-sep"></div>

      <!-- Rail toggle -->
      <button class="filter-btn" onclick="toggleRail()" id="rail-toggle-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        Filters <kbd>F</kbd>
      </button>

      <div class="filter-spacer"></div>

      <!-- Count -->
      <span class="count-label" id="row-count">— / — pairs</span>

      <!-- Columns btn -->
      <button class="filter-btn" onclick="openColumnsModal()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="18"/><rect x="14" y="3" width="7" height="18"/></svg>
        Columns <kbd>C</kbd>
      </button>

      <!-- CSV -->
      <button class="filter-btn" onclick="exportCSV()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        CSV
      </button>

      <!-- Live toggle -->
      <button class="filter-btn" id="live-btn" onclick="toggleLive()">
        <span class="live-dot" id="live-btn-dot"></span>
        <span id="live-btn-label">PAUSED</span>
      </button>
    </div>

    <!-- Subbar hints -->
    <div class="subbar">
      ↑↓ navigate &nbsp;·&nbsp; Enter inspect &nbsp;·&nbsp; Esc close &nbsp;·&nbsp;
      <kbd>/</kbd> search &nbsp;·&nbsp;
      <kbd>E</kbd> exchanges &nbsp;·&nbsp;
      <kbd>F</kbd> filters &nbsp;·&nbsp;
      <kbd>C</kbd> columns
      <div style="flex:1"></div>
      <span id="sort-hint" style="color:var(--text3)"></span>
    </div>

    <!-- Body -->
    <div class="markets-body">

      <!-- Left Rail -->
      <aside class="left-rail" id="left-rail">

        <!-- Exchanges -->
        <div class="rail-section">
          <div class="rail-header" onclick="toggleSection('ex')">
            Exchanges <span id="ex-sec-arrow">▾</span>
          </div>
          <div class="rail-body" id="ex-sec-body">
            <div class="rail-quick">
              <button class="rail-quick-btn" onclick="clearExchanges()">All</button>
              <button class="rail-quick-btn" onclick="selectTier1()">Tier 1</button>
