}

// ── Row selection ─────────────────────────────────────────────────────────────
function selectRow(idx) {
  if (selectedIdx===idx && selectedRow) { closeInspector(); return; }
  selectedIdx = idx;
  selectedRow = filteredRows[idx];
  renderBody();
  openInspector(selectedRow);
}

// ── Status filter ─────────────────────────────────────────────────────────────
function toggleStatus(btn) {
  const s = btn.dataset.status;
  const idx = selStatuses.indexOf(s);
  if (idx>=0) { selStatuses.splice(idx,1); btn.classList.remove('active'); }
  else { selStatuses.push(s); btn.classList.add('active'); }
  loadMarkets();
}

// ── Exchange filter ───────────────────────────────────────────────────────────
function clearExchanges() {
  selExchanges = [];
  document.querySelectorAll('.modal-ex-cb,.rail-ex-cb').forEach(cb => cb.checked=true);
  document.getElementById('ex-badge').textContent = '';
  loadMarkets();
}
function selectTier1() {
  selExchanges = exchanges.filter(e=>e.tier===1).map(e=>e.exchange);
  syncExCbAll();
  document.getElementById('ex-badge').textContent = selExchanges.length;
  loadMarkets();
}
function syncExCbAll() {
  document.querySelectorAll('.modal-ex-cb,.rail-ex-cb').forEach(cb => {
    cb.checked = selExchanges.length===0 || selExchanges.includes(cb.dataset.ex);
  });
}
function toggleEx(exName, cb) {
  if (selExchanges.length===0) {
    // Was "all selected", now deselect others
    selExchanges = exchanges.map(e=>e.exchange).filter(e=>e!==exName);
  } else if (cb.checked) {
    if (!selExchanges.includes(exName)) selExchanges.push(exName);
  } else {
    selExchanges = selExchanges.filter(e=>e!==exName);
    if (!selExchanges.length) selExchanges = [];
  }
  syncExCbAll();
  document.getElementById('ex-badge').textContent = selExchanges.length||'';
  loadMarkets();
}

// ── Base/Quote filters ────────────────────────────────────────────────────────
function toggleBase(b, el) {
  const idx = selBases.indexOf(b);
  if (idx>=0) { selBases.splice(idx,1); el.classList.remove('active'); }
  else { selBases.push(b); el.classList.add('active'); }
  loadMarkets();
}
function toggleQuote(q, el) {
  const idx = selQuotes.indexOf(q);
  if (idx>=0) { selQuotes.splice(idx,1); el.classList.remove('active'); }
  else { selQuotes.push(q); el.classList.add('active'); }
  loadMarkets();
}

