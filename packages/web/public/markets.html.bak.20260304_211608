<script>
// ── Auth ──────────────────────────────────────────────────────────────────────
const TOKEN = localStorage.getItem('agoraiq_token');
if (!TOKEN) window.location.href = '/login';
const AUTH = () => ({ 'Authorization': `Bearer ${TOKEN}`, 'Content-Type': 'application/json' });
const MI_API = '/api/v1/markets';

// ── Column Definitions ────────────────────────────────────────────────────────
const COL_DEFS = [
  { key:'exchange',        label:'Exchange',    w:110, align:'l', sort:true,  group:'identity', vis:true  },
  { key:'symbol',          label:'Pair',        w:110, align:'l', sort:true,  group:'identity', vis:true  },
  { key:'status',          label:'Status',      w:95,  align:'c', sort:true,  group:'identity', vis:true  },
  { key:'last',            label:'Price',       w:120, align:'r', sort:true,  group:'live',     vis:true,  mono:true },
  { key:'spreadBps',       label:'Sprd bps',    w:90,  align:'r', sort:true,  group:'live',     vis:true,  mono:true },
  { key:'volume24h',       label:'Vol 24h',     w:110, align:'r', sort:true,  group:'live',     vis:true,  mono:true },
  { key:'liquidityScore',  label:'Liquidity',   w:110, align:'r', sort:true,  group:'live',     vis:true  },
  { key:'volatilityScore', label:'Volatility',  w:110, align:'r', sort:true,  group:'live',     vis:true  },
  { key:'fundingRate',     label:'Funding',     w:95,  align:'r', sort:true,  group:'live',     vis:false, mono:true },
  { key:'spreadAbs',       label:'Spread',      w:100, align:'r', sort:true,  group:'live',     vis:false, mono:true },
  { key:'volume24hUsd',    label:'Vol USD',     w:110, align:'r', sort:true,  group:'live',     vis:false, mono:true },
  { key:'tickSize',        label:'Tick',        w:100, align:'r', sort:false, group:'specs',    vis:false, mono:true },
  { key:'orderMin',        label:'Min Qty',     w:90,  align:'r', sort:false, group:'specs',    vis:false, mono:true },
  { key:'marginAvailable', label:'Margin',      w:75,  align:'c', sort:true,  group:'specs',    vis:true  },
  { key:'lastSyncedAt',    label:'Synced',      w:80,  align:'r', sort:true,  group:'ops',      vis:false },
];

let columns = COL_DEFS.map(c => ({ ...c }));

// ── State ─────────────────────────────────────────────────────────────────────
let allRows     = [];
let filteredRows= [];
let exchanges   = [];
let selExchanges= [];
let selBases    = [];
let selQuotes   = [];
let selStatuses = ['ONLINE','POST_ONLY','LIMIT_ONLY'];
let marginOnly  = false;
let minVol      = null;
let maxSpread   = null;
let searchVal   = '';
let sortCol     = 'liquidityScore';
let sortDir     = 'desc';
let selectedIdx = null;
let selectedRow = null;
let liveOn      = false;
let wsConn      = null;
let railOpen    = true;
let currentTab  = 'overview';

const TOP_BASES  = ['BTC','ETH','SOL','BNB','XRP','ADA','AVAX','DOGE','DOT','MATIC','LINK','UNI'];
const TOP_QUOTES = ['USDT','USDC','USD','EUR','BTC','ETH'];

// ── Format helpers ────────────────────────────────────────────────────────────
function fPrice(v, dec=6) {
  if (v==null) return null;
  const n = parseFloat(v);
  if (isNaN(n)) return null;
  if (n>=1000) return n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  if (n>=1)    return n.toFixed(4);
  return n.toFixed(Math.min(dec,8));
}
function fVol(v) {
  if (v==null) return null;
  const n=parseFloat(v);
  if (isNaN(n)) return null;
  if(n>=1e9) return (n/1e9).toFixed(2)+'B';
  if(n>=1e6) return (n/1e6).toFixed(2)+'M';
  if(n>=1e3) return (n/1e3).toFixed(2)+'K';
  return n.toFixed(2);
}
function fBps(v)  { if(v==null) return null; return parseFloat(v).toFixed(2); }
function fFund(v) {
  if(v==null) return null;
  const n=parseFloat(v);
  return (n>=0?'+':'')+( n*100).toFixed(4)+'%';
}
function fRel(iso) {
  if(!iso) return null;
  const ms=Date.now()-new Date(iso).getTime();
  if(ms<60000)   return Math.floor(ms/1000)+'s';
  if(ms<3600000) return Math.floor(ms/60000)+'m';
  if(ms<86400000)return Math.floor(ms/3600000)+'h';
  return Math.floor(ms/86400000)+'d';
}
function scoreColor(s) {
  if(s==null) return 'var(--border2)';
  if(s>=80) return 'var(--green)';
  if(s>=60) return 'var(--amber)';
  if(s>=40) return 'var(--accent)';
  return 'var(--red)';
}
function scoreFill(s) {
  if(s==null) return 'var(--border2)';
  if(s>=80) return 'var(--green)';
  if(s>=60) return 'var(--amber)';
  if(s>=40) return 'var(--accent)';
  return 'var(--red)';
}
function statusCls(s) {
  return {ONLINE:'s-online',POST_ONLY:'s-post',LIMIT_ONLY:'s-limit',
    CANCEL_ONLY:'s-cancel',DELISTED:'s-delist',REDUCE_ONLY:'s-cancel'}[s]||'s-unknown';
}
function statusLabel(s) {
  return {ONLINE:'ONLINE',POST_ONLY:'POST',LIMIT_ONLY:'LIMIT',
    CANCEL_ONLY:'CANCEL',DELISTED:'DELIST',REDUCE_ONLY:'REDUCE'}[s]||s;
}
function tierDot(tier) {
  return `<span class="tier-dot tier-${tier}"></span>`;
}
function exDot(tier) {
  const c = tier===1?'var(--blue)':tier===2?'var(--text3)':'var(--border2)';
  return `<span style="width:5px;height:5px;border-radius:50%;background:${c};display:inline-block;flex-shrink:0"></span>`;
}

// ── Init ──────────────────────────────────────────────────────────────────────
async function init() {
  try {
    const r = await fetch('/api/v1/auth/me', { headers: AUTH() });
    const d = await r.json();
    if (d.error) { window.location.href='/login'; return; }
    const email = d.user?.email || '';
    document.getElementById('user-email').textContent = email;
    document.getElementById('user-avatar').textContent = email[0]?.toUpperCase()||'?';
    const plan = d.subscription?.planTier || d.subscription?.tier?.toUpperCase() || 'FREE';
    document.getElementById('plan-chip').textContent = plan;
  } catch(e) { window.location.href='/login'; return; }

  await loadMeta();
  await loadMarkets();
  buildRail();
  renderHead();
  setupKeyboard();
  setupResize();
}

// ── Load metadata ─────────────────────────────────────────────────────────────
async function loadMeta() {
  try {
    const r = await fetch(`${MI_API}/meta/exchanges`, { headers: AUTH() });
    const d = await r.json();
    exchanges = d.data || [];

    // Update topbar stats
    const totalOnline = exchanges.reduce((s,e)=>s+(e.onlinePairs||0),0);
    document.getElementById('tb-online').textContent    = totalOnline.toLocaleString();
    document.getElementById('tb-exchanges').textContent = exchanges.length;
    document.getElementById('pair-count-badge').textContent =
      exchanges.reduce((s,e)=>s+(e.totalPairs||0),0).toLocaleString();

    buildRailExchanges();
    buildModalExchanges();
  } catch(e) { console.warn('Meta load failed', e); }
}

// ── Load markets ──────────────────────────────────────────────────────────────
async function loadMarkets() {
  document.getElementById('grid-body').innerHTML =
    '<tr class="loading-row"><td colspan="20">Loading markets…</td></tr>';

  const params = new URLSearchParams();
  if (selExchanges.length)  params.set('exchanges', selExchanges.join(','));
  if (searchVal)            params.set('search', searchVal);
  if (selBases.length===1)  params.set('base', selBases[0]);
  if (selQuotes.length===1) params.set('quote', selQuotes[0]);
  if (selStatuses.length)   params.set('status', selStatuses.join(','));
  if (marginOnly)           params.set('marginAvailable','true');
  if (minVol)               params.set('minVolume', minVol);
  if (maxSpread)            params.set('maxSpreadBps', maxSpread);
  params.set('sort', `${sortCol}:${sortDir}`);
  params.set('pageSize', '3000');

  try {
    const r = await fetch(`${MI_API}?${params}`, { headers: AUTH() });
    const d = await r.json();
    allRows = d.data || [];
    applyClientFilters();
  } catch(e) {
    document.getElementById('grid-body').innerHTML =
      '<tr class="loading-row"><td colspan="20">Failed to load — check API connection</td></tr>';
  }
}

// ── Client-side filter + sort ─────────────────────────────────────────────────
function applyFilters() {
  minVol    = parseFloat(document.getElementById('min-vol-input').value)   || null;
  maxSpread = parseFloat(document.getElementById('max-spread-input').value)|| null;
  applyClientFilters();
}

function applyClientFilters() {
  let rows = allRows;

  if (searchVal) {
    const q = searchVal.toUpperCase();
    rows = rows.filter(r =>
      r.symbol?.toUpperCase().includes(q) ||
      r.baseCanonical?.includes(q) ||
      r.quoteCanonical?.includes(q) ||
      r.pairId?.toUpperCase().includes(q) ||
      (r.tvSymbol||'').toUpperCase().includes(q)
    );
  }
  if (selExchanges.length) {
    const s = new Set(selExchanges);
    rows = rows.filter(r => s.has(r.exchange));
  }
  if (selStatuses.length < 6) {
    const s = new Set(selStatuses);
    rows = rows.filter(r => s.has(r.status));
  }
  if (selBases.length) {
    const s = new Set(selBases);
    rows = rows.filter(r => s.has(r.baseCanonical));
  }
  if (selQuotes.length) {
    const s = new Set(selQuotes);
    rows = rows.filter(r => s.has(r.quoteCanonical));
  }
  if (marginOnly) rows = rows.filter(r => r.marginAvailable);
  if (minVol)     rows = rows.filter(r => r.volume24h!=null && parseFloat(r.volume24h)>=minVol);
  if (maxSpread)  rows = rows.filter(r => r.spreadBps!=null && parseFloat(r.spreadBps)<=maxSpread);

  // Sort
  rows = [...rows].sort((a,b) => {
    const av = a[sortCol]; const bv = b[sortCol];
    if(av==null) return 1;
    if(bv==null) return -1;
    const n = parseFloat(av), m = parseFloat(bv);
    const cmp = (!isNaN(n)&&!isNaN(m)) ? n-m : String(av).localeCompare(String(bv));
    return sortDir==='desc' ? -cmp : cmp;
  });

  filteredRows = rows;
  document.getElementById('row-count').textContent =
    `${rows.length.toLocaleString()} / ${allRows.length.toLocaleString()} pairs`;

  renderBody();
  updateSortHint();
}

// ── Render header ─────────────────────────────────────────────────────────────
function renderHead() {
  const visCols = columns.filter(c=>c.vis);
  const ths = visCols.map(c => {
    const align = c.align==='r'?'r':c.align==='c'?'c':'';
    const sortCls = c.sort ? 'sortable' + (c.key===sortCol ? ` sort-${sortDir}` : '') : '';
    const onclick = c.sort ? `onclick="doSort('${c.key}')"` : '';
    return `<th style="width:${c.w}px" class="${align} ${sortCls}" ${onclick}>${c.label}</th>`;
  }).join('');
  document.getElementById('grid-head').innerHTML = `<tr>${ths}</tr>`;
}

// ── Render body ───────────────────────────────────────────────────────────────
function renderBody() {
  const visCols = columns.filter(c=>c.vis);
  if (!filteredRows.length) {
    document.getElementById('grid-body').innerHTML =
      '<tr class="loading-row"><td colspan="20">No pairs match the current filters</td></tr>';
    return;
  }

  const html = filteredRows.map((row, idx) => {
    const selCls = (selectedRow && row.id===selectedRow.id) ? 'selected' : '';
    const tds = visCols.map(c => renderCell(c, row)).join('');
    return `<tr class="grid-row ${selCls}" data-idx="${idx}" onclick="selectRow(${idx})">${tds}</tr>`;
  }).join('');

  document.getElementById('grid-body').innerHTML = html;
}

function renderCell(c, row) {
  const align = c.align==='r'?'r':c.align==='c'?'c':'';
  const cls = align ? ` class="${align}"` : '';
  const val = row[c.key];

  switch(c.key) {
    case 'exchange': {
      const ex = exchanges.find(e=>e.exchange===row.exchange);
      const tier = ex?.tier || row.exchangeTier || 2;
      const dot = exDot(tier);
      const name = row.exchangeDisplayName || row.exchange;
      const color = tier===1?'var(--blue)':tier===2?'var(--text2)':'var(--text3)';
      return `<td><span class="ex-chip" style="color:${color}">${dot}${name}</span></td>`;
    }
    case 'symbol':
      return `<td><span class="symbol-cell">${row.symbol}</span></td>`;
    case 'status': {
      const sc = statusCls(row.status);
      const sl = statusLabel(row.status);
      return `<td class="c"><span class="status-badge ${sc}"><span class="status-dot" style="background:currentColor"></span>${sl}</span></td>`;
    }
    case 'last': {
      const v = fPrice(val);
      if (!v) return `<td class="r null-cell">—</td>`;
      return `<td class="r cell-mono" style="color:var(--text)">${v}</td>`;
    }
    case 'spreadBps': {
      const v = fBps(val);
      if (!v) return `<td class="r null-cell">—</td>`;
      const color = parseFloat(val)<5?'var(--green)':parseFloat(val)<20?'var(--amber)':'var(--text2)';
      return `<td class="r cell-mono" style="color:${color}">${v}</td>`;
    }
    case 'spreadAbs': {
      const v = fPrice(val);
      return v ? `<td class="r cell-mono">${v}</td>` : `<td class="r null-cell">—</td>`;
    }
    case 'volume24h': {
      const v = fVol(val);
      return v ? `<td class="r cell-mono">${v}</td>` : `<td class="r null-cell">—</td>`;
    }
    case 'volume24hUsd': {
      const v = fVol(val);
      return v ? `<td class="r cell-mono">$${v}</td>` : `<td class="r null-cell">—</td>`;
    }
    case 'liquidityScore':
    case 'volatilityScore': {
      if (val==null) return `<td class="r null-cell">—</td>`;
      const s = parseInt(val);
      const color = scoreColor(s);
      const fill  = scoreFill(s);
      return `<td class="r">
        <span class="score-wrap">
          <span style="color:${color};font-family:var(--mono);font-size:11px;">${s}</span>
          <span class="score-bar-bg"><span class="score-bar-fill" style="width:${s}%;background:${fill}"></span></span>
        </span>
      </td>`;
    }
    case 'fundingRate': {
      const v = fFund(val);
      if (!v) return `<td class="r null-cell">—</td>`;
      const color = parseFloat(val)>=0?'var(--green)':'var(--red)';
      return `<td class="r cell-mono" style="color:${color}">${v}</td>`;
    }
    case 'marginAvailable':
      return val
        ? `<td class="c"><span class="margin-chip">MARGIN</span></td>`
        : `<td class="c null-cell">—</td>`;
    case 'tickSize':
    case 'orderMin':
      return val ? `<td class="r cell-mono" style="font-size:11px">${val}</td>` : `<td class="r null-cell">—</td>`;
    case 'lastSyncedAt': {
      const v = fRel(val);
      return v ? `<td class="r" style="color:var(--text3);font-size:11px">${v}</td>` : `<td class="r null-cell">—</td>`;
    }
    default:
      return `<td${cls}>${val!=null?val:'—'}</td>`;
  }
}

// ── Sort ──────────────────────────────────────────────────────────────────────
function doSort(col) {
  if (sortCol===col) { sortDir = sortDir==='desc'?'asc':'desc'; }
  else { sortCol=col; sortDir='desc'; }
