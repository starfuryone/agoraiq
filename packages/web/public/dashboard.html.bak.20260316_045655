<script>
(function(){
  'use strict';
  const API='/api/v1', TK=localStorage.getItem('iq_token');
  if(!TK){window.location.href='/login';return;}

  async function f(p,o={}){
    try{
      const r=await fetch(API+p,{headers:{'Authorization':'Bearer '+TK,'Content-Type':'application/json',...(o.headers||{})},...o});
      if(r.status===401){window.location.href='/login';return null;}
      if(!r.ok)return null;
      return await r.json();
    }catch(e){console.error('[Dash]',p,e);return null;}
  }
  function ago(d){if(!d)return'—';const m=Math.floor((Date.now()-new Date(d))/6e4);if(m<1)return'now';if(m<60)return m+'m';const h=Math.floor(m/60);if(h<24)return h+'h';return Math.floor(h/24)+'d';}
  function cl(s){return s>=80?'high':s>=60?'med':'low';}
  function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}
  function stl(s){
    const o=(s.outcome||s.status||'').toLowerCase();
    if(/tp/.test(o))return{t:'TP Hit',c:'tp'};if(/sl|stop/.test(o))return{t:'Stopped',c:'stopped'};
    if(/exp/.test(o))return{t:'Expired',c:'expired'};if(/open|active/.test(o))return{t:'Active',c:'active'};
    if(s.createdAt&&Date.now()-new Date(s.createdAt)<36e5)return{t:'New',c:'new'};
    return{t:'Active',c:'active'};
  }

  let plan='free',cf='all',pr='7d',allSigs=[];

  // ── Auth ──
  async function loadUser(){
    const d=await f('/auth/me');if(!d)return;
    const u=d.user||d;
    const sub=d.subscription||u.subscription||{};
    plan=(sub.tier||sub.plan||u.tier||u.plan||'free').toLowerCase();
    if(plan==='starter')plan='free';
    const t=document.getElementById('dash-plan');t.dataset.plan=plan;t.textContent=plan.toUpperCase();
    document.getElementById('dash-upgrade-hdr').style.display=plan==='free'?'':'none';
    if(plan!=='free')document.getElementById('dash-ucard').style.display='none';
    // Nav email
    const emailEl=document.getElementById('dash-nav-email');
    if(emailEl&&(u.email||u.name))emailEl.textContent=u.email||u.name;
    // Lock pro-only nav links for free tier
    document.querySelectorAll('#dash-nav-links a[data-pro]').forEach(a=>{
      if(plan==='free'){
        a.classList.add('nav-locked');
        a.addEventListener('click',e=>{
          e.preventDefault();
          window.location.href='/pricing';
        });
      } else {
        a.classList.remove('nav-locked');
      }
    });
  }

  // ── Intel Strip ──
  function renderIntel(d){
    const el=document.getElementById('dash-intel');
    if(!d){el.innerHTML=Array(5).fill(0).map((_,i)=>`<div class="dash-intel-card brand-fadeUp brand-fadeUp-${i+1}" data-type="${['regime','signals','provider','breadth','plan'][i]}"><div class="dash-intel-label">${['Market Regime','Actionable Signals','Top Provider','Market Breadth','Your Plan'][i]}</div><div class="dash-intel-value"><span class="brand-skeleton brand-skel-value"></span></div><div class="dash-intel-meta"><span class="brand-skeleton brand-skel-text"></span></div></div>`).join('');return;}
    const r=d.regime||{},rc=(r.label||'').toLowerCase().includes('risk-on')?'bullish':(r.label||'').toLowerCase().includes('risk-off')?'bearish':'neutral';
    const plCopy=plan==='free'?`You're seeing 3 of ${d.totalProviders||'100+'} providers`:`${d.totalProviders||'—'} providers tracked`;
    el.innerHTML=`
      <div class="dash-intel-card brand-fadeUp brand-fadeUp-1" data-type="regime">
        <div class="dash-intel-label">Market Regime</div>
        <div class="dash-intel-value"><span class="dash-regime-dot ${rc}"></span>${esc(r.label||'—')}</div>
        <div class="dash-intel-meta">Confidence ${r.confidence||'—'}%${r.changedAgo?` · <span class="${rc==='bullish'?'up':'down'}">Changed ${esc(r.changedAgo)}</span>`:''}</div>
        <div class="dash-conf-bar"><div class="fill" style="width:${r.confidence||0}%;background:var(--${rc==='bullish'?'green':rc==='bearish'?'red':'amber'});"></div></div>
      </div>
      <div class="dash-intel-card brand-fadeUp brand-fadeUp-2" data-type="signals">
        <div class="dash-intel-label">Actionable Signals</div>
        <div class="dash-intel-value" style="color:var(--cyan);">${d.actionableCount??'—'}</div>
        <div class="dash-intel-meta">High-confidence setups${d.actionableDelta!=null?` · <span class="${d.actionableDelta>=0?'up':'down'}">${d.actionableDelta>=0?'+':''}${d.actionableDelta} vs yesterday</span>`:''}</div>
      </div>
      <div class="dash-intel-card brand-fadeUp brand-fadeUp-3" data-type="provider">
        <div class="dash-intel-label">Top Provider Today</div>
        <div class="dash-intel-value" style="font-size:16px;">${esc(d.topProvider?.name||'—')}</div>
        <div class="dash-intel-meta">${d.topProvider?`7d WR ${d.topProvider.winRate||'—'}% · Avg R <span class="up">${d.topProvider.avgR||'—'}</span>`:'—'}</div>
      </div>
      <div class="dash-intel-card brand-fadeUp brand-fadeUp-4" data-type="breadth">
        <div class="dash-intel-label">Market Breadth</div>
        <div class="dash-intel-value" style="color:#f59e0b;">${d.breadth??'—'}%</div>
        <div class="dash-intel-meta">Pairs above short-term trend</div>
        <div class="dash-conf-bar"><div class="fill" style="width:${d.breadth||0}%;background:#f59e0b;"></div></div>
      </div>
      <div class="dash-intel-card brand-fadeUp brand-fadeUp-5" data-type="plan">
        <div class="dash-intel-label">Your Plan</div>
        <div class="dash-intel-value" style="font-size:16px;">${plan.charAt(0).toUpperCase()+plan.slice(1)}</div>
        <div class="dash-intel-meta">${plCopy}</div>
      </div>`;
    document.getElementById('dash-updated').textContent='Updated '+ago(d.updatedAt||new Date().toISOString());
  }
  async function loadIntel(){renderIntel(null);const d=await f('/dashboard/intelligence');if(d)renderIntel(d);}

  // ── Signals ──
  function renderSigs(sigs){
    const feed=document.getElementById('dash-feed'),ftr=document.getElementById('dash-sftr'),act=document.getElementById('dash-nact');
    const FL=6,paid=plan!=='free',vc=paid?sigs.length:Math.min(sigs.length,FL),lc=paid?0:Math.max(0,sigs.length-FL);
    let h='';
    sigs.forEach((s,i)=>{
      const lk=!paid&&i>=FL,st=stl(s),c=cl(s.confidence||s.score||0),dir=(s.direction||'').toLowerCase();
      h+=`<div class="dash-srow${lk?' locked':''}"><div class="dash-spair">${esc(s.pair)}</div><div><span class="dash-sdir ${dir}">${dir}</span></div><div class="dash-sentry">${s.entry?parseFloat(s.entry).toLocaleString(undefined,{maximumFractionDigits:6}):'—'}</div><div><span class="dash-cdot ${c}"></span>${s.confidence||s.score||'—'}%</div><div class="dash-sprov">${esc(s.providerName||s.provider)}</div><div class="dash-sage">${ago(s.createdAt)}</div><div><span class="dash-sstat ${st.c}">${st.t}</span></div><div class="dash-sact"><a href="/signals">View →</a></div></div>`;
    });
    if(!sigs.length)h='<div style="padding:32px 18px;text-align:center;color:var(--text-muted);">No signals match this filter</div>';
    feed.innerHTML=h;
    ftr.innerHTML=lc>0?`<span>${lc} more signal${lc>1?'s':''} available today</span><a href="/pricing">See which signals deserve attention →</a>`:`<a href="/signals" style="color:var(--cyan);text-decoration:none;font-size:11.5px;">Browse full signal history →</a>`;
    const top=sigs[0];
    act.innerHTML=`<a href="/signals" class="dash-nbtn"><div class="lb">Review top signal</div><div class="ht">${top?esc(top.pair)+' '+(top.confidence||top.score||'')+'%':'—'}</div></a><a href="/marketplace" class="dash-nbtn"><div class="lb">Follow top provider</div><div class="ht" id="dash-nxtprov">—</div></a><a href="/scanner" class="dash-nbtn"><div class="lb">Open Scanner</div><div class="ht">Confirm with TA</div></a>`;
  }
  function filterSigs(flt){cf=flt;let s=allSigs;if(flt==='high')s=allSigs.filter(x=>(x.confidence||x.score||0)>=80);if(flt==='new')s=allSigs.filter(x=>stl(x).c==='new');if(flt==='active')s=allSigs.filter(x=>['active','new'].includes(stl(x).c));if(flt==='closed')s=allSigs.filter(x=>['tp','stopped','expired'].includes(stl(x).c));renderSigs(s);}
  async function loadSigs(){const d=await f('/dashboard/signals?limit=20');if(!d)return;allSigs=d.signals||d||[];filterSigs(cf);}

  // ── Providers ──
  function renderProvs(ps){
    const el=document.getElementById('dash-plist'),cta=document.getElementById('dash-pcta');
    const paid=plan!=='free',FL=3;
    let h='';
    (ps||[]).forEach((p,i)=>{
      const lk=!paid&&i>=FL,ini=(p.name||'??').split(/[\s_-]/).map(w=>w[0]).join('').substring(0,2).toUpperCase();
      h+=`<div class="dash-prow${lk?' locked':''}"><div class="dash-pinfo"><div class="dash-prank${i<3?' top':''}">${i+1}</div><div class="dash-pavatar">${ini}</div><div class="dash-pname">${esc(p.name)}</div></div><div class="dash-pstats"><div><div class="dash-psl">WR</div><div class="dash-psv${(p.winRate||0)>=65?' pos':''}">${p.winRate||'—'}%</div></div><div><div class="dash-psl">Avg R</div><div class="dash-psv${(p.avgR||0)>=1.5?' pos':''}">${p.avgR||'—'}</div></div></div><button class="dash-fbtn">Follow</button></div>`;
    });
    el.innerHTML=h||'<div style="padding:20px 18px;text-align:center;color:var(--text-muted);">No provider data</div>';
    if(ps&&ps[0]){const ht=document.getElementById('dash-nxtprov');if(ht)ht.textContent=ps[0].name+' · '+(ps[0].winRate||'—')+'% WR';}
    cta.innerHTML=!paid&&ps.length>FL?`<a href="/pricing" style="color:var(--cyan);text-decoration:none;font-size:11.5px;font-weight:500;">Unlock all 100+ providers →</a>`:`<a href="/marketplace" style="color:var(--cyan);text-decoration:none;font-size:11.5px;">Full provider rankings →</a>`;
  }
  async function loadProvs(r){pr=r||pr;const d=await f('/dashboard/top-providers?range='+pr+'&limit=8');if(d)renderProvs(d.providers||d||[]);}

  // ── Explainers ──
  async function loadExpl(){
    const d=await f('/dashboard/explainers'),el=document.getElementById('dash-expl');
    if(!d||!d.items||!d.items.length){el.innerHTML='<div class="dash-eitem"><div class="dash-eq">Why this section exists</div><div class="dash-ea">AgoraIQ uses composite scoring to grade signals and providers. This section explains the reasoning behind today\'s top rankings and market read.</div></div>';return;}
    el.innerHTML=d.items.map(i=>`<div class="dash-eitem"><div class="dash-eq">${esc(i.question)}</div><div class="dash-ea">${esc(i.answer)}</div></div>`).join('');
  }

  // ── Activity Bar Chart (SVG) ──
  function renderActivityChart(days) {
    const svg = document.getElementById('dash-act-svg');
    const tt = document.getElementById('dash-act-tt');
    const wrap = document.getElementById('dash-activity-chart');
    const avgEl = document.getElementById('dash-act-avg');
    const todayEl = document.getElementById('dash-today-ct');

    const W = 560, H = 160, PAD_L = 32, PAD_R = 8, PAD_T = 12, PAD_B = 24;
    const chartW = W - PAD_L - PAD_R;
    const chartH = H - PAD_T - PAD_B;
    const n = days.length;
    const mx = Math.max(...days, 1);
    const barW = Math.max(2, (chartW / n) - 2);
    const gap = (chartW - barW * n) / n;
    const avg = Math.round(days.reduce((a, b) => a + b, 0) / n);

    // Y-axis ticks
    const ticks = [0, Math.round(mx / 2), mx];
    let markup = '';

    // Grid lines + Y labels
    ticks.forEach(t => {
      const y = PAD_T + chartH - (t / mx) * chartH;
      markup += `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${y}" y2="${y}" stroke="#1a1d2e" stroke-width="1"/>`;
      markup += `<text x="${PAD_L - 6}" y="${y + 3}" fill="#475569" font-size="9" font-family="DM Mono,monospace" text-anchor="end">${t}</text>`;
    });

    // Average line
    const avgY = PAD_T + chartH - (avg / mx) * chartH;
    markup += `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${avgY}" y2="${avgY}" stroke="rgba(0,212,255,0.25)" stroke-width="1" stroke-dasharray="4,3"/>`;

    // Bars
    days.forEach((v, i) => {
      const x = PAD_L + i * (barW + gap) + gap / 2;
      const h = (v / mx) * chartH;
      const y = PAD_T + chartH - h;
      const opacity = v === 0 ? 0.08 : 0.6 + (v / mx) * 0.4;
      const dayLabel = getDayLabel(i, n);

      markup += `<rect x="${x}" y="${y}" width="${barW}" height="${Math.max(h, 1)}" rx="2" fill="var(--cyan)" opacity="${opacity}" class="dash-act-bar" data-idx="${i}" data-val="${v}" data-label="${dayLabel}"/>`;

      // X-axis labels (every 5 days)
      if (i % 5 === 0 || i === n - 1) {
        markup += `<text x="${x + barW / 2}" y="${H - 4}" fill="#475569" font-size="8" font-family="DM Mono,monospace" text-anchor="middle">${dayLabel}</text>`;
      }
    });

    svg.innerHTML = markup;

    // Tooltip
    svg.addEventListener('mousemove', e => {
      const bar = e.target.closest('.dash-act-bar');
      if (!bar) { tt.classList.remove('show'); return; }
      const rect = wrap.getBoundingClientRect();
      const ex = e.clientX - rect.left;
      const ey = e.clientY - rect.top;
      tt.innerHTML = `<span class="tt-label">${bar.dataset.label}</span><br><span class="tt-value">${bar.dataset.val} signals</span>`;
      tt.style.left = (ex + 12) + 'px';
      tt.style.top = (ey - 8) + 'px';
      tt.classList.add('show');
    });
    svg.addEventListener('mouseleave', () => tt.classList.remove('show'));

    avgEl.textContent = `Avg: ${avg}/day`;
    todayEl.textContent = 'Today: ' + (days[days.length - 1] || 0) + ' signals';
  }

  function getDayLabel(idx, total) {
    const d = new Date(Date.now() - (total - 1 - idx) * 864e5);
    return (d.getMonth() + 1) + '/' + d.getDate();
  }

  async function loadActivity() {
    const d = await f('/dashboard/activity?days=30');
    const days = d && d.days ? d.days : Array(30).fill(0);
    renderActivityChart(days);
  }

  // ── Win Rate Line Chart (SVG) ──
  function renderWinRateChart(data) {
    // data = [{ date, winRate (0-100), resolved (count) }, ...]
    const svg = document.getElementById('dash-wr-svg');
    const tt = document.getElementById('dash-wr-tt');
    const wrap = document.getElementById('dash-wr-chart');
    const avgEl = document.getElementById('dash-wr-avg');
    const tsEl = document.getElementById('dash-wr-ts');

    const W = 560, H = 160, PAD_L = 32, PAD_R = 8, PAD_T = 12, PAD_B = 24;
    const chartW = W - PAD_L - PAD_R;
    const chartH = H - PAD_T - PAD_B;
    const n = data.length;
    if (n === 0) { svg.innerHTML = '<text x="280" y="80" fill="#475569" font-size="11" text-anchor="middle" font-family="DM Mono,monospace">No data yet</text>'; return; }

    const maxResolved = Math.max(...data.map(d => d.resolved), 1);
    const avgWR = Math.round(data.reduce((a, d) => a + d.winRate, 0) / n);

    let markup = '';

    // Y-axis ticks (win rate 0-100%)
    [0, 25, 50, 75, 100].forEach(t => {
      const y = PAD_T + chartH - (t / 100) * chartH;
      markup += `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${y}" y2="${y}" stroke="#1a1d2e" stroke-width="1"/>`;
      markup += `<text x="${PAD_L - 6}" y="${y + 3}" fill="#475569" font-size="9" font-family="DM Mono,monospace" text-anchor="end">${t}%</text>`;
    });

    // Resolved trade volume bars (background)
    const barW = Math.max(2, (chartW / n) - 3);
    const barGap = (chartW - barW * n) / n;
    data.forEach((d, i) => {
      const x = PAD_L + i * (barW + barGap) + barGap / 2;
      const h = (d.resolved / maxResolved) * chartH * 0.5; // scale to half height
      const y = PAD_T + chartH - h;
      markup += `<rect x="${x}" y="${y}" width="${barW}" height="${h}" rx="1.5" fill="rgba(0,212,255,0.12)" />`;
    });

    // Win rate line
    const points = data.map((d, i) => {
      const x = PAD_L + (i / Math.max(n - 1, 1)) * chartW;
      const y = PAD_T + chartH - (d.winRate / 100) * chartH;
      return { x, y, ...d };
    });

    // Area fill under line
    const areaPath = `M${points[0].x},${PAD_T + chartH} ` +
      points.map(p => `L${p.x},${p.y}`).join(' ') +
      ` L${points[points.length - 1].x},${PAD_T + chartH} Z`;
    markup += `<path d="${areaPath}" fill="url(#wr-gradient)" opacity="0.3"/>`;

    // Gradient def
    markup += `<defs><linearGradient id="wr-gradient" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--green)" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="var(--green)" stop-opacity="0"/>
    </linearGradient></defs>`;

    // Line path
    const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x},${p.y}`).join(' ');
    markup += `<path d="${linePath}" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`;

    // Average line
    const avgY = PAD_T + chartH - (avgWR / 100) * chartH;
    markup += `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${avgY}" y2="${avgY}" stroke="rgba(16,185,129,0.25)" stroke-width="1" stroke-dasharray="4,3"/>`;

    // Data points (hover targets)
    points.forEach((p, i) => {
      const dayLabel = getDayLabel(i, n);
      markup += `<circle cx="${p.x}" cy="${p.y}" r="12" fill="transparent" class="dash-wr-dot" data-idx="${i}" data-wr="${p.winRate}" data-res="${p.resolved}" data-label="${dayLabel}"/>`;
      markup += `<circle cx="${p.x}" cy="${p.y}" r="3" fill="var(--green)" opacity="0" class="dash-wr-vis" data-idx="${i}"/>`;
    });

    // X labels
    points.forEach((p, i) => {
      if (i % 5 === 0 || i === n - 1) {
        const dayLabel = getDayLabel(i, n);
        markup += `<text x="${p.x}" y="${H - 4}" fill="#475569" font-size="8" font-family="DM Mono,monospace" text-anchor="middle">${dayLabel}</text>`;
      }
    });

    svg.innerHTML = markup;

    // Tooltip + dot reveal
    svg.addEventListener('mousemove', e => {
      const dot = e.target.closest('.dash-wr-dot');
      // Hide all visible dots first
      svg.querySelectorAll('.dash-wr-vis').forEach(d => d.setAttribute('opacity', '0'));
      if (!dot) { tt.classList.remove('show'); return; }
      const idx = dot.dataset.idx;
      const vis = svg.querySelector(`.dash-wr-vis[data-idx="${idx}"]`);
      if (vis) vis.setAttribute('opacity', '1');
      const rect = wrap.getBoundingClientRect();
      const ex = e.clientX - rect.left;
      const ey = e.clientY - rect.top;
      tt.innerHTML = `<span class="tt-label">${dot.dataset.label}</span><br><span class="tt-value green">${dot.dataset.wr}% win rate</span><br><span class="tt-label">${dot.dataset.res} resolved</span>`;
      tt.style.left = Math.min(ex + 12, wrap.offsetWidth - 120) + 'px';
      tt.style.top = (ey - 8) + 'px';
      tt.classList.add('show');
    });
    svg.addEventListener('mouseleave', () => {
      tt.classList.remove('show');
      svg.querySelectorAll('.dash-wr-vis').forEach(d => d.setAttribute('opacity', '0'));
    });

    avgEl.textContent = `Avg: ${avgWR}%`;
    if (data.length > 0) {
      const latest = data[data.length - 1];
      const trend = latest.winRate >= avgWR ? '↑' : '↓';
      tsEl.textContent = `Current: ${latest.winRate}% ${trend}`;
    }
  }

  async function loadWinRate() {
    const d = await f('/dashboard/win-rate-trend?days=30');
    if (d && d.trend) {
      renderWinRateChart(d.trend);
    } else {
      // Fallback: empty state
      renderWinRateChart([]);
    }
  }

  // ── Market Pulse ──
  async function loadPulse(){
    const el=document.getElementById('dash-mpulse'),hl=document.getElementById('dash-mhl');
    const d=await f('/dashboard/market-pulse');
    if(!d||!d.pairs){el.innerHTML='<div style="padding:20px 18px;text-align:center;color:var(--text-muted);">Market data loading…</div>';return;}
    el.innerHTML=d.pairs.map(p=>{
      const cc=p.change24h>=0?'pos':'neg',tc=(p.trend||'').toLowerCase().replace(/\s/g,''),vc=(p.volumeStatus||'normal').toLowerCase();
      return`<div class="dash-mrow"><div class="dash-mpair">${esc(p.pair)}</div><div class="dash-mchg ${cc}">${p.change24h>=0?'+':''}${p.change24h}%</div><div><span class="dash-mbadge ${vc}">${esc(p.volumeStatus||'Normal')}</span></div><div><span class="dash-mbadge ${tc}">${esc(p.trend||'—')}</span></div><div style="color:var(--text-dim);">${esc(p.volatility||'—')}</div><div style="color:var(--cyan);">${p.signalCount??'—'}</div></div>`;
    }).join('');
    const tags=[];
    if(d.movers)d.movers.forEach(m=>tags.push(`<span class="dash-mtag mover">⬆ ${esc(m)}</span>`));
    if(d.breakouts)d.breakouts.forEach(b=>tags.push(`<span class="dash-mtag breakout">◈ Breakout: ${esc(b)}</span>`));
    if(d.freshSignals)d.freshSignals.forEach(x=>tags.push(`<span class="dash-mtag fresh">⚡ Signal: ${esc(x)}</span>`));
    if(d.overextended)d.overextended.forEach(x=>tags.push(`<span class="dash-mtag overext">⚠ Overextended: ${esc(x)}</span>`));
    hl.innerHTML=tags.join('')||'<span style="color:var(--text-muted);font-size:10px;">No highlights currently</span>';
  }

  // ── Events ──
  document.getElementById('dash-filters').addEventListener('click',e=>{
    const p=e.target.closest('.dash-fpill');if(!p)return;
    document.querySelectorAll('#dash-filters .dash-fpill').forEach(x=>x.classList.remove('active'));
    p.classList.add('active');filterSigs(p.dataset.f);
  });
  document.getElementById('dash-ptoggle').addEventListener('click',e=>{
    const t=e.target.closest('.dash-ttab');if(!t)return;
    document.querySelectorAll('#dash-ptoggle .dash-ttab').forEach(x=>x.classList.remove('active'));
    t.classList.add('active');loadProvs(t.dataset.r);
  });

  // Hamburger toggle
  document.getElementById('dash-hamburger').addEventListener('click',()=>{
    document.getElementById('dash-nav-links').classList.toggle('open');
  });
  // Close menu on link click (mobile)
  document.getElementById('dash-nav-links').addEventListener('click',e=>{
    if(e.target.tagName==='A') document.getElementById('dash-nav-links').classList.remove('open');
  });
  // Logout
  document.getElementById('dash-logout').addEventListener('click',e=>{
    e.preventDefault();
    localStorage.removeItem('iq_token');
    window.location.href='/login';
  });

  // ── Init ──
  (async()=>{
    await loadUser();
    await Promise.all([loadIntel(),loadSigs(),loadProvs(),loadExpl(),loadActivity(),loadWinRate(),loadPulse()]);
  })();

  // Auto-refresh 60s
  setInterval(()=>{loadIntel();loadSigs();loadPulse();},60000);
})();
</script>
</body>
</html>
