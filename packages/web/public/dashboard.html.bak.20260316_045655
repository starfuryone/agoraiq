<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgoraIQ — Signal Intelligence Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<style>
  /* ══════════════════════════════════════
     DASHBOARD — Signal Intelligence Hub
     Self-contained dark theme (no external CSS dependency)
     ══════════════════════════════════════ */

  :root {
    --bg: #08090d;
    --bg-card: #0e1017;
    --bg-surface: #111320;
    --border: #1a1d2e;
    --border-active: #2a2f45;
    --cyan: #00d4ff;
    --green: #10b981;
    --red: #ef4444;
    --amber: #f59e0b;
    --purple: #a78bfa;
    --text: #e2e8f0;
    --text-dim: #64748b;
    --text-muted: #475569;
    --font-display: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  #dashboard-root {
    max-width: 1320px;
    margin: 0 auto;
    padding: 24px 28px 48px;
  }

  @keyframes brand-fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes brand-shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  .brand-fadeUp { animation: brand-fadeUp 0.45s ease-out both; }
  .brand-fadeUp-1 { animation-delay: 0.04s; }
  .brand-fadeUp-2 { animation-delay: 0.08s; }
  .brand-fadeUp-3 { animation-delay: 0.12s; }
  .brand-fadeUp-4 { animation-delay: 0.16s; }
  .brand-fadeUp-5 { animation-delay: 0.20s; }

  .brand-skeleton {
    background: linear-gradient(90deg, var(--bg-card,#0e1017) 25%, #1a1d2e 50%, var(--bg-card,#0e1017) 75%);
    background-size: 200% 100%;
    animation: brand-shimmer 1.4s ease-in-out infinite;
    border-radius: 4px;
    display: inline-block;
  }
  .brand-skel-text  { width: 80px; height: 14px; }
  .brand-skel-value { width: 48px; height: 22px; }
  .brand-skel-row   { width: 100%; height: 42px; margin-bottom: 1px; }

  /* ── Brand Logo (matches landing page exactly) ── */
  .dash-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .dash-brand .brand-mark {
    width: 32px; height: 32px;
    background: linear-gradient(135deg, var(--cyan, #00d4ff), #0066ff);
    clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
    flex: 0 0 auto;
  }
  .dash-brand .brand-text {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -0.5px;
    color: var(--text, #e2e8f0);
    white-space: nowrap;
    line-height: 1;
  }
  .dash-brand .brand-iq {
    color: var(--cyan, #00d4ff);
    margin-left: 0;
  }

  /* ── Page Header ── */
  .dash-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 22px;
  }
  .dash-header h1 {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 22px; font-weight: 700; letter-spacing: -0.5px;
    color: var(--text, #e2e8f0);
  }
  .dash-subtitle {
    color: var(--text-dim, #64748b); font-size: 12px; margin-top: 3px;
    font-family: var(--font-mono, 'DM Mono', monospace);
  }
  .dash-plan-badge { display: flex; align-items: center; gap: 10px; }
  .dash-plan-tag {
    font-size: 10px; font-weight: 500; padding: 4px 10px; border-radius: 20px;
    letter-spacing: 0.8px; text-transform: uppercase;
    font-family: var(--font-mono, 'DM Mono', monospace);
  }
  .dash-plan-tag[data-plan="free"]  { background: rgba(100,116,139,0.12); color: var(--text-dim); border: 1px solid var(--border); }
  .dash-plan-tag[data-plan="pro"]   { background: rgba(0,212,255,0.1); color: var(--cyan); border: 1px solid rgba(0,212,255,0.2); }
  .dash-plan-tag[data-plan="elite"] { background: rgba(167,139,250,0.1); color: #a78bfa; border: 1px solid rgba(167,139,250,0.2); }
  .dash-upgrade-sm {
    background: linear-gradient(135deg, var(--cyan,#00d4ff), #0099cc);
    color: var(--bg,#08090d);
    font-family: var(--font-display); font-weight: 600; font-size: 11px;
    padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer;
    text-decoration: none; transition: all 0.2s;
  }
  .dash-upgrade-sm:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,212,255,0.25); }

  /* ── Intel Strip ── */
  .dash-intel-strip { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 22px; }
  .dash-intel-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 16px; position: relative; overflow: hidden;
    transition: border-color 0.2s, transform 0.15s;
  }
  .dash-intel-card:hover { border-color: #2a2f45; transform: translateY(-1px); }
  .dash-intel-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; }
  .dash-intel-card[data-type="regime"]::before   { background: var(--green); }
  .dash-intel-card[data-type="signals"]::before   { background: var(--cyan); }
  .dash-intel-card[data-type="provider"]::before  { background: #a78bfa; }
  .dash-intel-card[data-type="breadth"]::before   { background: #f59e0b; }
  .dash-intel-card[data-type="plan"]::before      { background: #2a2f45; }
  .dash-intel-label {
    font-size: 10px; color: var(--text-muted,#475569); text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 8px; font-family: var(--font-mono);
  }
  .dash-intel-value {
    font-family: var(--font-display); font-size: 18px; font-weight: 700;
    letter-spacing: -0.3px; margin-bottom: 4px;
  }
  .dash-intel-meta { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }
  .dash-intel-meta .up   { color: var(--green); }
  .dash-intel-meta .down { color: var(--red); }
  .dash-regime-dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 50%;
    margin-right: 6px; position: relative; top: -1px;
  }
  .dash-regime-dot.bullish { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .dash-regime-dot.bearish { background: var(--red); box-shadow: 0 0 6px var(--red); }
  .dash-regime-dot.neutral { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; }
  .dash-conf-bar { margin-top:8px; height:3px; background:var(--bg); border-radius:2px; overflow:hidden; }
  .dash-conf-bar .fill { height:100%; border-radius:2px; transition:width 0.6s ease; }

  /* ── Body ── */
  .dash-body { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; }

  /* ── Cards ── */
  .dash-card { background:var(--bg-card); border:1px solid var(--border); border-radius:10px; overflow:hidden; }
  .dash-card-head {
    display:flex; justify-content:space-between; align-items:center;
    padding:14px 18px; border-bottom:1px solid var(--border);
  }
  .dash-card-title { font-family:var(--font-display); font-size:13.5px; font-weight:600; letter-spacing:-0.2px; }
  .dash-view-all { color:var(--cyan); text-decoration:none; font-size:11px; font-family:var(--font-mono); opacity:0.8; transition:opacity 0.2s; }
  .dash-view-all:hover { opacity:1; }
  .dash-ts { font-size:10px; color:var(--text-muted); font-family:var(--font-mono); }
  .dash-ts::before { content:'●'; color:var(--green); margin-right:4px; font-size:7px; position:relative; top:-1px; }

  /* ── Filters ── */
  .dash-filters { display:flex; gap:6px; padding:10px 18px; border-bottom:1px solid var(--border); overflow-x:auto; }
  .dash-fpill {
    background:var(--bg); color:var(--text-dim); border:1px solid var(--border);
    border-radius:20px; padding:4px 12px; font-size:10.5px; font-family:var(--font-mono);
    cursor:pointer; white-space:nowrap; transition:all 0.2s;
  }
  .dash-fpill:hover { border-color:#2a2f45; color:var(--text); }
  .dash-fpill.active { background:rgba(0,212,255,0.1); color:var(--cyan); border-color:rgba(0,212,255,0.3); }

  /* ── Signal Feed ── */
  .dash-srow {
    display:grid; grid-template-columns:100px 56px 90px 72px 100px 50px 100px 70px;
    align-items:center; gap:8px; padding:11px 18px; border-bottom:1px solid var(--border);
    font-size:12px; font-family:var(--font-mono); transition:background 0.15s;
  }
  .dash-srow:hover { background:#13151e; }
  .dash-srow.hdr {
    font-size:10px; color:var(--text-muted); text-transform:uppercase;
    letter-spacing:0.8px; background:var(--bg); font-weight:500;
  }
  .dash-srow.hdr:hover { background:var(--bg); }
  .dash-srow.locked { filter:blur(3px); pointer-events:none; user-select:none; opacity:0.5; }
  .dash-spair { font-family:var(--font-display); font-weight:600; font-size:12.5px; }
  .dash-sdir { font-size:10px; font-weight:500; padding:2px 8px; border-radius:3px; text-align:center; text-transform:uppercase; letter-spacing:0.5px; }
  .dash-sdir.long  { background:rgba(16,185,129,0.1); color:var(--green); }
  .dash-sdir.short { background:rgba(239,68,68,0.1);  color:var(--red); }
  .dash-sentry { color:var(--text-dim); font-variant-numeric:tabular-nums; }
  .dash-cdot { display:inline-block; width:6px; height:6px; border-radius:50%; margin-right:5px; }
  .dash-cdot.high { background:var(--green); }
  .dash-cdot.med  { background:#f59e0b; }
  .dash-cdot.low  { background:var(--red); }
  .dash-sprov { color:var(--text-dim); font-size:11px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .dash-sage { color:var(--text-muted); font-size:11px; }
  .dash-sstat {
    font-size:10px; padding:2px 8px; border-radius:3px; text-align:center;
    font-weight:500; letter-spacing:0.3px; text-transform:uppercase; display:inline-block;
  }
  .dash-sstat.new     { background:rgba(0,212,255,0.1);  color:var(--cyan); }
  .dash-sstat.active  { background:rgba(16,185,129,0.1); color:var(--green); }
  .dash-sstat.tp      { background:rgba(16,185,129,0.1); color:var(--green); }
  .dash-sstat.stopped { background:rgba(239,68,68,0.1);  color:var(--red); }
  .dash-sstat.expired { background:rgba(100,116,139,0.1);color:var(--text-muted); }
  .dash-sact a { color:var(--cyan); text-decoration:none; font-size:11px; opacity:0.7; transition:opacity 0.2s; }
  .dash-sact a:hover { opacity:1; }

  .dash-sfooter { padding:14px 18px; text-align:center; border-top:1px solid var(--border); font-family:var(--font-mono); }
  .dash-sfooter span { font-size:11.5px; color:var(--text-dim); }
  .dash-sfooter a { color:var(--cyan); text-decoration:none; font-size:11.5px; margin-left:8px; font-weight:500; }

  /* ── Next Actions ── */
  .dash-nactions { display:flex; gap:10px; padding:14px 18px; border-top:1px solid var(--border); background:var(--bg); }
  .dash-nbtn {
    flex:1; background:var(--bg-card); border:1px solid var(--border); border-radius:6px;
    padding:10px 12px; text-align:center; cursor:pointer; transition:all 0.2s; text-decoration:none; display:block;
  }
  .dash-nbtn:hover { border-color:var(--cyan); background:#13151e; }
  .dash-nbtn .lb { font-family:var(--font-display); font-size:11px; font-weight:600; color:var(--text); margin-bottom:2px; }
  .dash-nbtn .ht { font-size:10px; color:var(--text-muted); font-family:var(--font-mono); }

  /* ── Right Rail ── */
  .dash-rrail { display:flex; flex-direction:column; gap:16px; }

  /* Providers */
  .dash-prow {
    display:flex; align-items:center; justify-content:space-between;
    padding:11px 18px; border-bottom:1px solid var(--border); transition:background 0.15s;
  }
  .dash-prow:hover { background:#13151e; }
  .dash-prow.locked { filter:blur(4px); pointer-events:none; user-select:none; }
  .dash-pinfo { display:flex; align-items:center; gap:10px; flex:1; min-width:0; }
  .dash-prank { font-family:var(--font-display); font-weight:700; font-size:13px; color:var(--text-muted); width:22px; text-align:center; }
  .dash-prank.top { color:var(--cyan); }
  .dash-pavatar {
    width:28px; height:28px; border-radius:6px; background:rgba(0,212,255,0.06);
    display:flex; align-items:center; justify-content:center;
    font-family:var(--font-display); font-weight:700; font-size:11px; color:var(--cyan); flex-shrink:0;
  }
  .dash-pname { font-size:12px; font-weight:500; font-family:var(--font-mono); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .dash-pstats { display:flex; gap:14px; align-items:center; font-size:11px; flex-shrink:0; font-family:var(--font-mono); }
  .dash-psl { color:var(--text-muted); font-size:9px; text-transform:uppercase; letter-spacing:0.5px; }
  .dash-psv { font-variant-numeric:tabular-nums; }
  .dash-psv.pos { color:var(--green); }
  .dash-fbtn {
    background:rgba(100,116,139,0.08); border:1px solid var(--border); color:var(--text-dim);
    font-size:10px; padding:4px 10px; border-radius:4px; cursor:pointer;
    font-family:var(--font-mono); transition:all 0.2s; margin-left:10px; flex-shrink:0;
  }
  .dash-fbtn:hover { border-color:var(--cyan); color:var(--cyan); }

  .dash-ttabs { display:flex; gap:2px; background:var(--bg); border-radius:6px; padding:2px; }
  .dash-ttab {
    font-size:10px; font-family:var(--font-mono); padding:4px 10px; border-radius:4px;
    background:transparent; color:var(--text-muted); border:none; cursor:pointer; transition:all 0.2s;
  }
  .dash-ttab.active { background:var(--bg-card); color:var(--text); }

  /* Upgrade card */
  .dash-ucard {
    background:linear-gradient(135deg,rgba(0,212,255,0.05),rgba(167,139,250,0.05));
    border:1px solid rgba(0,212,255,0.12); border-radius:10px; padding:20px; text-align:center;
  }
  .dash-ucard h3 { font-family:var(--font-display); font-size:14px; font-weight:700; margin-bottom:6px; }
  .dash-ucard p { color:var(--text-dim); font-size:11.5px; line-height:1.6; margin-bottom:14px; font-family:var(--font-mono); }
  .dash-ubtn {
    display:inline-block; background:linear-gradient(135deg,var(--cyan),#0099cc);
    color:var(--bg); font-family:var(--font-display); font-weight:700; font-size:12px;
    padding:10px 28px; border-radius:8px; border:none; cursor:pointer; text-decoration:none;
    transition:all 0.25s;
  }
  .dash-ubtn:hover { transform:translateY(-2px); box-shadow:0 6px 24px rgba(0,212,255,0.25); }
  .dash-ufeats { margin-top:12px; text-align:left; list-style:none; padding:0; }
  .dash-ufeats li { font-size:11px; color:var(--text-dim); padding:3px 0; font-family:var(--font-mono); }
  .dash-ufeats li::before { content:'→ '; color:var(--cyan); }

  /* Explainer */
  .dash-eblock { padding:16px 18px; }
  .dash-eitem { padding:10px 0; border-bottom:1px solid var(--border); }
  .dash-eitem:last-child { border-bottom:none; }
  .dash-eq { font-family:var(--font-display); font-weight:600; font-size:12px; color:var(--cyan); margin-bottom:5px; }
  .dash-ea { font-size:11.5px; color:var(--text-dim); line-height:1.6; font-family:var(--font-mono); }

  /* Bottom row */
  .dash-bottom { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:20px; }

  /* ── SVG Charts ── */
  .dash-chart-wrap {
    padding: 16px 18px 12px;
    position: relative;
  }
  .dash-chart-wrap svg {
    width: 100%;
    display: block;
    overflow: visible;
  }
  .dash-chart-tooltip {
    position: absolute;
    background: #1a1d2e;
    border: 1px solid #2a2f45;
    border-radius: 6px;
    padding: 6px 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 10;
    white-space: nowrap;
  }
  .dash-chart-tooltip.show { opacity: 1; }
  .dash-chart-tooltip .tt-label { color: var(--text-muted); }
  .dash-chart-tooltip .tt-value { color: var(--cyan); font-weight: 500; }
  .dash-chart-tooltip .tt-value.green { color: var(--green); }
  .dash-chart-legend {
    display: flex; gap: 14px; padding: 8px 18px 12px;
    font-size: 10px; color: var(--text-muted); font-family: var(--font-mono);
  }
  .dash-chart-legend .leg-dot {
    display: inline-block; width: 8px; height: 8px;
    border-radius: 2px; margin-right: 5px; position: relative; top: 1px;
  }

  /* Market Pulse */
  .dash-mrow {
    display:grid; grid-template-columns:100px 68px 68px 78px 68px 56px;
    align-items:center; gap:8px; padding:9px 18px; border-bottom:1px solid var(--border);
    font-size:11.5px; font-family:var(--font-mono); transition:background 0.15s;
  }
  .dash-mrow:hover { background:#13151e; }
  .dash-mrow.hdr { font-size:10px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.8px; background:var(--bg); font-weight:500; }
  .dash-mpair { font-family:var(--font-display); font-weight:600; font-size:12px; }
  .dash-mchg.pos { color:var(--green); }
  .dash-mchg.neg { color:var(--red); }
  .dash-mbadge {
    font-size:9px; padding:2px 6px; border-radius:3px; text-transform:uppercase;
    letter-spacing:0.3px; font-weight:500; display:inline-block;
  }
  .dash-mbadge.uptrend   { background:rgba(16,185,129,0.1);  color:var(--green); }
  .dash-mbadge.downtrend { background:rgba(239,68,68,0.1);   color:var(--red); }
  .dash-mbadge.ranging   { background:rgba(245,158,11,0.1);  color:#f59e0b; }
  .dash-mbadge.spike     { background:rgba(167,139,250,0.1); color:#a78bfa; }
  .dash-mbadge.normal    { background:rgba(100,116,139,0.08);color:var(--text-muted); }
  .dash-mhighlights { padding:10px 18px; border-top:1px solid var(--border); display:flex; gap:8px; flex-wrap:wrap; }
  .dash-mtag { font-size:9px; padding:2px 6px; border-radius:3px; font-weight:500; font-family:var(--font-mono); }
  .dash-mtag.mover   { background:rgba(0,212,255,0.1);  color:var(--cyan); }
  .dash-mtag.breakout { background:rgba(167,139,250,0.1);color:#a78bfa; }
  .dash-mtag.fresh    { background:rgba(16,185,129,0.1); color:var(--green); }
  .dash-mtag.overext  { background:rgba(239,68,68,0.1);  color:var(--red); }

  /* ── Top Nav Bar ── */
  .dash-topnav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(8,9,13,0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 28px;
    display: flex; align-items: center; justify-content: space-between;
    height: 56px;
    margin: -24px -28px 24px;
    width: calc(100% + 56px);
  }
  .dash-topnav-brand {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .dash-topnav-brand .brand-mark {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, var(--cyan), #0066ff);
    clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
    flex: 0 0 auto;
  }
  .dash-topnav-brand .brand-text {
    font-family: var(--font-display);
    font-weight: 800; font-size: 16px;
    letter-spacing: -0.5px; color: var(--text);
    line-height: 1;
  }
  .dash-topnav-brand .brand-iq { color: var(--cyan); }
  .dash-topnav-links {
    display: flex; align-items: center; gap: 4px;
  }
  .dash-topnav-links a {
    color: var(--text-dim); text-decoration: none;
    font-family: var(--font-mono); font-size: 11.5px;
    padding: 6px 12px; border-radius: 6px;
    transition: all 0.2s; white-space: nowrap;
  }
  .dash-topnav-links a:hover { color: var(--text); background: rgba(255,255,255,0.04); }
  .dash-topnav-links a.active { color: var(--cyan); background: rgba(0,212,255,0.08); }
  .dash-topnav-links a.nav-locked {
    color: var(--text-muted);
    opacity: 0.45;
    cursor: pointer;
    position: relative;
  }
  .dash-topnav-links a.nav-locked:hover {
