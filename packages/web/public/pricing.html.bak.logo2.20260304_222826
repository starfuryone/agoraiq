<title>Pricing — AgoraIQ</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060a14;--bg2:#0b1120;--bg3:#111827;--bg4:#1a2332;--bg5:#1f2b3d;
  --border:#1e293b;--border2:#334155;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;
  --cyan:#38bdf8;--violet:#a78bfa;--green:#4ade80;--amber:#f59e0b;--red:#ff3b5c;
  --mono:'JetBrains Mono',monospace;--sans:'DM Sans',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased}

/* ── NAV ── */
.nav{position:sticky;top:0;z-index:100;background:rgba(6,10,20,.82);backdrop-filter:blur(20px) saturate(1.4);border-bottom:1px solid rgba(30,41,59,.5)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:60px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-weight:800;font-size:16px;letter-spacing:-.02em;color:var(--text);text-decoration:none;display:flex;align-items:center;gap:8px}
.nav-logo .agora{color:#a78bfa}
.nav-logo .iq{color:#e2e8f0}
.nav-links{display:flex;align-items:center;gap:6px}
.nav-links a{font-size:13px;font-weight:500;color:var(--text3);text-decoration:none;padding:6px 14px;border-radius:8px;transition:all .2s}
.nav-links a:hover{color:var(--text);background:rgba(255,255,255,.04)}
.nav-links a.active{color:var(--violet)}
.nav-cta{font-size:13px;font-weight:600;color:#fff!important;background:linear-gradient(135deg,var(--cyan),var(--violet));padding:7px 18px;border-radius:8px;text-decoration:none;transition:opacity .2s}
.nav-cta:hover{opacity:.88}

/* ── HERO ── */
.hero{text-align:center;padding:72px 24px 0;max-width:740px;margin:0 auto}
.hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.12);border-radius:999px;padding:5px 16px;font-size:12px;font-weight:600;color:var(--cyan);letter-spacing:.06em;text-transform:uppercase;margin-bottom:20px}
.hero h1{font-size:clamp(32px,5vw,52px);font-weight:800;letter-spacing:-.04em;line-height:1.1;margin-bottom:16px}
.hero h1 .grad{background:linear-gradient(135deg,var(--cyan),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero p{font-size:16px;color:var(--text2);max-width:560px;margin:0 auto;line-height:1.7}

/* ── BILLING TOGGLE ── */
.toggle-wrap{display:flex;align-items:center;justify-content:center;gap:12px;margin:40px 0 8px}
.toggle-label{font-size:14px;font-weight:500;color:var(--text3);transition:color .2s;cursor:pointer}
.toggle-label.active{color:var(--text)}
.toggle-track{width:52px;height:28px;border-radius:99px;background:var(--bg4);border:1px solid var(--border2);cursor:pointer;position:relative;transition:background .25s}
.toggle-track.on{background:linear-gradient(135deg,var(--cyan),var(--violet))}
.toggle-knob{width:22px;height:22px;border-radius:50%;background:#fff;position:absolute;top:2px;left:2px;transition:transform .25s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.toggle-track.on .toggle-knob{transform:translateX(24px)}
.save-badge{font-size:11px;font-weight:700;color:var(--green);background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.18);padding:2px 10px;border-radius:99px;margin-left:4px}

/* ── PRICING GRID ── */
.pricing-grid{max-width:1200px;margin:40px auto 0;padding:0 24px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
@media(max-width:1080px){.pricing-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.pricing-grid{grid-template-columns:1fr;max-width:440px}}

/* ── CARD ── */
.price-card{background:var(--bg3);border:1px solid var(--border);border-radius:16px;padding:32px 28px;display:flex;flex-direction:column;position:relative;transition:border-color .3s,transform .3s,box-shadow .3s}
.price-card:hover{border-color:var(--border2);transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.35)}
.price-card.featured{border-color:rgba(167,139,250,.35);background:linear-gradient(170deg,rgba(167,139,250,.06) 0%,var(--bg3) 40%)}
.price-card.featured::before{content:'';position:absolute;inset:-1px;border-radius:16px;background:linear-gradient(135deg,rgba(56,189,248,.25),rgba(167,139,250,.25));z-index:-1;opacity:0;transition:opacity .3s}
.price-card.featured:hover::before{opacity:1}
.popular-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--cyan),var(--violet));color:#fff;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:4px 16px;border-radius:99px;white-space:nowrap}

.card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:16px}
.card-icon.starter{background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.15)}
.card-icon.pro{background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.15)}
.card-icon.team{background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.15)}
.card-icon.vendor{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.15)}

.card-tier{font-size:15px;font-weight:700;margin-bottom:2px;letter-spacing:-.01em}
.card-audience{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.card-audience.cyan{color:var(--cyan)}
.card-audience.violet{color:var(--violet)}
.card-audience.green{color:var(--green)}
.card-audience.amber{color:var(--amber)}
.card-desc{font-size:13px;color:var(--text3);margin-bottom:20px;min-height:38px;line-height:1.55}

.card-price{display:flex;align-items:baseline;gap:4px;margin-bottom:4px}
.card-price .amount{font-family:var(--mono);font-size:40px;font-weight:700;letter-spacing:-.03em}
.card-price .period{font-size:13px;color:var(--text3)}
.card-price .original{font-size:14px;color:var(--text3);text-decoration:line-through;margin-left:6px;font-family:var(--mono)}
.card-billed{font-size:12px;color:var(--text3);margin-bottom:4px;min-height:18px}
.card-setup{font-size:11.5px;color:var(--amber);margin-bottom:20px;min-height:16px}

.card-divider{height:1px;background:var(--border);margin-bottom:20px}

.card-features{list-style:none;flex:1;margin-bottom:24px}
.card-features li{font-size:13px;color:var(--text2);padding:5px 0;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.card-features li::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0;font-size:12px;margin-top:2px}
.card-features li.highlight{color:var(--text);font-weight:600}
.card-features li.highlight::before{color:var(--cyan)}
.card-features li.addon{color:var(--text3);font-style:italic}
.card-features li.addon::before{content:'+';color:var(--amber)}

.upgrade-hint{font-size:11.5px;color:var(--text3);background:rgba(255,255,255,.025);border:1px dashed var(--border);border-radius:8px;padding:10px 12px;margin-bottom:16px;line-height:1.55}
.upgrade-hint strong{color:var(--text2);font-weight:600}

.card-cta{display:block;text-align:center;padding:12px 20px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;transition:all .2s;cursor:pointer;border:none;width:100%}
.card-cta.outline{background:transparent;border:1px solid var(--border2);color:var(--text)}
.card-cta.outline:hover{border-color:var(--text2);background:rgba(255,255,255,.03)}
.card-cta.primary{background:linear-gradient(135deg,var(--cyan),var(--violet));color:#fff}
.card-cta.primary:hover{opacity:.88;transform:scale(1.02)}
.card-cta.solid{background:var(--bg5);border:1px solid var(--border2);color:var(--text)}
.card-cta.solid:hover{background:rgba(255,255,255,.08)}
.card-cta.amber{background:linear-gradient(135deg,var(--amber),#f97316);color:#fff}
.card-cta.amber:hover{opacity:.88;transform:scale(1.02)}

/* ── COMPARISON TABLE ── */
.compare-section{max-width:1200px;margin:80px auto 0;padding:0 24px}
.compare-title{font-size:24px;font-weight:700;letter-spacing:-.03em;text-align:center;margin-bottom:32px}
.compare-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
.compare-table{width:100%;border-collapse:collapse;background:var(--bg3);border-radius:12px;overflow:hidden;min-width:640px}
.compare-table thead th{background:var(--bg2);padding:14px 16px;font-size:13px;font-weight:700;text-align:center;border-bottom:1px solid var(--border);color:var(--text)}
.compare-table thead th:first-child{text-align:left;color:var(--text2);font-weight:500}
.compare-table thead th .th-price{font-family:var(--mono);font-size:11px;font-weight:500;color:var(--text3);display:block;margin-top:2px}
.compare-table tbody td{padding:12px 16px;border-bottom:1px solid var(--border);font-size:13px;text-align:center;color:var(--text2)}
.compare-table tbody td:first-child{text-align:left;color:var(--text);font-weight:500}
.compare-table tbody tr:last-child td{border-bottom:none}
.compare-table tbody tr:hover{background:var(--bg4)}
.compare-table .check{color:var(--green);font-weight:700}
.compare-table .dash{color:var(--border2)}
.compare-table .cat-row td{background:var(--bg2);font-weight:700;color:var(--text);font-size:11px;text-transform:uppercase;letter-spacing:.06em;padding:10px 16px}

/* ── FAQ ── */
.faq-section{max-width:720px;margin:80px auto 0;padding:0 24px}
.faq-title{font-size:24px;font-weight:700;letter-spacing:-.03em;text-align:center;margin-bottom:32px}
.faq-item{border-bottom:1px solid var(--border);padding:20px 0}
.faq-q{font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;color:var(--text);transition:color .2s}
.faq-q:hover{color:var(--cyan)}
.faq-q .arrow{font-size:18px;color:var(--text3);transition:transform .25s}
.faq-item.open .faq-q .arrow{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .35s ease}
.faq-item.open .faq-a{max-height:300px;padding-top:12px}
.faq-a p{font-size:13px;color:var(--text2);line-height:1.7}

/* ── BOTTOM CTA ── */
.bottom-cta{text-align:center;padding:64px 24px 80px;max-width:560px;margin:0 auto}
.bottom-cta h2{font-size:24px;font-weight:700;letter-spacing:-.02em;margin-bottom:12px}
.bottom-cta p{font-size:14px;color:var(--text2);margin-bottom:24px}
.bottom-cta a{display:inline-block;background:linear-gradient(135deg,var(--cyan),var(--violet));color:#fff;padding:12px 32px;border-radius:10px;font-weight:600;font-size:15px;text-decoration:none;transition:opacity .2s}
.bottom-cta a:hover{opacity:.88}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  .nav-links a:not(.nav-cta){display:none}
  .hero{padding:48px 20px 0}
  .pricing-grid{padding:0 16px}
  .price-card{padding:28px 22px}
  .compare-section{padding:0 16px}
}

/* ── MEGA FOOTER ── */
.site-footer{border-top:1px solid rgba(255,255,255,.07);background:rgba(0,0,0,.25)}
.site-footer-inner{max-width:1200px;margin:0 auto;padding:40px 24px 48px}
.footer-top{display:flex;flex-wrap:wrap;gap:40px 56px;margin-bottom:32px}
.footer-brand{min-width:200px;max-width:260px}
.footer-logo{display:flex;align-items:center;gap:6px;text-decoration:none;font-size:14px;font-weight:800;letter-spacing:-.02em;margin-bottom:12px}
.footer-logo .agora{color:#a78bfa}
.footer-logo .iq{color:#e2e8f0}
.footer-logo svg{flex-shrink:0}
.footer-brand p{font-size:12px;color:var(--text3);line-height:1.65}
.footer-col h4{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);margin-bottom:12px}
.footer-col a{display:block;font-size:12.5px;color:var(--text3);text-decoration:none;padding:3px 0;transition:color .2s}
.footer-col a:hover{color:var(--cyan)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding-top:20px;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-start;gap:12px}
.footer-disclaimer{font-size:11px;line-height:1.6;color:var(--text3);max-width:640px}
.footer-disclaimer strong{color:var(--red)}
.footer-copy{font-size:11px;color:rgba(255,255,255,.2)}
@media(max-width:600px){.footer-top{gap:28px}.footer-brand{max-width:100%}}

</style>
