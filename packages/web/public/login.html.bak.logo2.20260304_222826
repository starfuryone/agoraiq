.brand{display:flex;align-items:center;gap:10px;text-decoration:none}
.brand-mark{width:32px;height:32px;background:linear-gradient(135deg,var(--cyan,#00e5ff),#0066ff);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex:0 0 auto}
.brand-text{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;letter-spacing:-0.5px;color:var(--text,#e2e8f0);white-space:nowrap;line-height:1}
.brand-iq{color:var(--cyan,#00e5ff);margin-left:0}
.brand-sm .brand-mark{width:20px;height:20px}
.brand-sm .brand-text{font-size:14px}
.brand-xs .brand-mark{width:18px;height:18px}
.brand-xs .brand-text{font-size:14px}
</style>
