<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AgoraIQ — Login</title>
  <style>
    :root { --bg:#0a0e17; --bg2:#111827; --card:#1a2332; --border:#2a3548; --text:#e5e7eb; --muted:#9ca3af; --accent:#3b82f6; --accent2:#2563eb; --green:#22c55e; --red:#ef4444; --font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; --radius:8px; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:var(--font); background:var(--bg); color:var(--text); min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; }
    
    .auth-card { background:var(--card); margin-bottom:60px; border:1px solid var(--border); border-radius:12px; padding:40px; width:100%; max-width:400px; }
    .logo { font-size:15px; font-weight:800; text-align:center; margin-bottom:8px; letter-spacing:-0.02em; display:flex; align-items:center; justify-content:center; gap:6px; } .logo .agora { color:#a78bfa; } .logo .iq { color:var(--text); }
    .subtitle { text-align:center; color:var(--muted); font-size:14px; margin-bottom:32px; }
    label { display:block; font-size:13px; color:var(--muted); margin-bottom:6px; margin-top:16px; }
    input { width:100%; padding:10px 14px; border-radius:var(--radius); border:1px solid var(--border); background:var(--bg2); color:var(--text); font-size:14px; outline:none; }
    input:focus { border-color:var(--accent); }
    .btn { width:100%; padding:12px; border-radius:var(--radius); border:none; background:var(--accent); color:#fff; font-size:15px; font-weight:600; cursor:pointer; margin-top:24px; }
    .btn:hover { background:var(--accent2); }
    .error { color:var(--red); font-size:13px; margin-top:12px; display:none; }
    .link { text-align:center; margin-top:16px; font-size:13px; color:var(--muted); }
    .link a { color:var(--accent); }
  
/* ── MEGA FOOTER ── */
