        <a href="/announcements">Announcements</a>
        <a href="/news">News</a>
        <a href="/press">Press</a>
      </div>
      <div class="footer-col">
        <h4>Legal</h4>
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="/cookies">Cookies</a>
        <a href="/disclaimer">Disclaimer</a>
        <a href="/trust">Building Trust</a>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <a href="/blog">Blog</a>
        <a href="/community">Community</a>
        <a href="/risk-warning">Risk Warning</a>
        <a href="/notices">Notices</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-disclaimer"><strong>⚠ Not for UK Persons.</strong> AgoraIQ is not authorised or regulated by the FCA. Not directed at UK persons. Nothing on this site constitutes financial advice. Past performance does not guarantee future results.</div>
      <div class="footer-copy">© 2026 ChatLogic Insights LTD. All rights reserved.</div>
    </div>
  </div>
</footer>

</body>
</html>
