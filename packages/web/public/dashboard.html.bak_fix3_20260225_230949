      const anchor = document.getElementById('monthly-breakdown') ||
                     document.getElementById('top-symbols');
      if (anchor) anchor.parentNode.insertBefore(container, anchor.nextSibling);
      else document.querySelector('.performance-section')?.appendChild(container);
    }

    function fmtHrs(h) {
      if (h === 0) return '—';
      if (h < 1) return Math.round(h * 60) + 'm';
      if (h < 24) return h.toFixed(1) + 'h';
      return (h / 24).toFixed(1) + 'd';
    }

    container.innerHTML = `
      <h3 style="font-size:16px;font-weight:600;color:#e2e8f0;margin-bottom:12px;">
        ⏱️ Duration Analytics
      </h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:16px;">
        <div style="background:#1e293b;border-radius:8px;padding:12px;">
          <div style="color:#94a3b8;font-size:11px;">Avg Duration</div>
          <div style="color:#e2e8f0;font-size:20px;font-weight:600;">${fmtHrs(dur.avgDuration)}</div>
          <div style="color:#64748b;font-size:11px;">Median: ${fmtHrs(dur.medianDuration)}</div>
        </div>
        <div style="background:#1e293b;border-radius:8px;padding:12px;">
          <div style="color:#94a3b8;font-size:11px;">Avg Time to TP</div>
          <div style="color:#4ade80;font-size:20px;font-weight:600;">${fmtHrs(dur.avgTimeToTP)}</div>
          <div style="color:#64748b;font-size:11px;">Median: ${fmtHrs(dur.medianTimeToTP)}</div>
        </div>
        <div style="background:#1e293b;border-radius:8px;padding:12px;">
          <div style="color:#94a3b8;font-size:11px;">Avg Time to SL</div>
          <div style="color:#f87171;font-size:20px;font-weight:600;">${fmtHrs(dur.avgTimeToSL)}</div>
          <div style="color:#64748b;font-size:11px;">Median: ${fmtHrs(dur.medianTimeToSL)}</div>
        </div>
        <div style="background:#1e293b;border-radius:8px;padding:12px;">
          <div style="color:#94a3b8;font-size:11px;">Trades Analyzed</div>
          <div style="color:#e2e8f0;font-size:20px;font-weight:600;">${dur.totalWithDuration}</div>
        </div>
      </div>
      <!-- Duration distribution chart -->
      <canvas id="duration-dist-chart" height="160"></canvas>
    `;

    // Draw horizontal bar chart for duration distribution
    const canvas = document.getElementById('duration-dist-chart');
    if (canvas && dur.distribution) {
      const ctx = canvas.getContext('2d');
      const W = canvas.width = canvas.offsetWidth;
      const H = canvas.height = 160;
      const pad = { top: 8, right: 16, bottom: 8, left: 60 };
      const cW = W - pad.left - pad.right;
      const cH = H - pad.top - pad.bottom;
      const buckets = dur.distribution;
      const maxCount = Math.max(...buckets.map(b => b.count), 1);
      const barH = Math.min(18, (cH / buckets.length) * 0.75);
      const gap = cH / buckets.length;

      ctx.fillStyle = '#0f172a';
      ctx.fillRect(0, 0, W, H);

      buckets.forEach((b, i) => {
        const y = pad.top + i * gap + (gap - barH) / 2;
        const barW = (b.count / maxCount) * cW;
        // Label
        ctx.fillStyle = '#94a3b8';
        ctx.font = '11px sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(b.label, pad.left - 8, y + barH / 2);
        // Bar
        ctx.fillStyle = '#6366f1';
        ctx.fillRect(pad.left, y, Math.max(barW, 2), barH);
        // Count
        if (b.count > 0) {
          ctx.fillStyle = '#e2e8f0';
          ctx.textAlign = 'left';
          ctx.fillText(String(b.count), pad.left + barW + 6, y + barH / 2);
        }
      });
    }
  }
})();





(function() {
  var _origFetch = window.fetch;
  var _lastPerfData = null;

  // Intercept performance API responses to grab new fields
  window.fetch = function() {
    var result = _origFetch.apply(this, arguments);
    var url = arguments[0];
    if (typeof url === 'string' && url.indexOf('/performance') !== -1) {
      result.then(function(resp) {
        return resp.clone().json();
      }).then(function(data) {
        if (data && data.monthlyBreakdown) {
          _lastPerfData = data;
          if (typeof currentPage !== "undefined" && currentPage === "performance") { setTimeout(function() { renderMonthly(data.monthlyBreakdown); renderDuration(data.durationAnalytics); }, 300); }
        }
      }).catch(function(){});
    }
    return result;
  };

  function renderMonthly(months) {
    if (!months || months.length === 0) return;
    var old = document.getElementById('monthly-breakdown');
    if (old) old.remove();
    var c = document.createElement('div');
    c.id = 'monthly-breakdown';
    c.style.cssText = 'margin-top:24px;padding:16px;background:#1e293b;border-radius:12px;';
    var anchor = document.getElementById('top-symbols') || document.querySelector('[class*=perf]') || document.querySelector('main');
    if (anchor && anchor.parentNode) anchor.parentNode.insertBefore(c, anchor.nextSibling);
    else document.body.appendChild(c);

    var rows = months.map(function(m) {
      var parts = m.month.split('-');
      var d = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1);
      var label = d.toLocaleString('default', { month: 'short', year: 'numeric' });
      var pnlColor = m.pnl >= 0 ? '#4ade80' : '#f87171';
      var wrColor = m.winRate >= 50 ? '#4ade80' : '#f87171';
      return '<tr style="border-bottom:1px solid #334155;">' +
        '<td style="padding:8px;color:#e2e8f0;">' + label + '</td>' +
        '<td style="text-align:right;padding:8px;color:#cbd5e1;">' + m.trades + '</td>' +
        '<td style="text-align:right;padding:8px;color:#4ade80;">' + m.wins + '</td>' +
        '<td style="text-align:right;padding:8px;color:#f87171;">' + m.losses + '</td>' +
        '<td style="text-align:right;padding:8px;color:' + wrColor + ';">' + m.winRate + '%</td>' +
        '<td style="text-align:right;padding:8px;color:' + pnlColor + ';">' + (m.pnl >= 0 ? '+' : '') + m.pnl + '%</td></tr>';
    }).join('');

    c.innerHTML = '<h3 style="font-size:16px;font-weight:600;color:#e2e8f0;margin-bottom:12px;">Monthly Breakdown</h3>' +
      '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:13px;">' +
      '<thead><tr style="border-bottom:1px solid #475569;color:#94a3b8;">' +
      '<th style="text-align:left;padding:8px;">Month</th>' +
      '<th style="text-align:right;padding:8px;">Trades</th>' +
      '<th style="text-align:right;padding:8px;">Wins</th>' +
      '<th style="text-align:right;padding:8px;">Losses</th>' +
      '<th style="text-align:right;padding:8px;">Win Rate</th>' +
      '<th style="text-align:right;padding:8px;">PnL %</th></tr></thead>' +
      '<tbody>' + rows + '</tbody></table></div>' +
      '<canvas id="monthly-pnl-chart" height="180" style="margin-top:16px;width:100%;"></canvas>';

    setTimeout(function() { drawMonthlyChart(months); }, 50);
  }

  function drawMonthlyChart(months) {
    var canvas = document.getElementById('monthly-pnl-chart');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.width = canvas.offsetWidth || 600;
    var H = canvas.height = 180;
    var pad = { top: 20, right: 16, bottom: 40, left: 50 };
    var cW = W - pad.left - pad.right;
    var cH = H - pad.top - pad.bottom;
    var vals = months.map(function(m) { return m.pnl; });
    var maxAbs = Math.max(Math.abs(Math.min.apply(null, vals)), Math.abs(Math.max.apply(null, vals)), 1);
    var gap = cW / months.length;
    var barW = Math.min(40, gap * 0.7);
    var zeroY = pad.top + cH / 2;

    ctx.fillStyle = '#0f172a';
    ctx.fillRect(0, 0, W, H);
    ctx.strokeStyle = '#475569';
    ctx.setLineDash([4, 4]);
    ctx.beginPath(); ctx.moveTo(pad.left, zeroY); ctx.lineTo(W - pad.right, zeroY); ctx.stroke();
    ctx.setLineDash([]);

    months.forEach(function(m, i) {
      var parts = m.month.split('-');
      var d = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1);
      var label = d.toLocaleString('default', { month: 'short' });
      var x = pad.left + i * gap + (gap - barW) / 2;
      var barH = (m.pnl / maxAbs) * (cH / 2);
      ctx.fillStyle = m.pnl >= 0 ? '#4ade80' : '#f87171';
      if (m.pnl >= 0) { ctx.fillRect(x, zeroY - barH, barW, barH); }
      else { ctx.fillRect(x, zeroY, barW, Math.abs(barH)); }
      // Value on bar
      ctx.fillStyle = '#e2e8f0';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      var vy = m.pnl >= 0 ? zeroY - barH - 6 : zeroY + Math.abs(barH) + 14;
      ctx.fillText((m.pnl >= 0 ? '+' : '') + m.pnl + '%', x + barW / 2, vy);
      // Month label
      ctx.fillStyle = '#94a3b8';
      ctx.font = '10px sans-serif';
      ctx.fillText(label, x + barW / 2, H - 8);
    });
  }

  function renderDuration(dur) {
    if (!dur) return;
    var old = document.getElementById('duration-analytics');
    if (old) old.remove();
    var c = document.createElement('div');
    c.id = 'duration-analytics';
    c.style.cssText = 'margin-top:16px;padding:16px;background:#1e293b;border-radius:12px;';
    var anchor = document.getElementById('monthly-breakdown');
    if (anchor && anchor.parentNode) anchor.parentNode.insertBefore(c, anchor.nextSibling);
    else document.body.appendChild(c);

    function fh(h) {
      if (!h || h === 0) return '\u2014';
      if (h < 1) return Math.round(h * 60) + 'm';
      if (h < 24) return h.toFixed(1) + 'h';
      return (h / 24).toFixed(1) + 'd';
    }

    function card(label, val, sub, color) {
      return '<div style="background:#0f172a;border-radius:8px;padding:12px;min-width:130px;">' +
        '<div style="color:#94a3b8;font-size:11px;margin-bottom:4px;">' + label + '</div>' +
        '<div style="color:' + (color || '#e2e8f0') + ';font-size:20px;font-weight:600;">' + val + '</div>' +
        (sub ? '<div style="color:#64748b;font-size:11px;margin-top:2px;">' + sub + '</div>' : '') + '</div>';
    }

    c.innerHTML = '<h3 style="font-size:16px;font-weight:600;color:#e2e8f0;margin-bottom:12px;">Duration Analytics</h3>' +
      '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:16px;">' +
      card('Avg Duration', fh(dur.avgDuration), 'Median: ' + fh(dur.medianDuration)) +
      card('Avg Time to TP', fh(dur.avgTimeToTP), 'Median: ' + fh(dur.medianTimeToTP), '#4ade80') +
      card('Avg Time to SL', fh(dur.avgTimeToSL), 'Median: ' + fh(dur.medianTimeToSL), '#f87171') +
      card('Trades Analyzed', String(dur.totalWithDuration), '') +
      '</div><canvas id="duration-dist-chart" height="160" style="width:100%;"></canvas>';

    setTimeout(function() { drawDurationChart(dur.distribution); }, 50);
  }

  function drawDurationChart(buckets) {
    var canvas = document.getElementById('duration-dist-chart');
    if (!canvas || !buckets) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.width = canvas.offsetWidth || 600;
    var H = canvas.height = 160;
    var pad = { top: 8, right: 40, bottom: 8, left: 60 };
    var cW = W - pad.left - pad.right;
    var cH = H - pad.top - pad.bottom;
    var maxCount = Math.max.apply(null, buckets.map(function(b) { return b.count; }).concat([1]));
    var gap = cH / buckets.length;
    var barH = Math.min(18, gap * 0.75);

    ctx.fillStyle = '#0f172a';
    ctx.fillRect(0, 0, W, H);

    buckets.forEach(function(b, i) {
      var y = pad.top + i * gap + (gap - barH) / 2;
      var bw = Math.max((b.count / maxCount) * cW, 2);
      ctx.fillStyle = '#94a3b8';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      ctx.fillText(b.label, pad.left - 8, y + barH / 2);
      ctx.fillStyle = '#6366f1';
      ctx.fillRect(pad.left, y, bw, barH);
      if (b.count > 0) {
        ctx.fillStyle = '#e2e8f0';
        ctx.textAlign = 'left';
        ctx.fillText(String(b.count), pad.left + bw + 6, y + barH / 2);
      }
    });
  }
})();



// ═══════════════════════════════════════════════════════════════
// Multi-TP Progress Indicators — Dashboard Patch
// ═══════════════════════════════════════════════════════════════
(function() {
  // Add TP progress column to signal table
  var _origFetchSignals = window.fetchSignals;
  if (!_origFetchSignals) return;

  window.fetchSignals = async function() {
    await _origFetchSignals.apply(this, arguments);
    // Post-process: inject TP progress into each row
    setTimeout(addTpProgressToTable, 200);
  };

  function tpProgress(t) {
    if (!t) return '';
    var levels = [];
    if (t.tp1Price) levels.push({ n: 1, price: t.tp1Price, hit: t.tp1HitAt });
    if (t.tp2Price) levels.push({ n: 2, price: t.tp2Price, hit: t.tp2HitAt });
    if (t.tp3Price) levels.push({ n: 3, price: t.tp3Price, hit: t.tp3HitAt });
    if (levels.length === 0) return '';

    var dots = levels.map(function(l) {
      var color = l.hit ? '#4ade80' : '#475569';
      var border = l.hit ? 'none' : '1px solid #64748b';
      var title = 'TP' + l.n + ': ' + l.price.toFixed(2) + (l.hit ? ' ✓ ' + new Date(l.hit).toLocaleString() : ' pending');
      return '<span title="' + title + '" style="display:inline-block;width:10px;height:10px;border-radius:50%;background:' + color + ';border:' + border + ';margin:0 2px;"></span>';
    }).join('');

    return '<span style="white-space:nowrap;">' + dots + ' <span style="font-size:10px;color:#94a3b8;">' + (t.tpHitCount || 0) + '/' + levels.length + '</span></span>';
  }

  function addTpProgressToTable() {
    // Find the signals table
    var table = document.querySelector('#signals-table table');
    if (!table) return;
    var thead = table.querySelector('thead tr');
    var tbody = table.querySelector('tbody');
    if (!thead || !tbody) return;

    // Add TP column header if not already there
    if (thead.innerHTML.indexOf('Targets') === -1) {
      var th = document.createElement('th');
      th.textContent = 'Targets';
      thead.appendChild(th);
    }

    // We need the trade data — refetch from the cached response
    // Instead, attach data via a global
    if (window._lastSignalData) {
      var signals = window._lastSignalData;
      var rows = tbody.querySelectorAll('tr');
      for (var i = 0; i < rows.length && i < signals.length; i++) {
        var s = signals[i];
        var t = s.trade || {};
        var existing = rows[i].querySelector('.tp-progress-cell');
        if (!existing) {
          var td = document.createElement('td');
          td.className = 'tp-progress-cell';
          td.innerHTML = tpProgress(t);
          rows[i].appendChild(td);
        }
      }
    }
  }

  // Hook fetch to capture signal data
  var _origFetch2 = window.fetch;
  window.fetch = function() {
    var url = arguments[0];
    var result = _origFetch2.apply(this, arguments);
    if (typeof url === 'string' && url.indexOf('/signals') !== -1 && url.indexOf('/signals/') === -1) {
      result.then(function(r) { return r.clone().json(); }).then(function(d) {
        if (d && d.signals) window._lastSignalData = d.signals;
      }).catch(function(){});
    }
    return result;
  };

  // Also enhance click-to-detail: add TP progress to any modal/detail view
  document.addEventListener('click', function(e) {
    var row = e.target.closest && e.target.closest('tr');
    if (!row || !window._lastSignalData) return;
    var idx = Array.from(row.parentNode.children).indexOf(row);
    if (idx < 0 || idx >= window._lastSignalData.length) return;
    var s = window._lastSignalData[idx];
    if (!s || !s.trade) return;
    // If a detail panel opens, enhance it after a short delay
    setTimeout(function() { enhanceDetailPanel(s.trade); }, 500);
  });

  function enhanceDetailPanel(t) {
    var levels = [];
    if (t.tp1Price) levels.push({ n: 1, price: t.tp1Price, hit: t.tp1HitAt });
    if (t.tp2Price) levels.push({ n: 2, price: t.tp2Price, hit: t.tp2HitAt });
    if (t.tp3Price) levels.push({ n: 3, price: t.tp3Price, hit: t.tp3HitAt });
    if (levels.length === 0) return;

    var existing = document.getElementById('multitp-detail');
    if (existing) existing.remove();

    var panel = document.createElement('div');
    panel.id = 'multitp-detail';
    panel.style.cssText = 'margin:12px 0;padding:12px;background:#0f172a;border-radius:8px;';

    var barsHtml = levels.map(function(l) {
      var pct = l.hit ? 100 : 0;
      if (!l.hit && t.entryPrice && t.status === 'ACTIVE') {
        // Could compute progress based on current price, but we don't have it client-side
        pct = 0;
      }
      var barColor = l.hit ? '#4ade80' : '#334155';
      var textColor = l.hit ? '#4ade80' : '#94a3b8';
      var icon = l.hit ? '✅' : '⬜';
      var hitTime = l.hit ? '<span style="color:#64748b;font-size:10px;margin-left:8px;">' + new Date(l.hit).toLocaleString() + '</span>' : '';
      return '<div style="display:flex;align-items:center;gap:8px;margin:6px 0;">' +
        '<span style="color:#94a3b8;font-size:12px;width:30px;">TP' + l.n + '</span>' +
        '<div style="flex:1;height:6px;background:#1e293b;border-radius:3px;overflow:hidden;">' +
          '<div style="width:' + pct + '%;height:100%;background:' + barColor + ';border-radius:3px;transition:width 0.3s;"></div>' +
        '</div>' +
        '<span style="color:' + textColor + ';font-size:12px;font-family:monospace;">' + l.price.toFixed(2) + '</span>' +
        '<span style="font-size:12px;">' + icon + '</span>' +
        hitTime +
      '</div>';
    }).join('');

    var summary = (t.tpHitCount || 0) + ' of ' + levels.length + ' targets hit';
    panel.innerHTML = '<div style="font-size:13px;font-weight:600;color:#e2e8f0;margin-bottom:8px;">🎯 Target Progress</div>' +
      barsHtml +
      '<div style="color:#64748b;font-size:11px;margin-top:8px;">' + summary + '</div>';

    // Try to insert into a detail view/modal
    var detailEl = document.querySelector('.trade-detail, .signal-detail, .modal-body, [id*=detail]');
    if (detailEl) {
      detailEl.appendChild(panel);
    }
  }
})();

</script>
