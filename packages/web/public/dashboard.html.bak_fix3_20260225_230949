  document.getElementById('top-symbols').innerHTML = `
    <table><thead><tr><th style="width:48px">#</th><th>Symbol</th><th>Trades</th><th>Win Rate</th><th>PnL</th></tr></thead>
    <tbody>${rows}</tbody></table>`;
}

