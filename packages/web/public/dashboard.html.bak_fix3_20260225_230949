// ── Chart Helpers ─────────────────────────────────────────────

function getCtx(id) {
  const canvas = document.getElementById(id);
  if (!canvas) return null;
  const rect = canvas.parentElement.getBoundingClientRect();
  canvas.width = rect.width * 2;
  canvas.height = rect.height * 2;
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(2, 2);
  return { ctx, w: rect.width, h: rect.height };
}

function drawEquityChart(curve) {
  const c = getCtx('equity-chart');
  if (!c || curve.length < 2) return;
  const { ctx, w, h } = c;
  const pad = { top: 20, right: 20, bottom: 30, left: 60 };
  const cw = w - pad.left - pad.right;
  const ch = h - pad.top - pad.bottom;

  const vals = curve.map(p => p.cumPnl);
  const minY = Math.min(0, ...vals);
  const maxY = Math.max(0, ...vals);
  const rangeY = maxY - minY || 1;

  function x(i) { return pad.left + (i / (curve.length - 1)) * cw; }
  function y(v) { return pad.top + ch - ((v - minY) / rangeY) * ch; }

  // Grid
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 0.5;
  const steps = 5;
  for (let i = 0; i <= steps; i++) {
    const yy = pad.top + (i / steps) * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, yy); ctx.lineTo(w - pad.right, yy); ctx.stroke();
    const val = maxY - (i / steps) * rangeY;
    ctx.fillStyle = '#64748b';
    ctx.font = '10px IBM Plex Mono';
    ctx.textAlign = 'right';
    ctx.fillText(val.toFixed(1) + '%', pad.left - 8, yy + 3);
  }

  // Zero line
  if (minY < 0) {
    ctx.strokeStyle = 'rgba(255,255,255,0.1)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath(); ctx.moveTo(pad.left, y(0)); ctx.lineTo(w - pad.right, y(0)); ctx.stroke();
    ctx.setLineDash([]);
  }

  // Area fill
  ctx.beginPath();
  ctx.moveTo(x(0), y(0));
  for (let i = 0; i < curve.length; i++) ctx.lineTo(x(i), y(curve[i].cumPnl));
  ctx.lineTo(x(curve.length - 1), y(0));
  ctx.closePath();
  const grad = ctx.createLinearGradient(0, pad.top, 0, h);
  grad.addColorStop(0, 'rgba(167,139,250,0.15)');
  grad.addColorStop(1, 'rgba(167,139,250,0.01)');
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  for (let i = 0; i < curve.length; i++) {
    if (i === 0) ctx.moveTo(x(i), y(curve[i].cumPnl));
    else ctx.lineTo(x(i), y(curve[i].cumPnl));
  }
  ctx.strokeStyle = '#a78bfa';
  ctx.lineWidth = 1.5;
  ctx.lineJoin = 'round';
  ctx.stroke();

  // X labels
  ctx.fillStyle = '#64748b';
  ctx.font = '10px IBM Plex Mono';
  ctx.textAlign = 'center';
  const labelCount = Math.min(6, curve.length);
  for (let i = 0; i < labelCount; i++) {
    const idx = Math.floor((i / (labelCount - 1)) * (curve.length - 1));
    const d = new Date(curve[idx].date);
    ctx.fillText(d.toLocaleDateString('en', { month: 'short', day: 'numeric' }), x(idx), h - 6);
  }

  // Final value
  const last = vals[vals.length - 1];
  ctx.fillStyle = last >= 0 ? '#34d399' : '#f87171';
  ctx.font = 'bold 12px IBM Plex Mono';
  ctx.textAlign = 'left';
  ctx.fillText((last >= 0 ? '+' : '') + last.toFixed(1) + '%', x(curve.length - 1) - 40, y(last) - 8);
}

function drawDrawdownChart(curve) {
  const c = getCtx('drawdown-chart');
  if (!c || curve.length < 2) return;
  const { ctx, w, h } = c;
  const pad = { top: 10, right: 20, bottom: 30, left: 60 };
  const cw = w - pad.left - pad.right;
  const ch = h - pad.top - pad.bottom;

  const vals = curve.map(p => p.drawdown);
  const minY = Math.min(...vals, 0);
  const rangeY = Math.abs(minY) || 1;

  function x(i) { return pad.left + (i / (curve.length - 1)) * cw; }
  function y(v) { return pad.top + (-v / rangeY) * ch; }

  // Grid
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 0.5;
  for (let i = 0; i <= 3; i++) {
    const yy = pad.top + (i / 3) * ch;
    ctx.beginPath(); ctx.moveTo(pad.left, yy); ctx.lineTo(w - pad.right, yy); ctx.stroke();
    const val = -(i / 3) * rangeY;
    ctx.fillStyle = '#64748b'; ctx.font = '10px IBM Plex Mono'; ctx.textAlign = 'right';
    ctx.fillText(val.toFixed(1) + '%', pad.left - 8, yy + 3);
  }

  // Area
  ctx.beginPath();
  ctx.moveTo(x(0), y(0));
  for (let i = 0; i < curve.length; i++) ctx.lineTo(x(i), y(vals[i]));
  ctx.lineTo(x(curve.length - 1), y(0));
  ctx.closePath();
  const grad = ctx.createLinearGradient(0, pad.top, 0, h);
  grad.addColorStop(0, 'rgba(248,113,113,0.02)');
  grad.addColorStop(1, 'rgba(248,113,113,0.20)');
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  for (let i = 0; i < curve.length; i++) {
    if (i === 0) ctx.moveTo(x(i), y(vals[i]));
    else ctx.lineTo(x(i), y(vals[i]));
  }
  ctx.strokeStyle = '#f87171';
  ctx.lineWidth = 1.5;
  ctx.lineJoin = 'round';
  ctx.stroke();

  // X labels
  ctx.fillStyle = '#64748b'; ctx.font = '10px IBM Plex Mono'; ctx.textAlign = 'center';
  const labelCount = Math.min(6, curve.length);
  for (let i = 0; i < labelCount; i++) {
    const idx = Math.floor((i / (labelCount - 1)) * (curve.length - 1));
    const d = new Date(curve[idx].date);
    ctx.fillText(d.toLocaleDateString('en', { month: 'short', day: 'numeric' }), x(idx), h - 6);
  }
}

function drawDailyChart(daily) {
  const c = getCtx('daily-chart');
  if (!c || daily.length === 0) return;
  const { ctx, w, h } = c;
  const pad = { top: 10, right: 10, bottom: 30, left: 50 };
  const cw = w - pad.left - pad.right;
  const ch = h - pad.top - pad.bottom;

  const vals = daily.map(d => d.pnl);
  const maxV = Math.max(...vals.map(Math.abs), 1);

  const barW = Math.max(2, Math.min(12, (cw / daily.length) - 2));
  const zeroY = pad.top + ch / 2;

  // Zero line
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 0.5;
  ctx.beginPath(); ctx.moveTo(pad.left, zeroY); ctx.lineTo(w - pad.right, zeroY); ctx.stroke();

  // Y labels
  ctx.fillStyle = '#64748b'; ctx.font = '10px IBM Plex Mono'; ctx.textAlign = 'right';
  ctx.fillText('+' + maxV.toFixed(0) + '%', pad.left - 6, pad.top + 10);
  ctx.fillText('-' + maxV.toFixed(0) + '%', pad.left - 6, h - pad.bottom - 4);
  ctx.fillText('0%', pad.left - 6, zeroY + 3);

  // Bars
  for (let i = 0; i < daily.length; i++) {
    const bx = pad.left + (i / daily.length) * cw + (cw / daily.length - barW) / 2;
    const barH = (Math.abs(daily[i].pnl) / maxV) * (ch / 2);
    const isPos = daily[i].pnl >= 0;

    ctx.fillStyle = isPos ? 'rgba(52,211,153,0.7)' : 'rgba(248,113,113,0.7)';
    if (isPos) {
      ctx.fillRect(bx, zeroY - barH, barW, barH);
    } else {
      ctx.fillRect(bx, zeroY, barW, barH);
    }
  }

  // X labels
  ctx.fillStyle = '#64748b'; ctx.font = '9px IBM Plex Mono'; ctx.textAlign = 'center';
  const skip = Math.max(1, Math.floor(daily.length / 6));
  for (let i = 0; i < daily.length; i += skip) {
    const bx = pad.left + (i / daily.length) * cw + (cw / daily.length) / 2;
    const d = new Date(daily[i].date);
    ctx.fillText(d.toLocaleDateString('en', { month: 'short', day: 'numeric' }), bx, h - 6);
  }
}

function drawRDistChart(dist) {
  const c = getCtx('rdist-chart');
  if (!c) return;
  const { ctx, w, h } = c;
  const pad = { top: 10, right: 10, bottom: 40, left: 40 };
  const cw = w - pad.left - pad.right;
  const ch = h - pad.top - pad.bottom;

  const labels = Object.keys(dist);
  const vals = Object.values(dist);
  const maxV = Math.max(...vals, 1);
  const barW = Math.max(8, (cw / labels.length) - 8);

  // Bars
  const colors = ['#f87171', '#f87171', '#fb923c', '#fbbf24', '#34d399', '#34d399', '#34d399'];
  for (let i = 0; i < labels.length; i++) {
    const bx = pad.left + (i / labels.length) * cw + (cw / labels.length - barW) / 2;
    const barH = (vals[i] / maxV) * ch;

    ctx.fillStyle = colors[i] || '#64748b';
    ctx.globalAlpha = 0.7;
    ctx.beginPath();
    const radius = 3;
    ctx.moveTo(bx + radius, pad.top + ch - barH);
    ctx.lineTo(bx + barW - radius, pad.top + ch - barH);
    ctx.quadraticCurveTo(bx + barW, pad.top + ch - barH, bx + barW, pad.top + ch - barH + radius);
    ctx.lineTo(bx + barW, pad.top + ch);
    ctx.lineTo(bx, pad.top + ch);
    ctx.lineTo(bx, pad.top + ch - barH + radius);
    ctx.quadraticCurveTo(bx, pad.top + ch - barH, bx + radius, pad.top + ch - barH);
    ctx.fill();
    ctx.globalAlpha = 1;

    // Count label
    if (vals[i] > 0) {
      ctx.fillStyle = '#e2e8f0';
      ctx.font = 'bold 11px IBM Plex Mono';
      ctx.textAlign = 'center';
      ctx.fillText(vals[i].toString(), bx + barW / 2, pad.top + ch - barH - 5);
    }
  }

  // X labels
  ctx.fillStyle = '#64748b'; ctx.font = '9px IBM Plex Mono'; ctx.textAlign = 'center';
  for (let i = 0; i < labels.length; i++) {
    const bx = pad.left + (i / labels.length) * cw + (cw / labels.length) / 2;
    ctx.fillText(labels[i], bx, h - 8);
  }
}

function renderTopSymbols(symbols) {
