function renderDurationAnalyticsStandalone(dur, container) {
  function fmtHrs(h) {
    if (!h || h === 0) return '—';
    if (h < 1) return Math.round(h * 60) + 'm';
    if (h < 24) return h.toFixed(1) + 'h';
    return (h / 24).toFixed(1) + 'd';
  }

  container.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px;">
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;">
        <div style="color:var(--text2);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">Avg Duration</div>
        <div style="color:var(--text);font-size:24px;font-weight:700;">${fmtHrs(dur.avgDuration)}</div>
        <div style="color:var(--text3);font-size:11px;margin-top:4px;">Median: ${fmtHrs(dur.medianDuration)}</div>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;">
        <div style="color:var(--text2);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">Avg Time to TP</div>
        <div style="color:var(--green);font-size:24px;font-weight:700;">${fmtHrs(dur.avgTimeToTP)}</div>
        <div style="color:var(--text3);font-size:11px;margin-top:4px;">Median: ${fmtHrs(dur.medianTimeToTP)}</div>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;">
        <div style="color:var(--text2);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">Avg Time to SL</div>
        <div style="color:var(--red);font-size:24px;font-weight:700;">${fmtHrs(dur.avgTimeToSL)}</div>
        <div style="color:var(--text3);font-size:11px;margin-top:4px;">Median: ${fmtHrs(dur.medianTimeToSL)}</div>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px;">
        <div style="color:var(--text2);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">Trades Analyzed</div>
        <div style="color:var(--text);font-size:24px;font-weight:700;">${dur.totalWithDuration || '—'}</div>
      </div>
    </div>
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:20px;">
      <div style="font-size:13px;font-weight:600;color:var(--text2);margin-bottom:16px;">Duration Distribution</div>
      <canvas id="dur-dist-standalone" style="width:100%;height:200px;display:block;"></canvas>
    </div>
  `;

  const canvas = document.getElementById('dur-dist-standalone');
  if (canvas && dur.distribution) {
    requestAnimationFrame(() => {
      const ctx = canvas.getContext('2d');
      const W = canvas.width = canvas.offsetWidth;
      const H = canvas.height = 200;
      const pad = { top: 8, right: 50, bottom: 8, left: 70 };
      const cW = W - pad.left - pad.right;
      const cH = H - pad.top - pad.bottom;
      const buckets = dur.distribution;
      const maxCount = Math.max(...buckets.map(b => b.count), 1);
      const barH = Math.min(22, (cH / buckets.length) * 0.72);
      const gap = cH / buckets.length;

      ctx.fillStyle = 'var(--card, #0d1220)';
      ctx.fillRect(0, 0, W, H);

      buckets.forEach((b, i) => {
        const y = pad.top + i * gap + (gap - barH) / 2;
        const barW = (b.count / maxCount) * cW;
        ctx.fillStyle = '#64748b';
        ctx.font = '11px "IBM Plex Mono", monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(b.label, pad.left - 10, y + barH / 2);
        ctx.fillStyle = '#6366f1';
        ctx.beginPath();
        ctx.roundRect(pad.left, y, Math.max(barW, 3), barH, 3);
        ctx.fill();
        if (b.count > 0) {
          ctx.fillStyle = '#e2e8f0';
          ctx.textAlign = 'left';
          ctx.fillText(String(b.count), pad.left + barW + 8, y + barH / 2);
        }
      });
    });
  }
}

