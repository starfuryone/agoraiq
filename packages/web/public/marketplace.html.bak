<!doctype html>
<html lang="en">
<head>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>AgoraIQ — Signal Provider Marketplace</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --font:'IBM Plex Sans',sans-serif;--mono:'IBM Plex Mono',monospace;
  --bg:#060a14;--bg2:#0b0f1a;--bg3:#111827;--card:#0d1220;--card-hover:#111828;
  --border:#1a2236;--border2:#243049;
  --accent:#a78bfa;--accent-dim:rgba(167,139,250,.10);--accent-border:rgba(167,139,250,.20);
  --green:#34d399;--green-dim:rgba(52,211,153,.10);
  --red:#f87171;--red-dim:rgba(248,113,113,.10);
  --blue:#38bdf8;--blue-dim:rgba(56,189,248,.10);
  --amber:#fbbf24;--amber-dim:rgba(251,191,36,.10);
  --text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;--dim:#475569;
  --r:8px;--r-lg:12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);font-size:14px;line-height:1.5;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;min-height:100vh}
a{color:inherit;text-decoration:none}
button{font-family:var(--font);cursor:pointer;border:none;background:none;color:inherit}

/* ── Header ── */
.mp-header{background:var(--bg2);border-bottom:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
.mp-header-left{display:flex;align-items:center;gap:16px}
.mp-logo{font-size:15px;font-weight:700;letter-spacing:-.02em}
.mp-logo .a{color:var(--accent)}.mp-logo .b{color:var(--text)}
.mp-title{font-size:18px;font-weight:700;color:var(--text)}
.mp-subtitle{font-size:12px;color:var(--text3)}
.mp-back{padding:8px 16px;border-radius:var(--r);border:1px solid var(--border);color:var(--text2);font-size:13px;font-weight:500;transition:all .15s}
.mp-back:hover{border-color:var(--accent-border);color:var(--text)}

/* ── SSE Ticker ── */
.ticker-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:8px 32px;overflow:hidden;height:36px;display:flex;align-items:center;gap:8px}
.ticker-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);flex-shrink:0}
.ticker-feed{display:flex;gap:16px;overflow:hidden;flex:1}
.ticker-item{display:flex;align-items:center;gap:6px;font-size:12px;font-family:var(--mono);white-space:nowrap;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}

/* ── Filters ── */
.filters{padding:20px 32px;display:flex;gap:12px;flex-wrap:wrap;align-items:center;border-bottom:1px solid var(--border)}
.filter-group{display:flex;align-items:center;gap:6px}
.filter-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
select{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:6px 10px;border-radius:var(--r);font-size:12px;font-family:var(--font)}
select:focus{outline:none;border-color:var(--accent-border)}
.filter-spacer{flex:1}
.sort-btn{padding:6px 12px;border-radius:var(--r);font-size:12px;font-weight:500;color:var(--text3);border:1px solid transparent;transition:all .15s}
.sort-btn:hover,.sort-btn.active{color:var(--text);border-color:var(--border);background:var(--bg3)}

/* ── Provider Grid ── */
.grid{padding:24px 32px;display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:16px}
.provider-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:20px;transition:all .2s;cursor:pointer;position:relative}
.provider-card:hover{border-color:var(--accent-border);background:var(--card-hover);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.3)}
.provider-card.verified::after{content:"";position:absolute;top:16px;right:16px;width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green)}
.pc-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.pc-name{font-size:15px;font-weight:700}
.pc-badge{font-size:10px;font-weight:600;padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:.05em}
.pc-badge.clean{background:var(--green-dim);color:var(--green)}
.pc-badge.caution{background:var(--amber-dim);color:var(--amber)}
.pc-badge.suspect{background:var(--red-dim);color:var(--red)}
.pc-tags{display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap}
.pc-tag{font-size:10px;padding:2px 8px;border-radius:4px;background:var(--bg3);color:var(--text3);border:1px solid var(--border)}
.pc-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.pc-stat{text-align:center}
.pc-stat-val{font-size:16px;font-weight:700;font-family:var(--mono)}
.pc-stat-val.pos{color:var(--green)}.pc-stat-val.neg{color:var(--red)}.pc-stat-val.neutral{color:var(--text2)}
.pc-stat-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
.pc-footer{display:flex;align-items:center;justify-content:space-between;margin-top:14px;padding-top:12px;border-top:1px solid var(--border)}
.pc-meta{font-size:11px;color:var(--text3)}
.pc-completeness{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text3)}
.pc-bar{width:60px;height:4px;border-radius:2px;background:var(--bg3);overflow:hidden}
.pc-bar-fill{height:100%;border-radius:2px;background:var(--accent);transition:width .5s}

/* ── Detail Modal ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);width:90%;max-width:800px;max-height:85vh;overflow-y:auto;padding:32px}
.modal-close{position:absolute;top:16px;right:16px;font-size:18px;color:var(--text3);cursor:pointer}
.modal h2{font-size:20px;font-weight:700;margin-bottom:4px}
.modal .subtitle{color:var(--text3);font-size:13px;margin-bottom:24px}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center}
.stat-card .val{font-size:18px;font-weight:700;font-family:var(--mono)}
.stat-card .lbl{font-size:10px;color:var(--text3);text-transform:uppercase;margin-top:4px}
.period-tabs{display:flex;gap:4px;margin-bottom:20px}
.period-tab{padding:6px 14px;border-radius:var(--r);font-size:12px;font-weight:500;color:var(--text3);border:1px solid transparent;transition:all .15s}
.period-tab:hover,.period-tab.active{color:var(--text);background:var(--bg3);border-color:var(--border)}
.timeline-item{display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px}
.tl-type{font-family:var(--mono);font-weight:600;width:60px}
.tl-pair{color:var(--text);font-weight:500}
.tl-r{font-family:var(--mono);font-weight:600}
.tl-hash{font-family:var(--mono);font-size:11px;color:var(--text3)}
.tl-time{margin-left:auto;color:var(--text3);font-size:11px}

/* ── Type Tabs ── */
.type-tab{padding:12px 20px;font-size:13px;font-weight:600;color:var(--text3);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s}
.type-tab:hover{color:var(--text)}
.type-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
/* ── Empty/Loading ── */
.loading{display:flex;align-items:center;justify-content:center;padding:80px;color:var(--text3)}
.empty{text-align:center;padding:80px 32px;color:var(--text3)}

/* ── Responsive ── */
@media(max-width:768px){
  .grid{grid-template-columns:1fr;padding:16px}
  .filters{padding:12px 16px}
  .mp-header{padding:12px 16px}
  .stat-grid{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<!-- ═══ Header ═══ -->
<div class="mp-header">
  <div class="mp-header-left">
    <div class="mp-logo" style="display:flex;align-items:center;gap:10px"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="a">Agora</span><span class="b">IQ</span></div>
    <div>
      <div class="mp-title">Signal Provider Marketplace</div>
      <div class="mp-subtitle"><span id="tier-counts">Loading...</span> · SHA-256 immutable proof · Cherry-pick detection</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;align-items:center">
    <button onclick="openSubmitForm()" style="padding:8px 16px;border-radius:var(--r);background:var(--accent);color:#fff;font-size:13px;font-weight:600;border:none;cursor:pointer">+ Suggest Provider</button>
    <a href="/dashboard" class="mp-back">← Console</a>
  </div>
</div>

<!-- ═══ SSE Ticker ═══ -->
<div class="ticker-bar">
  <span class="ticker-label">Live Feed</span>
  <div class="ticker-feed" id="ticker-feed">
    <span style="color:var(--text3);font-size:12px">Connecting...</span>
  </div>
</div>

<!-- ═══ Filters ═══ -->
<div style="display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 32px;background:var(--bg2)">
  <button class="type-tab active" data-type="all" onclick="setType(this)">All Sources</button>
  <button class="type-tab" data-type="SIGNAL" onclick="setType(this)">📡 Signals</button>
  <button class="type-tab" data-type="TOOL" onclick="setType(this)">🤖 Bots</button>
  <button class="type-tab" data-type="ALERT" onclick="setType(this)">🐋 Alerts</button>
</div>
<div class="filters">
  <div class="filter-group">
    <span class="filter-label">Market</span>
    <select id="f-market" onchange="loadProviders()">
      <option value="All">All</option><option>Spot</option><option>Futures</option><option>Mixed</option>
    </select>
  </div>
  <div class="filter-group">
    <span class="filter-label">Style</span>
    <select id="f-style" onchange="loadProviders()">
      <option value="All">All</option><option>Scalp</option><option>Swing</option><option>Day Trade</option><option>Position</option>
    </select>
  </div>
  <div class="filter-group">
    <span class="filter-label">Min Trades</span>
    <select id="f-min" onchange="loadProviders()">
      <option value="0">Any</option><option value="5">5+</option><option value="20">20+</option><option value="50">50+</option><option value="100">100+</option>
    </select>
  </div>
  <div class="filter-group">
    <span class="filter-label">Tier</span>
    <select id="f-tier" onchange="loadProviders()">
      <option value="all">All</option><option value="VERIFIED">✅ Verified</option><option value="BETA">🧪 Beta</option>
    </select>
  </div>
  <div class="filter-spacer"></div>
  <div class="filter-group">
    <span class="filter-label">Sort by</span>
    <select id="f-sort" onchange="loadProviders()">
      <option value="volAdj">Vol-Adj Expectancy</option>
      <option value="expectancy">Raw Expectancy</option>
      <option value="winrate">Win Rate</option>
      <option value="trades">Trade Count</option>
      <option value="completeness">Data Quality</option>
    </select>
  </div>
</div>

<!-- ═══ Provider Grid ═══ -->
<div class="grid" id="provider-grid">
  <div class="loading">Loading providers...</div>
</div>

<!-- ═══ Detail Modal ═══ -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal" id="modal-content"></div>
</div>

<script>
const TOKEN = localStorage.getItem('agoraiq_token');
if (!TOKEN) window.location.href = '/login';
function headers() { return { Authorization: 'Bearer ' + TOKEN }; }

// ── Auth check: Pro/Elite only ──
(async function checkTier() {
  try {
    const r = await fetch('/api/v1/auth/me', { headers: headers() });
    if (!r.ok) { window.location.href = '/login'; return; }
    const d = await r.json();
    const tier = d.subscription?.planTier || d.subscription?.tier?.toUpperCase() || 'FREE';
    if (tier === 'FREE') {
      document.getElementById('provider-grid').innerHTML = `
        <div class="empty">
          <div style="font-size:48px;margin-bottom:16px">◈</div>
          <div style="font-size:16px;font-weight:600;margin-bottom:8px">Marketplace requires Pro or Elite</div>
          <div style="margin-bottom:20px">Upgrade your plan to browse verified signal providers</div>
          <a href="/dashboard#subscription" style="padding:10px 24px;border-radius:8px;background:var(--accent);color:#fff;font-weight:600;font-size:13px">Upgrade Now →</a>
        </div>`;
      return;
    }
    loadProviders();
  } catch { window.location.href = '/login'; }
})();

// ── Load Providers ──
async function loadProviders() {
  const grid = document.getElementById('provider-grid');
  grid.innerHTML = '<div class="loading">Loading...</div>';
  const params = new URLSearchParams({
    market: document.getElementById('f-market').value,
    style: document.getElementById('f-style').value,
    minTrades: document.getElementById('f-min').value,
    sort: document.getElementById('f-sort').value,
    type: document.querySelector('.type-tab.active')?.dataset.type || 'all',
    tier: document.getElementById('f-tier').value,
  });
  try {
    const r = await fetch('/api/v1/marketplace/providers?' + params);
    const d = await r.json();
    if (!d.providers || d.providers.length === 0) {
      grid.innerHTML = '<div class="empty">No providers match your filters</div>';
      return;
    }
    grid.innerHTML = d.providers.map(p => renderCard(p)).join('');
  } catch(e) {
    grid.innerHTML = '<div class="empty">Failed to load providers</div>';
  }
}

function renderCard(p) {
  const s = p.stats30d || {};
  const vae = s.volAdjExpectancy != null ? (s.volAdjExpectancy >= 0 ? '+' : '') + s.volAdjExpectancy.toFixed(2) : '—';
  const wr = s.winRate != null ? (s.winRate * 100).toFixed(1) + '%' : '—';
  const trades = s.trades || 0;
  const cherry = s.cherryLabel || 'Unknown';
  const cherryClass = cherry === 'Clean' ? 'clean' : cherry === 'Caution' ? 'caution' : 'suspect';
  const vaeClass = s.volAdjExpectancy > 0 ? 'pos' : s.volAdjExpectancy < 0 ? 'neg' : 'neutral';
  const wrVal = s.winRate != null ? s.winRate * 100 : 0;
  const wrClass = wrVal >= 50 ? 'pos' : wrVal > 0 ? 'neg' : 'neutral';
  const compl = s.dataCompleteness != null ? (s.dataCompleteness * 100).toFixed(0) : 0;
  const tags = p.tags || {};
  const typeIcon = p.providerType === 'TOOL' ? '🤖' : p.providerType === 'ALERT' ? '🐋' : '📡';
  const tagHtml = [p.providerType !== 'SIGNAL' ? p.category : null, p.chain, tags.market, tags.style, tags.leverageBand, tags.exchange].filter(Boolean).map(t => `<span class="pc-tag">${t}</span>`).join('');
  const verified = p.isVerified ? ' verified' : '';
  return `<div class="provider-card${verified}" onclick="openDetail('${p.slug}')">
    <div class="pc-header">
      <span class="pc-name">${esc(p.name)}</span>
      <span style="display:flex;gap:6px;align-items:center">
        <span class="pc-badge" style="background:${p.tier==='VERIFIED'?'var(--green-dim)':'var(--blue-dim)'};color:${p.tier==='VERIFIED'?'var(--green)':'var(--blue)'}">${p.tier==='VERIFIED'?'✅ Ranked':'🧪 Beta'}</span>
        <span class="pc-badge ${cherryClass}">${cherry}</span>
      </span>
    </div>
    <div class="pc-tags">${tagHtml || '<span class="pc-tag">Crypto</span>'} <span class="pc-tag" style="border-color:var(--accent-border);color:var(--accent)">${typeIcon} ${p.providerType || 'SIGNAL'}</span></div>
    <div class="pc-stats">
      <div class="pc-stat"><div class="pc-stat-val ${vaeClass}">${vae}</div><div class="pc-stat-label">VaE (30d)</div></div>
      <div class="pc-stat"><div class="pc-stat-val ${wrClass}">${wr}</div><div class="pc-stat-label">Win Rate</div></div>
      <div class="pc-stat"><div class="pc-stat-val neutral">${trades}</div><div class="pc-stat-label">Trades</div></div>
    </div>
    <div class="pc-footer">
      <span class="pc-meta">${p.subscriberCount || 0} subs · ${p.language || 'EN'}</span>
      <span class="pc-completeness"><span class="pc-bar"><span class="pc-bar-fill" style="width:${compl}%"></span></span>${compl}% complete</span>
    </div>
  </div>`;
}

// ── Provider Detail ──
async function openDetail(slug) {
  const modal = document.getElementById('modal');
  const content = document.getElementById('modal-content');
  modal.classList.add('open');
  content.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const [detail, monthly] = await Promise.all([
      fetch('/api/v1/marketplace/providers/' + slug).then(r => r.json()),
      fetch('/api/v1/marketplace/providers/' + slug + '/monthly').then(r => r.json()),
    ]);
    const p = detail.provider;
    const periods = ['7d','30d','90d','all'];
    let activePeriod = '30d';

    function renderDetail() {
      const s = detail.stats[activePeriod] || {};
      const vae = s.volAdjExpectancy != null ? (s.volAdjExpectancy >= 0 ? '+' : '') + s.volAdjExpectancy.toFixed(3) : '—';
      const wr = s.winRate != null ? (s.winRate * 100).toFixed(1) + '%' : '—';
      const exp = s.expectancyR != null ? (s.expectancyR >= 0 ? '+' : '') + s.expectancyR.toFixed(3) + 'R' : '—';
      const sigma = s.rStddev != null ? s.rStddev.toFixed(3) : '—';
      const pf = s.profitFactor != null ? s.profitFactor.toFixed(2) : '—';
      const dd = s.maxDD != null ? s.maxDD.toFixed(1) + '%' : '—';
      const compl = s.dataCompleteness != null ? (s.dataCompleteness * 100).toFixed(1) + '%' : '—';
      const conf = s.sampleConfidence || '—';

      const lcHtml = s.lifecycle ? `
        <div style="margin-top:20px">
          <div style="font-weight:600;margin-bottom:8px;font-size:13px">Signal Lifecycle Completeness</div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
            ${['Entry|' + ((s.lifecycle.withEntry||0)*100).toFixed(0), 'SL|' + ((s.lifecycle.withSL||0)*100).toFixed(0), 'TP|' + ((s.lifecycle.withTP||0)*100).toFixed(0), 'Outcome|' + ((s.lifecycle.withOutcome||0)*100).toFixed(0)].map(x => {
              const [l,v] = x.split('|');
              return `<div style="text-align:center"><div style="font-family:var(--mono);font-weight:600;font-size:14px">${v}%</div><div style="font-size:10px;color:var(--text3)">${l}</div></div>`;
            }).join('')}
          </div>
        </div>` : '';

      const monthHtml = (monthly.months || []).slice(0,6).map(m => `
        <div style="display:flex;align-items:center;gap:12px;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
          <span style="font-family:var(--mono);width:60px;color:var(--text3)">${m.month}</span>
          <span style="width:50px;font-family:var(--mono);font-weight:600;color:${m.volAdjExpectancy > 0 ? 'var(--green)' : m.volAdjExpectancy < 0 ? 'var(--red)' : 'var(--text3)'}">${m.volAdjExpectancy != null ? m.volAdjExpectancy.toFixed(2) : '—'}</span>
          <span style="width:50px;color:var(--text2)">${m.trades} trades</span>
          <span style="width:50px;color:var(--text2)">${m.winRate != null ? (m.winRate*100).toFixed(0) + '%' : '—'} WR</span>
        </div>`).join('');

      const signalHtml = (detail.recentSignals || []).slice(0,5).map(s => `
        <div class="timeline-item">
          <span class="tl-type" style="color:${s.outcome==='HIT_TP'?'var(--green)':s.outcome==='HIT_SL'?'var(--red)':'var(--text3)'}">${s.outcome}</span>
          <span class="tl-pair">${s.symbol}</span>
          <span class="tl-r" style="color:${(s.rMultiple||0)>=0?'var(--green)':'var(--red)'}">${s.rMultiple!=null?(s.rMultiple>=0?'+':'')+s.rMultiple.toFixed(1)+'R':'—'}</span>
          <span class="tl-hash">${s.hashShort||''} ${s.wasEdited?'✏':''}${s.wasDeleted?'🗑':''}</span>
          <span class="tl-time">${new Date(s.timestamp).toLocaleDateString()}</span>
        </div>`).join('');

      content.innerHTML = `
        <div style="position:relative">
          <span style="position:absolute;top:0;right:0;font-size:18px;color:var(--text3);cursor:pointer" onclick="closeModal()">✕</span>
          <h2>${esc(p.name)} ${p.isVerified ? '<span style="color:var(--green);font-size:14px">● Verified</span>' : ''}</h2>
          <div class="subtitle">${esc(p.description || 'No description')} · Tracked since ${p.trackedSince ? new Date(p.trackedSince).toLocaleDateString() : 'Unknown'}</div>
          <div class="period-tabs">
            ${periods.map(pd => `<button class="period-tab ${pd===activePeriod?'active':''}" onclick="window._setPeriod('${pd}')">${pd}</button>`).join('')}
          </div>
          <div class="stat-grid">
            <div class="stat-card"><div class="val" style="color:${s.volAdjExpectancy>0?'var(--green)':'var(--red)'}">${vae}</div><div class="lbl">Vol-Adj Expectancy</div></div>
            <div class="stat-card"><div class="val">${exp}</div><div class="lbl">Raw Expectancy</div></div>
            <div class="stat-card"><div class="val">${wr}</div><div class="lbl">Win Rate</div></div>
            <div class="stat-card"><div class="val">${s.trades||0}</div><div class="lbl">Trades</div></div>
            <div class="stat-card"><div class="val">${sigma}</div><div class="lbl">R Std Dev</div></div>
            <div class="stat-card"><div class="val">${pf}</div><div class="lbl">Profit Factor</div></div>
            <div class="stat-card"><div class="val">${dd}</div><div class="lbl">Max Drawdown</div></div>
            <div class="stat-card"><div class="val">${conf}</div><div class="lbl">Sample Confidence</div></div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
            <span style="font-size:10px;font-weight:600;padding:3px 8px;border-radius:4px;background:${s.cherryLabel==='Clean'?'var(--green-dim)':s.cherryLabel==='Caution'?'var(--amber-dim)':'var(--red-dim)'};color:${s.cherryLabel==='Clean'?'var(--green)':s.cherryLabel==='Caution'?'var(--amber)':'var(--red)'}">${s.cherryLabel || 'Unknown'}</span>
            <span style="font-size:12px;color:var(--text3)">Cherry-Pick Score: ${s.cherryPickScore != null ? s.cherryPickScore.toFixed(3) : '—'}</span>
            <span style="font-size:12px;color:var(--text3)">· Data Completeness: ${compl}</span>
          </div>
          ${lcHtml}
          <div style="margin-top:24px">
            <div style="font-weight:600;margin-bottom:8px;font-size:13px">Monthly Breakdown</div>
            ${monthHtml || '<div style="color:var(--text3);font-size:12px">No monthly data yet</div>'}
          </div>
          <div style="margin-top:24px">
            <div style="font-weight:600;margin-bottom:8px;font-size:13px">Recent Signals</div>
            ${signalHtml || '<div style="color:var(--text3);font-size:12px">No recent signals with hashes</div>'}
          </div>
        </div>`;
    }

    window._setPeriod = function(pd) { activePeriod = pd; renderDetail(); };
    renderDetail();
  } catch(e) {
    content.innerHTML = '<div class="empty">Failed to load provider details</div>';
  }
}
function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function setType(el) {
  document.querySelectorAll('.type-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadProviders();
}

// ── SSE Live Feed ──
function connectSSE() {
  const feed = document.getElementById('ticker-feed');
  try {
    const es = new EventSource('/api/v1/feed/live');
    es.addEventListener('connected', () => { feed.innerHTML = '<span style="color:var(--green);font-size:11px">● Connected</span>'; });
    es.addEventListener('signal', e => {
      try {
        const d = JSON.parse(e.data);
        const color = d.type === 'HIT_TP' ? 'var(--green)' : d.type === 'HIT_SL' ? 'var(--red)' : 'var(--accent)';
        const icon = d.type === 'HIT_TP' ? '▲' : d.type === 'HIT_SL' ? '▼' : '◆';
        const item = document.createElement('span');
        item.className = 'ticker-item';
        item.innerHTML = `<span style="color:${color}">${icon}</span> <span style="color:var(--text2)">${d.provider}</span> <span style="font-weight:600">${d.pair}</span> ${d.result ? `<span style="color:${color}">${d.result}</span>` : ''}`;
        feed.insertBefore(item, feed.firstChild);
        if (feed.children.length > 20) feed.removeChild(feed.lastChild);
      } catch {}
    });
    es.onerror = () => { setTimeout(connectSSE, 5000); es.close(); };
  } catch { setTimeout(connectSSE, 5000); }
}
connectSSE();

// Load tier summary
(async function loadTierCounts() {
  try {
    const r = await fetch('/api/v1/marketplace/tiers/summary');
    const d = await r.json();
    document.getElementById('tier-counts').innerHTML =
      '<span style="color:var(--green)">' + d.verified + ' verified</span> · ' +
      '<span style="color:var(--blue)">' + d.beta + ' tracked</span> · ' +
      (d.verified + d.beta) + ' providers';
  } catch {}
})();

// Submit form
function openSubmitForm() {
  const modal = document.getElementById('modal');
  const content = document.getElementById('modal-content');
  modal.classList.add('open');
  content.innerHTML = `
    <div style="position:relative">
      <span style="position:absolute;top:0;right:0;font-size:18px;color:var(--text3);cursor:pointer" onclick="closeModal()">\u2715</span>
      <h2>Suggest a Signal Provider</h2>
      <div class="subtitle">Submit a Telegram or Discord channel for tracking. We'll review it within 48 hours.</div>
      <div style="display:flex;flex-direction:column;gap:14px;margin-top:20px">
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Channel Name *</label>
          <input id="sub-name" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px" placeholder="e.g. CryptoSignals VIP">
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Channel URL *</label>
          <input id="sub-url" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px" placeholder="https://t.me/channel_name">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Platform</label>
            <select id="sub-type" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px">
              <option value="telegram">Telegram</option><option value="discord">Discord</option>
            </select>
          </div>
          <div>
            <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Market Type</label>
            <select id="sub-market" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px">
              <option value="">Unknown</option><option>Spot</option><option>Futures</option><option>Mixed</option>
            </select>
          </div>
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Your Email (optional)</label>
          <input id="sub-email" type="email" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px" placeholder="you@example.com">
        </div>
        <div>
          <label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px">Description</label>
          <textarea id="sub-desc" rows="3" style="width:100%;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-size:13px;resize:vertical" placeholder="What makes this provider interesting?"></textarea>
        </div>
        <button id="sub-btn" onclick="submitProvider()" style="padding:10px 24px;border-radius:var(--r);background:var(--accent);color:#fff;font-size:14px;font-weight:600;border:none;cursor:pointer;margin-top:8px">Submit for Review</button>
        <div id="sub-status" style="font-size:12px;margin-top:4px"></div>
      </div>
    </div>`;
}

async function submitProvider() {
  const btn = document.getElementById('sub-btn');
  const status = document.getElementById('sub-status');
  const name = document.getElementById('sub-name').value.trim();
  const url = document.getElementById('sub-url').value.trim();
  if (!name || !url) { status.innerHTML = '<span style="color:var(--red)">Name and URL are required</span>'; return; }
  btn.disabled = true; btn.textContent = 'Submitting...';
  try {
    const r = await fetch('/api/v1/marketplace/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', ...(TOKEN ? { Authorization: 'Bearer ' + TOKEN } : {}) },
      body: JSON.stringify({
        channelName: name,
        channelUrl: url,
        channelType: document.getElementById('sub-type').value,
        email: document.getElementById('sub-email').value.trim() || null,
        marketType: document.getElementById('sub-market').value || null,
        description: document.getElementById('sub-desc').value.trim() || null,
      }),
    });
    const d = await r.json();
    if (d.submitted) {
      status.innerHTML = '<span style="color:var(--green)">\u2705 Submitted! We\'ll review within 48 hours.</span>';
      btn.textContent = 'Submitted';
    } else if (d.error === 'ALREADY_SUBMITTED') {
      status.innerHTML = '<span style="color:var(--amber)">This channel has already been submitted.</span>';
      btn.disabled = false; btn.textContent = 'Submit for Review';
    } else {
      status.innerHTML = '<span style="color:var(--red)">' + (d.error || 'Submission failed') + '</span>';
      btn.disabled = false; btn.textContent = 'Submit for Review';
    }
  } catch(e) {
    status.innerHTML = '<span style="color:var(--red)">Network error. Please try again.</span>';
    btn.disabled = false; btn.textContent = 'Submit for Review';
  }
}

function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
</script>
</body>
</html>