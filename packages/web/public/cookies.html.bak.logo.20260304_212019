          <td>Authenticated session token (HTTP-only, Secure, SameSite=Strict)</td>
          <td>7 days (sliding)</td>
          <td><span class="badge badge-green">Necessary</span></td>
        </tr>
        <tr>
          <td>aiq_refresh</td>
          <td>Silent session refresh token (HTTP-only)</td>
          <td>30 days</td>
          <td><span class="badge badge-green">Necessary</span></td>
        </tr>
        <tr>
