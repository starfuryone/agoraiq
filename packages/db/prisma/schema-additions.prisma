// ─────────────────────────────────────────────────────────────
// Smart Alerts v2 — Prisma Schema Additions
// Extends the v1 schema with event bus, DSL, priority, scoring
// Append to packages/db/prisma/schema.prisma
// Then run: pnpm --filter @agoraiq/db exec prisma migrate dev --name smart_alerts_v2
// ─────────────────────────────────────────────────────────────

enum AlertEventStatus {
  FIRED
  BLOCKED
  THROTTLED
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertCategory {
  SIGNAL
  MARKET
  WHALE
  LIQUIDATION
  PUMP
}

model AlertRule {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String

  name          String
  active        Boolean  @default(true)

  // Rule format indicator
  //   "legacy"     → conditions is a flat AlertConditions JSON (backward compat)
  //   "expression" → conditions contains a DSL AST (RuleNode JSON)
  ruleFormat    String   @default("legacy")

  // Filter conditions (format depends on ruleFormat)
  // Legacy: { minIQScore: 75, pairs: ["BTC/USDT"], ... }
  // DSL:    { type: "logical", op: "AND", left: {...}, right: {...} }
  conditions    Json

  // Which event categories this rule listens to
  // ["SIGNAL"] for legacy, ["SIGNAL","MARKET","WHALE"] for multi-category
  categories    Json     @default("[\"SIGNAL\"]")

  // Delivery channels: { web, telegram, email, discord, webpush }
  channels      Json

  // Minimum priority to fire (events below this priority are blocked)
  minPriority   AlertPriority @default(LOW)

  throttleMin   Int       @default(60)

  firedCount    Int       @default(0)
  blockedCount  Int       @default(0)
  lastFiredAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        AlertEvent[]

  @@index([userId, active])
  @@index([workspaceId, active])
}

model AlertEvent {
  id                String           @id @default(cuid())
  ruleId            String
  userId            String
  signalId          String?
  tradeId           String?

  status            AlertEventStatus
  priority          AlertPriority    @default(LOW)
  category          AlertCategory    @default(SIGNAL)
  alertScore        Int?             // 0-100 smart alert score

  // Human-readable pass/fail: ["IQ Score 91≥75 ✓", "category SIGNAL IN [SIGNAL] ✓"]
  matchedConditions Json

  // { web: "sent", telegram: "failed", dedup: "suppressed" }
  deliveryResults   Json             @default("{}")

  acknowledgedAt    DateTime?

  firedAt           DateTime         @default(now())

  rule              AlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, firedAt])
  @@index([userId, status, firedAt])
  @@index([userId, category, firedAt])
  @@index([signalId])
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  endpoint   String    @unique
  p256dh     String
  auth       String
  active     Boolean   @default(true)
  userAgent  String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

