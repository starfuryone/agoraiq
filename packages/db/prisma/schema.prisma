// ═══════════════════════════════════════════════════════════════
// @agoraiq/db — Prisma Schema
//
// Core tables:
//   Provider   — signal source config (webhook secret, proof_category)
//   Signal     — immutable incoming events (normalized + raw + idempotency)
//   Trade      — derived paper trades (entry/exit/TP/SL/status/R/P&L)
//   User       — app users with auth
//   Subscription — billing/entitlement
//   TelegramUser — Telegram ↔ User linkage
//   Watchlist  — user watchlists (pairs + providers)
//   AuditLog   — ingestion + admin event log
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Provider ──────────────────────────────────────────────────

model Provider {
  id            String   @id @default(cuid())
  slug          String   @unique                // e.g. "itb", "ext-provider-1"
  name          String                          // Display name
  description   String?
  proofCategory String   @default("all")        // spot | futures-low | futures-high | all
  isActive      Boolean  @default(true)
  config        Json     @default("{}")         // webhookSecret, rateLimits, ipAllowlist
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  marketplaceVisible  Boolean   @default(false) @map("marketplace_visible")
  trackedSince        DateTime? @map("tracked_since")
  marketType          String?   @map("market_type")
  tradingStyle        String?   @map("trading_style")
  leverageBand        String?   @map("leverage_band")
  exchangeFocus       String?   @map("exchange_focus")
  subscriberCount     Int?      @default(0) @map("subscriber_count")
  isVerified          Boolean   @default(false) @map("is_verified")
  language            String?   @default("EN")
  channelType         String?   @default("telegram") @map("channel_type")
  marketplaceTier     String    @default("PENDING") @map("marketplace_tier")
  providerType        String    @default("SIGNAL") @map("provider_type")
  category            String?
  chain               String?
  analyticsEligible   Boolean   @default(true) @map("analytics_eligible")

  statsSnapshots      ProviderStatsSnapshot[]
  monthlyStats        ProviderMonthlyStats[]
  auditEvents         SignalAuditEvent[]

  signals       Signal[]
  telegramSources TelegramSource[]
  trades        Trade[]

  @@map("providers")
}

// ── Signal ────────────────────────────────────────────────────

model Signal {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique              // provider_key+symbol+timeframe+ts
  schemaVersion   String   @default("1.0")
  providerKey     String                        // raw provider_key from payload
  providerId      String                        // FK to Provider
  workspaceId     String
  symbol          String                        // e.g. "BTCUSDT"
  timeframe       String                        // e.g. "1m", "5m", "1h"
  action          String                        // BUY | SELL | HOLD
  score           Float?
  confidence      Float?
  signalTs        DateTime                      // timestamp from provider
  price           Float?                        // price at signal time (optional)
  meta            Json?                         // model_version, etc.
  rawPayload      Json                          // full original payload (audit only)
  createdAt       DateTime @default(now())

  originalHash    String?   @map("original_hash")
  isExecutable    Boolean   @default(true) @map("is_executable")
  wasEdited       Boolean   @default(false) @map("was_edited")
  wasDeleted      Boolean   @default(false) @map("was_deleted")
  editCount       Int       @default(0) @map("edit_count")

  provider        Provider @relation(fields: [providerId], references: [id])
  trade           Trade?                        // 1:1 optional derived trade

  @@index([providerId, signalTs])
  @@index([workspaceId, symbol, signalTs])
  @@index([symbol, timeframe, signalTs])
  @@map("signals")
}

// ── Trade ─────────────────────────────────────────────────────

model Trade {
  id            String    @id @default(cuid())
  signalId      String    @unique              // 1:1 with Signal
  providerId    String
  workspaceId   String
  symbol        String
  timeframe     String
  direction     String                         // LONG | SHORT
  exchange      String    @default("BINANCE_FUTURES")
  leverage      Float?

  // Entry
  entryPrice    Float?
  enteredAt     DateTime?

  // Targets
  tpPrice       Float?
  slPrice       Float?
  tpPct         Float?                         // TP distance %
  slPct         Float?                         // SL distance %
  // Multi-TP targets
  tp1Price      Float?
  tp2Price      Float?
  tp3Price      Float?
  tp1HitAt      DateTime?
  tp2HitAt      DateTime?
  tp3HitAt      DateTime?
  tpHitCount    Int       @default(0)

  // Resolution
  status        String    @default("ACTIVE")   // ACTIVE | HIT_TP | HIT_SL | EXPIRED
  exitPrice     Float?
  exitedAt      DateTime?
  rMultiple     Float?                         // R-multiple
  pnlPct        Float?                         // P&L percentage

  // Timeout
  timeoutAt     DateTime?                      // when trade expires if no TP/SL

  // Metadata
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  signal        Signal    @relation(fields: [signalId], references: [id])
  provider      Provider  @relation(fields: [providerId], references: [id])

  @@index([workspaceId, status])
  @@index([workspaceId, symbol])
  @@index([workspaceId, providerId, status])
  @@index([status, timeoutAt])
  @@index([workspaceId, exitedAt])
  @@index([exchange, leverage])
  @@map("trades")
}

// ── User ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  workspaceId   String
  role          String    @default("user")     // user | admin
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription  Subscription?
  telegramUser  TelegramUser?
  watchlists    Watchlist[]
  telegramInvites     TelegramInvite[]
  telegramMemberships TelegramMembership[]
  referrals           Referral[] @relation("Referrals")
  preferences   Json      @default("{}")       // notification prefs, display prefs

  @@index([workspaceId])
  @@map("users")
}

// ── Subscription ──────────────────────────────────────────────

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  tier          String    @default("starter")  // starter | pro | elite
  status        String    @default("active")   // active | cancelled | past_due | trialing
  startsAt      DateTime  @default(now())
  endsAt        DateTime?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  stripePriceId        String?
  planTier             String    @default("FREE")
  subscriptionStatus   String    @default("inactive")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt


  @@map("subscriptions")
}

model WebhookEvent {
  id                String    @id @default(cuid())
  stripeEventId     String    @unique
  eventType         String
  payload           Json
  customerId        String?
  subscriptionId    String?
  processed         Boolean   @default(false)
  processingError   String?
  receivedAt        DateTime  @default(now())
  processedAt       DateTime?
  @@index([customerId])
  @@index([subscriptionId])
  @@index([processed])
  @@map("WebhookEvent")
}

// ── TelegramUser ──────────────────────────────────────────────

model TelegramUser {
  id            String    @id @default(cuid())
  telegramId    String    @unique              // Telegram user ID (numeric string)
  userId        String    @unique              // FK to User
  user          User      @relation(fields: [userId], references: [id])
  chatId        String                         // Telegram chat ID for sending messages
  username      String?                        // Telegram @username (optional, not exposed publicly)
  isActive      Boolean   @default(true)
  digestEnabled Boolean   @default(true)
  muteAll       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt


  @@map("telegram_users")
}

// ── Watchlist ─────────────────────────────────────────────────

model Watchlist {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  type          String                         // symbol | provider
  value         String                         // e.g. "BTCUSDT" or "itb"
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())


  @@unique([userId, type, value])
  @@index([userId, type])
  @@map("watchlists")
}

// ── AuditLog ──────────────────────────────────────────────────

model AuditLog {
  id            String    @id @default(cuid())
  action        String                         // signal.ingested | signal.rejected | trade.resolved | admin.*
  actorType     String    @default("system")   // system | provider | user | admin
  actorId       String?                        // provider slug or user ID
  resourceType  String?                        // signal | trade | provider | user
  resourceId    String?
  meta          Json?                          // additional context
  createdAt     DateTime  @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

enum PublishStatus {
  PENDING
  VALIDATED
  PUBLISHING
  PUBLISHED
  PARTIAL
  FAILED

  @@map("publish_status")
}

model SignalTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String   @db.VarChar(100)
  exchange    String   @db.VarChar(60)
  leverage    String?  @db.VarChar(20)
  footer      String?  @db.VarChar(120)
  channels    Json     @db.JsonB
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")

  publishes   SignalPublish[]

  @@index([userId], name: "idx_signal_template_user")
  @@index([workspaceId], name: "idx_signal_template_workspace")
  @@map("signal_templates")
}

model SignalPublish {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tradeId     String        @map("trade_id") @db.Uuid
  templateId  String?       @map("template_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  channels    Json          @db.JsonB
  format      String        @default("cornix") @db.VarChar(20)
  content     String        @db.Text
  status      PublishStatus @default(PENDING)
  validatedAt DateTime?     @map("validated_at")
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  results     Json?         @db.JsonB
  error       String?       @db.Text

  template    SignalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tradeId], name: "idx_signal_publish_trade")
  @@index([userId, createdAt(sort: Desc)], name: "idx_signal_publish_user")

  @@index([workspaceId, createdAt(sort: Desc)], name: "idx_signal_publish_workspace")

  @@map("signal_publishes")
}

model SignalLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  symbol      String
  direction   String?
  entryMin    Float?
  entryMax    Float?
  stopLoss    Float?
  takeProfits Json?
  leverage    Float?
  marketType  String?
  confidence  Float?
  rawMessage  String?
  note        String?
  createdAt   DateTime @default(now())


}

// ── Provider Stats Snapshot ───────────────────────────────────

model ProviderStatsSnapshot {
  id                  String   @id @default(cuid())
  providerId          String   @map("provider_id")
  period              String

  winRate             Float?   @map("win_rate")
  expectancyR         Float?   @map("expectancy_r")
  volAdjExpectancy    Float?   @map("vol_adj_expectancy")
  rStddev             Float?   @map("r_stddev")
  maxDrawdownPct      Float?   @map("max_drawdown_pct")
  tradeCount          Int      @default(0) @map("trade_count")
  profitFactor        Float?   @map("profit_factor")
  sampleConfidence    String?  @map("sample_confidence")

  dataCompleteness    Float?   @map("data_completeness")
  pctWithEntry        Float?   @map("pct_with_entry")
  pctWithSl           Float?   @map("pct_with_sl")
  pctWithTp           Float?   @map("pct_with_tp")
  pctWithOutcome      Float?   @map("pct_with_outcome")
  pctFullCycle        Float?   @map("pct_full_cycle")

  cherryPickScore     Float?   @map("cherry_pick_score")
  cherryDeleteRate    Float?   @map("cherry_delete_rate")
  cherryEditRate      Float?   @map("cherry_edit_rate")
  cherryUnresolvedRate Float?  @map("cherry_unresolved_rate")
  cherryAnnounceRatio Float?   @map("cherry_announce_ratio")
  cherryConfidence    Float?   @map("cherry_confidence")

  computedAt          DateTime @default(now()) @map("computed_at")

  provider            Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, period])
  @@map("provider_stats_snapshot")
}

model ProviderMonthlyStats {
  id                  String   @id @default(cuid())
  providerId          String   @map("provider_id")
  month               String

  winRate             Float?   @map("win_rate")
  expectancyR         Float?   @map("expectancy_r")
  volAdjExpectancy    Float?   @map("vol_adj_expectancy")
  rStddev             Float?   @map("r_stddev")
  maxDrawdownPct      Float?   @map("max_drawdown_pct")
  tradeCount          Int      @default(0) @map("trade_count")
  dataCompleteness    Float?   @map("data_completeness")
  cherryPickScore     Float?   @map("cherry_pick_score")
  sampleConfidence    String?  @map("sample_confidence")

  computedAt          DateTime @default(now()) @map("computed_at")

  provider            Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, month])
  @@map("provider_monthly_stats")
}

model SignalAuditEvent {
  id            String    @id @default(cuid())
  providerId    String    @map("provider_id")
  signalId      String?   @map("signal_id")
  eventType     String    @map("event_type")
  eventData     Json?     @map("event_data")
  detectedAt    DateTime  @default(now()) @map("detected_at")

  provider      Provider  @relation(fields: [providerId], references: [id])

  @@index([providerId, detectedAt(sort: Desc)])
  @@map("signal_audit_events")
}

model WorkspaceProviderImport {
  id            String    @id @default(cuid())
  workspaceId   String    @map("workspace_id")
  providerId    String    @map("provider_id")
  userId        String?   @map("user_id")
  isActive      Boolean   @default(true) @map("is_active")
  importedAt    DateTime  @default(now()) @map("imported_at")

  @@unique([workspaceId, providerId])
  @@map("workspace_provider_imports")
}

model ProviderSubmission {
  id              String    @id @default(cuid())
  channelName     String    @map("channel_name")
  channelUrl      String    @map("channel_url")
  channelType     String    @default("telegram") @map("channel_type")
  submitterEmail  String?   @map("submitter_email")
  submitterUserId String?   @map("submitter_user_id")
  description     String?
  marketType      String?   @map("market_type")
  tradingStyle    String?   @map("trading_style")
  subscriberCount Int?      @map("subscriber_count")
  status          String    @default("PENDING")
  reviewerNotes   String?   @map("reviewer_notes")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("provider_submissions")
}

// ── Telegram Bot Tables ───────────────────────────────────────

model TelegramLinkCode {
  id         String    @id @default(cuid())
  code       String    @unique
  telegramId String
  userId     String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  @@index([code])
  @@index([telegramId])
  @@index([expiresAt])
  @@map("telegram_link_codes")
}

model TelegramSource {
  id             String    @id @default(cuid())
  name           String
  telegramChatId String    @unique @map("telegram_chat_id")
  category       String    @default("crypto_signals")
  tierMin        String    @default("FREE") @map("tier_min")
  status         String    @default("active")
  sortOrder      Int       @default(0) @map("sort_order")
  providerId     String?   @map("provider_id")
  provider       Provider? @relation(fields: [providerId], references: [id])
  memberCount    Int       @default(0) @map("member_count")
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invites        TelegramInvite[]
  memberships    TelegramMembership[]
  @@index([category, status])
  @@index([tierMin])
  @@map("telegram_sources")
}

model TelegramInvite {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  sourceId   String
  source     TelegramSource @relation(fields: [sourceId], references: [id])
  telegramId String
  inviteLink String         @map("invite_link")
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())
  @@index([userId, sourceId])
  @@index([telegramId])
  @@index([expiresAt])
  @@map("telegram_invites")
}

model TelegramMembership {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  sourceId      String
  source        TelegramSource @relation(fields: [sourceId], references: [id])
  telegramId    String
  status        String         @default("active")
  joinedAt      DateTime       @default(now())
  removedAt     DateTime?
  removalReason String?        @map("removal_reason")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@unique([userId, sourceId])
  @@index([telegramId])
  @@index([status])
  @@map("telegram_memberships")
}

model TelegramAuditLog {
  id         String   @id @default(cuid())
  action     String
  telegramId String?
  userId     String?
  sourceId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  @@index([action])
  @@index([telegramId])
  @@index([userId])
  @@index([createdAt])
  @@map("telegram_audit_logs")
}

model Referral {
  id             String    @id @default(cuid())
  referrerUserId String    @map("referrer_user_id")
  referrer       User      @relation("Referrals", fields: [referrerUserId], references: [id])
  referralCode   String    @unique @map("referral_code")
  referredUserId String?   @map("referred_user_id")
  rewardType     String    @default("credit") @map("reward_type")
  rewardValue    Int       @default(0) @map("reward_value")
  status         String    @default("pending")
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  @@index([referrerUserId])
  @@index([referralCode])
  @@map("referrals")
}
