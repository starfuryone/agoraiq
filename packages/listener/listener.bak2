SESSION_NAME = os.environ.get("TG_SESSION_NAME", "agoraiq_listener")
API_URL = os.environ.get("AGORAIQ_API_URL", "http://127.0.0.1:4000/api/v1/providers")
LOG_LEVEL = os.environ.get("LISTENER_LOG_LEVEL", "INFO")

