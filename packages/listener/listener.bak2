# ── Signal Parser ──────────────────────────────────────────────

# Common crypto pairs
KNOWN_PAIRS = {
    "BTC", "ETH", "SOL", "XRP", "DOGE", "ADA", "AVAX", "DOT", "MATIC", "LINK",
    "UNI", "AAVE", "LTC", "BCH", "ATOM", "FIL", "APT", "ARB", "OP", "SUI",
    "SEI", "TIA", "NEAR", "FTM", "INJ", "RUNE", "PEPE", "WIF", "BONK", "SHIB",
    "BNB", "TRX", "ALGO", "VET", "SAND", "MANA", "CRV", "MKR", "COMP", "SNX",
    "RENDER", "FET", "ONDO", "JUP", "WLD", "STRK", "PYTH", "JTO", "DYM",
    "ORDI", "1000PEPE", "1000SHIB", "1000BONK", "1000FLOKI", "PEOPLE",
    "NOT", "TON", "ENA", "ETHFI", "W", "OMNI", "MERL", "REZ", "IO",
}

# Regex patterns for signal detection
PAIR_PATTERN = re.compile(
    r"(?:^|\s|#|\$)"
    r"([A-Z0-9]{2,10})"
    r"(?:/|\s*[-–]\s*|\s+)"
    r"(USDT?|BTC|ETH|BUSD|USDC)"
    r"(?:\s|$|[.!?,])",
    re.IGNORECASE,
)

STANDALONE_PAIR = re.compile(
    r"(?:^|\s|#|\$)([A-Z0-9]{2,10})(USDT|BUSD|USDC)(?:\s|$|[.!?,])",
    re.IGNORECASE,
)

DIRECTION_PATTERNS = {
    "BUY": re.compile(
        r"\b(buy|long|bullish|🟢|🔵|entry\s*(?:zone|price)?:?\s*\d)"
        r"\b", re.IGNORECASE
    ),
    "SELL": re.compile(
        r"\b(sell|short|bearish|🔴|🟠|close\s*(?:short)?)"
        r"\b", re.IGNORECASE
    ),
}

ENTRY_PATTERN = re.compile(
    r"(?:entry|enter|buy\s*(?:at|zone|price|@)?|sell\s*(?:at|zone|price|@)?|price)"
    r"\s*:?\s*\$?\s*(\d+[.,]?\d*)",
    re.IGNORECASE,
)

TP_PATTERN = re.compile(
    r"(?:tp|take\s*profit|target)\s*\d?\s*:?\s*\$?\s*(\d+[.,]?\d*)",
    re.IGNORECASE,
)

SL_PATTERN = re.compile(
    r"(?:sl|stop\s*loss|stop)\s*:?\s*\$?\s*(\d+[.,]?\d*)",
    re.IGNORECASE,
)

LEVERAGE_PATTERN = re.compile(
    r"(\d+)\s*[xX]\s*(?:leverage)?",
    re.IGNORECASE,
)

TIMEFRAME_PATTERN = re.compile(
    r"\b(\d+[mhHdDwW]|1[hH]|4[hH]|15[mM]|30[mM]|1[dD])\b",
)


def parse_number(s: str) -> float:
    """Parse number string, handling commas."""
    return float(s.replace(",", ""))


def extract_signal(text: str) -> Optional[dict]:
    """
    Attempt to extract a trading signal from message text.
    Returns None if the message doesn't look like a signal.
    """
    if not text or len(text) < 10:
        return None

    upper = text.upper()

    # Skip non-signal messages
    skip_words = ["RESULT", "CLOSED", "PROFIT BOOKED", "ALREADY", "UPDATE", 
                  "CONGRATULATIONS", "CONGRATS", "ADMIN", "JOIN", "SUBSCRIBE",
                  "FOLLOW", "CHANNEL", "PROMOTION", "AD ", "ADVERTISEMENT"]
    if any(w in upper for w in skip_words):
        return None

    # ── Extract pair ──────────────────────────────────────
    symbol = None

    # Try PAIR/USDT format first
    m = PAIR_PATTERN.search(text)
    if m:
        base = m.group(1).upper()
        quote = m.group(2).upper()
        if quote == "USD":
            quote = "USDT"
        symbol = f"{base}{quote}"

    # Try standalone BTCUSDT format
    if not symbol:
        m = STANDALONE_PAIR.search(text)
        if m:
            symbol = f"{m.group(1).upper()}{m.group(2).upper()}"

    # Try known pairs mentioned standalone
    if not symbol:
        for pair in KNOWN_PAIRS:
            pattern = re.compile(r"(?:^|\s|#|\$)" + pair + r"(?:\s|$|/|[.!?,])", re.IGNORECASE)
            if pattern.search(text):
                symbol = f"{pair}USDT"
                break

    if not symbol:
        return None

    # ── Extract direction ─────────────────────────────────
    action = None
    for act, pat in DIRECTION_PATTERNS.items():
        if pat.search(text):
            action = act
            break

    if not action:
        return None

    # ── Extract prices ────────────────────────────────────
    entry_match = ENTRY_PATTERN.search(text)
    entry_price = parse_number(entry_match.group(1)) if entry_match else None

    tp_matches = TP_PATTERN.findall(text)
    tp_prices = [parse_number(t) for t in tp_matches] if tp_matches else []

    sl_match = SL_PATTERN.search(text)
    sl_price = parse_number(sl_match.group(1)) if sl_match else None

    # ── Extract extras ────────────────────────────────────
    lev_match = LEVERAGE_PATTERN.search(text)
    leverage = int(lev_match.group(1)) if lev_match else None

    tf_match = TIMEFRAME_PATTERN.search(text)
    timeframe = tf_match.group(1) if tf_match else "1h"

    # ── Compute confidence based on completeness ──────────
    score = 0.3  # base for having pair + direction
    if entry_price:
        score += 0.2
    if tp_prices:
        score += 0.2
    if sl_price:
        score += 0.2
    if leverage:
        score += 0.1

    return {
        "symbol": symbol,
        "action": action,
        "timeframe": timeframe,
        "entry_price": entry_price,
        "tp_prices": tp_prices[:5],  # max 5 TPs
        "sl_price": sl_price,
        "leverage": leverage,
        "confidence": round(min(score, 1.0), 2),
    }


# ── API Client ─────────────────────────────────────────────────

async def post_signal(session: aiohttp.ClientSession, slug: str, token: str, signal: dict, raw_text: str):
    """POST parsed signal to the AgoraIQ ingestion API."""
    url = f"{API_URL}/{slug}/signals"

    payload = {
        "schema_version": "1.0",
        "provider_key": slug,
        "symbol": signal["symbol"],
        "timeframe": signal["timeframe"],
        "action": signal["action"],
        "confidence": signal["confidence"],
        "ts": datetime.now(timezone.utc).isoformat(),
        "price": signal.get("entry_price"),
        "meta": {
            "source": "telegram",
            "raw_text": raw_text[:2000],  # truncate for safety
            "tp_prices": signal.get("tp_prices", []),
            "sl_price": signal.get("sl_price"),
            "leverage": signal.get("leverage"),
            "entry_price": signal.get("entry_price"),
        },
    }

    headers = {
        "Content-Type": "application/json",
        "X-AgoraIQ-Provider-Token": token,
    }

    try:
        async with session.post(url, json=payload, headers=headers, timeout=aiohttp.ClientTimeout(total=10)) as resp:
            status = resp.status
            body = await resp.text()
            if status in (200, 201):
                log.info(f"✅ Signal ingested: {signal['symbol']} {signal['action']} via {slug}")
            elif status == 409:
                log.debug(f"⏭ Duplicate signal skipped: {signal['symbol']} via {slug}")
            else:
                log.warning(f"❌ Ingestion failed ({status}): {body[:200]}")
    except Exception as e:
        log.error(f"❌ API request failed for {slug}: {e}")


# ── Message Handler ────────────────────────────────────────────

async def handle_message(event, http_session: aiohttp.ClientSession):
    """Process an incoming channel message."""
    msg: Message = event.message
    if not msg or not msg.text:
        return

    # Identify the channel
    chat = await event.get_chat()
    username = getattr(chat, "username", None)

    if not username or username not in CHANNELS:
        return

    channel_config = CHANNELS[username]
    slug = channel_config["slug"]
    token = channel_config["token"]

    text = msg.text.strip()
    if len(text) < 10:
        return

    log.debug(f"📩 [{username}] {text[:100]}...")

    # Parse the signal
    signal = extract_signal(text)
    if not signal:
        log.debug(f"⏭ [{username}] No signal detected")
        return

    log.info(
        f"🔍 [{username}] Parsed: {signal['symbol']} {signal['action']} "
        f"entry={signal.get('entry_price')} tp={signal.get('tp_prices')} "
        f"sl={signal.get('sl_price')} conf={signal['confidence']}"
    )

    # Post to API
    await post_signal(http_session, slug, token, signal, text)


# ── Main ───────────────────────────────────────────────────────

async def main():
    log.info("🚀 AgoraIQ Telegram Channel Listener starting...")
    log.info(f"📡 Monitoring {len(CHANNELS)} channels")

    # Create Telegram client (userbot)
    client = TelegramClient(SESSION_NAME, API_ID, API_HASH)
    await client.start()

    me = await client.get_me()
    log.info(f"✅ Logged in as {me.first_name} ({me.phone})")

    # Resolve and join channels
    resolved_ids = []
    for username in CHANNELS:
        try:
            entity = await client.get_entity(f"@{username}")
            resolved_ids.append(entity.id)
            log.info(f"✅ Resolved @{username} → {entity.id}")
        except Exception as e:
            log.warning(f"⚠ Could not resolve @{username}: {e}")

    log.info(f"📡 Listening to {len(resolved_ids)} channels")

    # Create HTTP session for API calls
    http_session = aiohttp.ClientSession()

    # Register handler for new messages in monitored channels
    @client.on(events.NewMessage(chats=resolved_ids))
    async def on_new_message(event):
        try:
            await handle_message(event, http_session)
        except Exception as e:
            log.error(f"❌ Handler error: {e}", exc_info=True)

    log.info("🟢 Listener running — waiting for signals...")

    # Keep running
    try:
        await client.run_until_disconnected()
    finally:
        await http_session.close()


if __name__ == "__main__":
    asyncio.run(main())
