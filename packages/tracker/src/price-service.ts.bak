// ═══════════════════════════════════════════════════════════════
// @agoraiq/tracker — Price Service
//
// Fetches candle/price data from Binance, Bybit, Kraken.
//
// SOCKS5 PROXY ROUTING:
//   Binance (spot + futures) and Bybit → via danted SOCKS5 proxy
//   Kraken and everything else         → direct (no proxy)
//
// The proxy box (143.198.202.65) runs danted.service.
// Set SOCKS_PROXY_URL to override the default.
//
// Features:
//   - Per-exchange SOCKS5 / direct routing
//   - Symbol mapping per exchange
//   - In-memory candle cache (5 min TTL)
//   - Exponential backoff retry (3 attempts)
//   - Never blocks ingestion
//
// Environment:
//   SOCKS_PROXY_URL       — default: socks5://143.198.202.65:1080
//   SOCKS_PROXY_USERNAME  — optional Dante auth
//   SOCKS_PROXY_PASSWORD  — optional Dante auth
// ═══════════════════════════════════════════════════════════════

import https from 'node:https';
import http from 'node:http';
import { URL } from 'node:url';
import { SocksProxyAgent } from 'socks-proxy-agent';
import { createLogger } from '@agoraiq/db';

const log = createLogger('price-service');

// ── SOCKS5 Proxy Agent ────────────────────────────────────────

const SOCKS_PROXY_URL = process.env.SOCKS_PROXY_URL || 'socks5://143.198.202.65:1080';
const SOCKS_PROXY_USERNAME = process.env.SOCKS_PROXY_USERNAME || '';
const SOCKS_PROXY_PASSWORD = process.env.SOCKS_PROXY_PASSWORD || '';

function buildProxyUrl(): string {
  if (SOCKS_PROXY_USERNAME && SOCKS_PROXY_PASSWORD) {
    const parsed = new URL(SOCKS_PROXY_URL);
    parsed.username = SOCKS_PROXY_USERNAME;
    parsed.password = SOCKS_PROXY_PASSWORD;
    return parsed.toString();
  }
  return SOCKS_PROXY_URL;
}

let _socksAgent: SocksProxyAgent | null = null;

function getSocksAgent(): SocksProxyAgent {
  if (!_socksAgent) {
    _socksAgent = new SocksProxyAgent(buildProxyUrl());
    log.info({ proxy: SOCKS_PROXY_URL }, 'SOCKS5 proxy agent initialized');
  }
  return _socksAgent;
}

// Exchanges that MUST route through the SOCKS proxy
const PROXIED_EXCHANGES = new Set([
  'BINANCE_SPOT',
  'BINANCE_FUTURES',
  'BYBIT',
]);

// ── Price Cache ───────────────────────────────────────────────

interface PriceCacheEntry {
  price: number;
  high: number;
  low: number;
  ts: number;
}

const priceCache = new Map<string, PriceCacheEntry>();
const PRICE_CACHE_TTL_MS = 5 * 60_000; // 5 minutes

// ── Exchange Config ───────────────────────────────────────────

const BINANCE_SPOT = process.env.BINANCE_API_BASE || 'https://api.binance.com';
const BINANCE_FUTURES = process.env.BINANCE_FUTURES_API_BASE || 'https://fapi.binance.com';
const BYBIT_API = process.env.BYBIT_API_BASE || 'https://api.bybit.com';
const KRAKEN_API = process.env.KRAKEN_API_BASE || 'https://api.kraken.com';

// ── Symbol Mapping ────────────────────────────────────────────

function mapSymbol(symbol: string, exchange: string): string {
  const sym = symbol.toUpperCase();
  if (exchange === 'KRAKEN') {
    const krakenMap: Record<string, string> = {
      'BTCUSDT': 'XBTUSDT',
      'BTCUSD': 'XXBTZUSD',
      'ETHUSDT': 'ETHUSDT',
      'ETHUSD': 'XETHZUSD',
    };
    return krakenMap[sym] || sym;
  }
  return sym;
}

// ── HTTP GET (proxy-aware) ────────────────────────────────────
// Uses Node's https module (not native fetch/undici) so we can
// inject the SocksProxyAgent.  Native fetch doesn't support
// SOCKS agents.

function httpGet(url: string, useProxy: boolean): Promise<string> {
  return new Promise((resolve, reject) => {
    const parsed = new URL(url);
    const isHttps = parsed.protocol === 'https:';
    const mod = isHttps ? https : http;

    const options: https.RequestOptions = {
      hostname: parsed.hostname,
      port: parsed.port || (isHttps ? 443 : 80),
      path: parsed.pathname + parsed.search,
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'User-Agent': 'AgoraIQ-Tracker/1.0',
      },
      timeout: 15_000,
    };

    if (useProxy) {
      options.agent = getSocksAgent();
    }

    const req = mod.request(options, (res) => {
      if (res.statusCode && (res.statusCode < 200 || res.statusCode >= 300)) {
        res.resume(); // drain to free socket
        reject(new Error(`HTTP ${res.statusCode} from ${parsed.hostname}${parsed.pathname}`));
        return;
      }

      const chunks: Buffer[] = [];
      res.on('data', (chunk: Buffer) => chunks.push(chunk));
      res.on('end', () => resolve(Buffer.concat(chunks).toString('utf-8')));
      res.on('error', reject);
    });

    req.on('error', reject);
    req.on('timeout', () => {
      req.destroy(new Error(`Timeout (15s) fetching ${parsed.hostname}`));
    });
    req.end();
  });
}

async function fetchJson(url: string, useProxy: boolean): Promise<any> {
  const body = await httpGet(url, useProxy);
  return JSON.parse(body);
}

// ── Fetch with Retry ──────────────────────────────────────────

async function fetchWithRetry(
  url: string,
  useProxy: boolean,
  retries = 3,
  delay = 1000,
): Promise<any> {
  for (let i = 0; i < retries; i++) {
    try {
      return await fetchJson(url, useProxy);
    } catch (err: any) {
      if (i === retries - 1) throw err;
      const wait = delay * Math.pow(2, i);
      log.warn(
        { attempt: i + 1, url: url.split('?')[0], proxy: useProxy, wait, error: err?.message },
        'Price fetch retry',
      );
      await new Promise(r => setTimeout(r, wait));
    }
  }
}

// ── Get Current Price ─────────────────────────────────────────

export async function getCurrentPrice(
  symbol: string,
  exchange: string,
): Promise<{ price: number; high: number; low: number } | null> {
  const cacheKey = `${exchange}:${symbol}`;
  const cached = priceCache.get(cacheKey);
  if (cached && Date.now() - cached.ts < PRICE_CACHE_TTL_MS) {
    return { price: cached.price, high: cached.high, low: cached.low };
  }

  const useProxy = PROXIED_EXCHANGES.has(exchange);
  const mappedSymbol = mapSymbol(symbol, exchange);

  try {
    let data: any;

    // ── Binance Spot (SOCKS proxy) ────────────────────────
    if (exchange === 'BINANCE_SPOT') {
      data = await fetchWithRetry(
        `${BINANCE_SPOT}/api/v3/klines?symbol=${mappedSymbol}&interval=1m&limit=1`,
        useProxy,
      );
      if (data?.length > 0) {
        const c = data[0];
        return cacheAndReturn(cacheKey, parseFloat(c[4]), parseFloat(c[2]), parseFloat(c[3]));
      }

    // ── Binance Futures (SOCKS proxy) ─────────────────────
    } else if (exchange === 'BINANCE_FUTURES') {
      data = await fetchWithRetry(
        `${BINANCE_FUTURES}/fapi/v1/klines?symbol=${mappedSymbol}&interval=1m&limit=1`,
        useProxy,
      );
      if (data?.length > 0) {
        const c = data[0];
        return cacheAndReturn(cacheKey, parseFloat(c[4]), parseFloat(c[2]), parseFloat(c[3]));
      }

    // ── Bybit V5 (SOCKS proxy) ───────────────────────────
    } else if (exchange === 'BYBIT') {
      data = await fetchWithRetry(
        `${BYBIT_API}/v5/market/kline?category=linear&symbol=${mappedSymbol}&interval=1&limit=1`,
        useProxy,
      );
      // Response: { retCode:0, result: { list: [[ ts, open, high, low, close, vol, turnover ]] } }
      const klines = data?.result?.list;
      if (klines?.length > 0) {
        const c = klines[0];
        return cacheAndReturn(cacheKey, parseFloat(c[4]), parseFloat(c[2]), parseFloat(c[3]));
      }

    // ── Kraken REST (direct — no proxy) ──────────────────
    } else if (exchange === 'KRAKEN') {
      data = await fetchWithRetry(
        `${KRAKEN_API}/0/public/OHLC?pair=${mappedSymbol}&interval=1`,
        false,
      );
      // Response: { error:[], result: { "XXBTZUSD": [[ ts, o, h, l, c, vwap, vol, count ]], last: N } }
      if (data && !data.error?.length && data.result) {
        const pairKey = Object.keys(data.result).find(k => k !== 'last');
        const klines = pairKey ? data.result[pairKey] : null;
        if (klines?.length > 0) {
          const c = klines[klines.length - 1]; // most recent candle
          return cacheAndReturn(cacheKey, parseFloat(c[4]), parseFloat(c[2]), parseFloat(c[3]));
        }
      }

    } else {
      log.warn({ exchange, symbol }, 'Unknown exchange — cannot fetch price');
    }

    return null;
  } catch (err) {
    log.error({ err, symbol, exchange, proxy: useProxy }, 'Failed to fetch price');
    return null;
  }
}

// ── Cache helper ──────────────────────────────────────────────

function cacheAndReturn(
  key: string, price: number, high: number, low: number,
): { price: number; high: number; low: number } {
  priceCache.set(key, { price, high, low, ts: Date.now() });
  return { price, high, low };
}

// ── Check if Price Hit TP/SL ──────────────────────────────────

export interface PriceCheck {
  hitTP: boolean;
  hitSL: boolean;
  currentPrice: number;
  high: number;
  low: number;
}

export async function checkPriceHit(
  symbol: string,
  exchange: string,
  direction: string, // LONG | SHORT
  tpPrice: number | null,
  slPrice: number | null,
): Promise<PriceCheck | null> {
  const priceData = await getCurrentPrice(symbol, exchange);
  if (!priceData) return null;

  const { price, high, low } = priceData;
  let hitTP = false;
  let hitSL = false;

  if (direction === 'LONG') {
    if (tpPrice && high >= tpPrice) hitTP = true;
    if (slPrice && low <= slPrice) hitSL = true;
  } else {
    if (tpPrice && low <= tpPrice) hitTP = true;
    if (slPrice && high >= slPrice) hitSL = true;
  }

  return { hitTP, hitSL, currentPrice: price, high, low };
}
