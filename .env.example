# ═══════════════════════════════════════════════════════════════
# AgoraIQ — Environment Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://agoraiq:changeme@localhost:5432/agoraiq?schema=public"

# ── Redis (caching, rate limiting, queues) ─────────────────────
REDIS_URL="redis://localhost:6379"

# ── Server ─────────────────────────────────────────────────────
NODE_ENV="production"
API_PORT=4000
API_HOST="0.0.0.0"
API_BASE_URL="https://agoraiq.net"
CORS_ORIGINS="https://agoraiq.net,http://localhost:3000"

# ── Auth / JWT ─────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_EXPIRY="7d"

# ── Proof / Public Demo ───────────────────────────────────────
# The workspace ID used for all public proof queries
PROOF_WORKSPACE_ID="proof-workspace-default"
# Active trade delay in minutes for public mode
PROOF_ACTIVE_DELAY_MINUTES=15
# Max feed items for public mode
PROOF_MAX_FEED_ITEMS=25
# Max months for public monthly table
PROOF_MAX_MONTHS=12

# ── Provider Webhook Secrets ───────────────────────────────────
# ITB in-house provider token (header: X-AgoraIQ-Provider-Token)
ITB_PROVIDER_TOKEN="change-this-itb-secret-token"
# Additional provider tokens (comma-separated key=value pairs)
# Format: PROVIDER_TOKENS="provider-slug-1=token1,provider-slug-2=token2"
PROVIDER_TOKENS=""

# ── Rate Limiting ──────────────────────────────────────────────
# Public proof endpoints: requests per window
RATE_LIMIT_PROOF_MAX=60
RATE_LIMIT_PROOF_WINDOW_MS=60000
# Provider webhook: requests per window
RATE_LIMIT_WEBHOOK_MAX=120
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
# SSE max concurrent connections
SSE_MAX_CONNECTIONS=100

# ── Telegram Bot ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
# Default workspace for Telegram-linked users
TELEGRAM_DEFAULT_WORKSPACE_ID="proof-workspace-default"

# ── Exchange Price APIs ────────────────────────────────────────
BINANCE_API_BASE="https://api.binance.com"
BINANCE_FUTURES_API_BASE="https://fapi.binance.com"
BYBIT_API_BASE="https://api.bybit.com"
KRAKEN_API_BASE="https://api.kraken.com"

# ── SOCKS5 Proxy (danted on 143.198.202.65) ───────────────────
# Binance and Bybit API calls route through this proxy.
# Kraken, Coinbase, and others go direct (no proxy).
SOCKS_PROXY_URL="socks5://143.198.202.65:1080"
SOCKS_PROXY_USERNAME=""
SOCKS_PROXY_PASSWORD=""

# ── Tracker Worker ─────────────────────────────────────────────
# How often the tracker polls for active trades to resolve (ms)
TRACKER_POLL_INTERVAL_MS=30000
# Trade timeout in hours (EXPIRED if no TP/SL hit)
TRACKER_DEFAULT_TIMEOUT_HOURS=72
# Default TP/SL percentages if not provided by signal
TRACKER_DEFAULT_TP_PCT=3.0
TRACKER_DEFAULT_SL_PCT=1.5

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL="info"
